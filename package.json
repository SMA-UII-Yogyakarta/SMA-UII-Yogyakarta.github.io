{
  "name": "smauii-dev-foundation",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0",
    "bun": ">=1.1.0"
  },
  "scripts": {
    "dev": "astro dev",
    "dev:api": "bun run --cwd smauii-dev-api dev",
    "dev:all": "concurrently --names \"WEB,API\" --prefix-colors \"blue,green\" \"bun run dev\" \"bun run dev:api\"",
    "build": "astro build",
    "preview": "echo '\\n⚠️  Mau test SSR atau SSG bos?\\n  bun run preview:ssr  → build + jalankan Node server (output: server)\\n  bun run preview:ssg  → build + serve static files (output: static)\\n'",
    "preview:ssr": "astro build && node dist/server/entry.mjs",
    "preview:ssg": "astro build && astro preview",
    "astro": "astro",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:migrate": "bun run scripts/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "db:seed": "bun run scripts/seed.ts",
    "db:seed:enhanced": "bun run scripts/seed-enhanced.ts",
    "db:setup": "bun run db:migrate && bun run db:seed",
    "db:setup:enhanced": "bun run scripts/drop-tables.ts && bun run db:push && bun run db:seed:enhanced",
    "test": "bun test tests/unit",
    "test:watch": "bun test tests/unit --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "bun test && playwright test",
    "ci": "bash scripts/ci-local.sh",
    "check": "astro check",
    "typecheck": "astro check"
  },
  "trustedDependencies": [
    "esbuild",
    "sharp"
  ],
  "peerDependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.4",
    "@astrojs/react": "^5.0.3",
    "@libsql/client": "^0.17.2",
    "@lucia-auth/adapter-drizzle": "^1.1.0",
    "@node-rs/argon2": "^2.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "arctic": "^3.7.0",
    "astro": "^6.1.6",
    "drizzle-orm": "^0.45.2",
    "lucia": "^3.2.2",
    "nanoid": "^5.1.7",
    "qrcode": "^1.5.4",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "remark-mermaidjs": "^7.0.0",
    "resend": "^6.12.2",
    "tailwindcss": "^4.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@playwright/test": "^1.59.1",
    "@types/qrcode": "^1.5.6",
    "bun-types": "^1.3.12",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2"
  }
}
