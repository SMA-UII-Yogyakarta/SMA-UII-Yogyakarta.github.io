# =============================================================================
# SMAUII Lab - Environment Configuration Example
# =============================================================================
# Copy file ini ke .env dan isi dengan credentials yang sesuai
# JANGAN commit .env ke git!

# -----------------------------------------------------------------------------
# Database - Turso (LibSQL)
# -----------------------------------------------------------------------------
# Development/Preview: smauiilab-prev (aman untuk testing & CI)
TURSO_URL=libsql://smauiilab-prev-sandikodev.aws-ap-northeast-1.turso.io
TURSO_TOKEN=your-turso-dev-token-here

# Production: smauiilab (uncomment untuk production deployment)
# TURSO_URL=libsql://smauiilab-sandikodev.aws-us-east-1.turso.io
# TURSO_TOKEN=your-turso-prod-token-here

# -----------------------------------------------------------------------------
# SLiMS Integration (untuk verifikasi NISN/NIS)
# -----------------------------------------------------------------------------
# Sementara menggunakan mock data, akan diimplementasikan nanti
SLIMS_API_URL=https://slims.smauiiyk.sch.id/api
SLIMS_API_KEY=your-slims-api-key

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
# Setup di: https://github.com/settings/developers
# Callback URL (dev):  http://localhost:4321/api/auth/github/callback
# Callback URL (prod): https://lab.smauiiyk.sch.id/api/auth/github/callback
OAUTH_GITHUB_CLIENT_ID=your-github-client-id
OAUTH_GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
# Development
PUBLIC_SITE_URL=http://localhost:4321
# Production
# PUBLIC_SITE_URL=https://lab.smauiiyk.sch.id
PUBLIC_SITE_NAME=SMA UII Lab

# -----------------------------------------------------------------------------
# Email Notifications (opsional, belum diimplementasikan)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@smauiiyk.sch.id

# =============================================================================
# GitHub Actions Secrets yang perlu diset di repo:
# Settings → Secrets and variables → Actions → New repository secret
# =============================================================================
# TURSO_URL          → nilai TURSO_URL di atas (smauiilab-prev)
# TURSO_TOKEN        → nilai TURSO_TOKEN di atas
# OAUTH_GITHUB_CLIENT_ID     → nilai OAUTH_GITHUB_CLIENT_ID di atas
# OAUTH_GITHUB_CLIENT_SECRET → nilai OAUTH_GITHUB_CLIENT_SECRET di atas
