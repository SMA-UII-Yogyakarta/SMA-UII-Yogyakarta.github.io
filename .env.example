# =============================================================================
# SMAUII Lab — Environment Template
# Copy file ini ke .env.local dan isi nilainya.
# File ini BOLEH di-commit (tidak berisi nilai nyata).
# =============================================================================

# -----------------------------------------------------------------------------
# Deployment Mode (SSR/SSG/Hybrid)
# - ssr:    Fullstack Astro SSR (Docker/VPS) — default
# - ssg:    Static frontend (GH Pages/CF Pages) + Hono API (CF Workers)
# - hybrid: Astro SSR + Hono API terpisah
# -----------------------------------------------------------------------------
DEPLOY_MODE=ssr

# -----------------------------------------------------------------------------
# External API URL (wajib untuk ssg/hybrid mode)
# Contoh: https://smauii-dev-api.your-username.workers.dev
# -----------------------------------------------------------------------------
PUBLIC_API_URL=

# -----------------------------------------------------------------------------
# Database — Turso (LibSQL)
# Buat database di: https://turso.tech
# -----------------------------------------------------------------------------
TURSO_URL=libsql://your-db-name.turso.io
TURSO_TOKEN=your-turso-auth-token

# -----------------------------------------------------------------------------
# GitHub OAuth
# Buat OAuth App di: https://github.com/settings/developers
# Development callback: http://localhost:4321/api/auth/github/callback
# Production callback:  https://lab.smauiiyk.sch.id/api/auth/github/callback
# -----------------------------------------------------------------------------
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# -----------------------------------------------------------------------------
# SLiMS API (untuk verifikasi NIS siswa)
# Internal network: http://smauii-slims-app/plugins/lab-digital-api
# Kosongkan untuk pakai mock data (development tanpa SLiMS)
# -----------------------------------------------------------------------------
SLIMS_API_URL=
SLIMS_API_KEY=

# -----------------------------------------------------------------------------
# Site URL
# Development: http://localhost:4321
# Production:  https://lab.smauiiyk.sch.id
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=http://localhost:4321

# -----------------------------------------------------------------------------
# Email Notifications (opsional)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@smauiiyk.sch.id

# Resend API (recommended)
# Get API key: https://resend.com/api-keys
# Free tier: 3,000 emails/month, 100 emails/day
RESEND_API_KEY=

# -----------------------------------------------------------------------------
# GitHub Personal Access Token (opsional)
# Untuk fetch kontribusi GitHub di profile
# Tanpa token: 60 requests/hour (unauthenticated)
# Dengan token: 5,000 requests/hour (authenticated)
# Buat di: https://github.com/settings/tokens
# Scope: public_repo (read-only)
# -----------------------------------------------------------------------------
GITHUB_PAT=
