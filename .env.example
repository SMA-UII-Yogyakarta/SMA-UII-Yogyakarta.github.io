# =============================================================================
# SMAUII Lab - Environment Configuration Example
# =============================================================================
# Copy file ini ke .env dan isi dengan credentials yang sesuai

# -----------------------------------------------------------------------------
# Database - Turso (LibSQL)
# -----------------------------------------------------------------------------
PUBLIC_TURSO_URL=libsql://your-database.turso.io
PUBLIC_TURSO_TOKEN=your-turso-token-here

# -----------------------------------------------------------------------------
# SLiMS Integration
# -----------------------------------------------------------------------------
SLIMS_API_URL=https://slims.smauiiyk.sch.id/api
SLIMS_API_KEY=your-slims-api-key

# -----------------------------------------------------------------------------
# GitHub OAuth
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# -----------------------------------------------------------------------------
# Site Configuration
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=https://lab.smauiiyk.sch.id
PUBLIC_SITE_NAME=SMA UII Lab

# -----------------------------------------------------------------------------
# Email Notifications (opsional)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=noreply@smauiiyk.sch.id
