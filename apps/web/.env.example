# =============================================================================
# SMAUII Lab — Environment Variables Template
# =============================================================================
# Copy file ini ke .env.local dan isi dengan nilai yang sesuai.
# JANGAN commit .env.local ke git! (sudah ada di .gitignore)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 PUBLIC VARIABLES (Client-side)
# Variables dengan prefix PUBLIC_ bisa diakses di browser
# Aman untuk di-expose, tidak mengandung secrets
# ─────────────────────────────────────────────────────────────────────────────

# Site URL — Domain produksi untuk canonical URL, sitemap, og:url
# Format: https://domain.com
# Required untuk: SEO, sitemap, social media sharing
PUBLIC_SITE_URL=https://lab.smauiiyk.sch.id

# API URL — Backend API endpoint
# Untuk SSG mode: semua API calls akan ke URL ini
# Untuk SSR mode: digunakan untuk external API calls
# Format: https://your-api.workers.dev atau https://api.domain.com
PUBLIC_API_URL=https://smauii-dev-api.konxcid.workers.dev

# ─────────────────────────────────────────────────────────────────────────────
# 🔒 SECRET VARIABLES (Server-side ONLY)
# JANGAN expose ke client! Hanya tersedia di server-side code
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (Turso/LibSQL) ─────────────────────────────────────────────────
# Required untuk: Database connections, ORM (Drizzle)
# Get from: https://console.turso.tech
TURSO_URL=libsql://your-db.your-org.turso.io
TURSO_TOKEN=your_turso_auth_token

# ── OAuth (GitHub) ──────────────────────────────────────────────────────────
# Required untuk: GitHub OAuth authentication
# Get from: https://github.com/settings/developers
# Callback URL: https://your-domain.com/api/auth/github/callback
OAUTH_GITHUB_CLIENT_ID=your_github_client_id
OAUTH_GITHUB_CLIENT_SECRET=your_github_client_secret

# ── JWT Secret ──────────────────────────────────────────────────────────────
# Required untuk: JWT token signing & verification
# Generate: openssl rand -hex 32
# Keep this SECRET! Jangan share ke manapun.
JWT_SECRET=your_super_secret_jwt_key_min_32_chars

# ── SLiMS API (Optional) ────────────────────────────────────────────────────
# Optional untuk: Integrasi dengan sistem perpustakaan SLiMS
# Leave empty kalau tidak pakai SLiMS (akan pakai mock data)
# Format: https://slims.your-school.edu/plugins/lab-digital-api
SLIMS_API_URL=
SLIMS_API_KEY=

# ── GitHub Personal Access Token (Optional) ─────────────────────────────────
# Optional untuk: Fetch GitHub contributions API
# Get from: https://github.com/settings/tokens
# Scope: public_repo, read:user
GITHUB_PAT=

# ─────────────────────────────────────────────────────────────────────────────
# 🔧 DEVELOPMENT VARIABLES (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Deploy Mode — Controls build output
# Options: ssr | ssg | hybrid
# Default: ssr (Server-Side Rendering)
# - ssr: Server-side rendering (Vercel, Railway, Node.js)
# - ssg: Static site generation (Cloudflare Pages static, GitHub Pages)
# - hybrid: Mixed mode (Cloudflare Pages with Functions)
DEPLOY_MODE=ssr

# Node Environment
# Default: development (local), production (deploy)
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# 📋 QUICK SETUP GUIDE
# ─────────────────────────────────────────────────────────────────────────────

# 1. Copy file ini:
#    cp .env.example .env.local
#
# 2. Isi required variables:
#    - TURSO_URL & TURSO_TOKEN (dari Turso Console)
#    - OAUTH_GITHUB_CLIENT_ID & SECRET (dari GitHub Developer Settings)
#    - JWT_SECRET (generate dengan: openssl rand -hex 32)
#    - PUBLIC_SITE_URL & PUBLIC_API_URL (domain produksi Anda)
#
# 3. Optional variables:
#    - SLIMS_API_URL & KEY (kalau pakai integrasi perpustakaan)
#    - GITHUB_PAT (kalau mau fetch GitHub contributions)
#
# 4. Verify setup:
#    bun run dev
#
# ─────────────────────────────────────────────────────────────────────────────
# 🚀 DEPLOYMENT CHECKLIST
# ─────────────────────────────────────────────────────────────────────────────

# ✅ Cloudflare Workers (API):
#    wrangler secret put TURSO_URL
#    wrangler secret put TURSO_TOKEN
#    wrangler secret put JWT_SECRET
#    wrangler secret put SLIMS_API_URL (optional)
#    wrangler secret put SLIMS_API_KEY (optional)
#
# ✅ Vercel/Railway/Netlify (Web SSR):
#    Set di dashboard: TURSO_URL, TURSO_TOKEN, JWT_SECRET, PUBLIC_API_URL
#
# ✅ Cloudflare Pages (Web SSG):
#    Settings → Environment Variables → Production
#    Add: PUBLIC_API_URL, PUBLIC_SITE_URL
#
# ─────────────────────────────────────────────────────────────────────────────
# 🔐 SECURITY NOTES
# ─────────────────────────────────────────────────────────────────────────────

# - JANGAN commit .env.local ke git (sudah di .gitignore)
# - JANGAN log atau print secret values di console
# - Gunakan https:// untuk semua production URLs
# - Rotate JWT_SECRET secara berkala
# - Gunakan different secrets untuk development vs production
# - Enable 2FA untuk GitHub account yang linked ke OAuth app
#
# ─────────────────────────────────────────────────────────────────────────────