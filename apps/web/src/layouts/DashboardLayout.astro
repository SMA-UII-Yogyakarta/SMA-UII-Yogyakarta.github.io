---
import '@styles/global.css';
import Sidebar from '@components/Sidebar.astro';
import Topbar from '@components/Topbar.astro';
import BottomNav from '@components/BottomNav.astro';
import Toast from '@components/app/Toast.astro';
import Modal from '@components/app/Modal.astro';
import { getSiteConfig } from '@smauii/shared';

const config = getSiteConfig();

interface Props {
  title: string;
  noPadding?: boolean;
  requiredRole?: 'maintainer' | 'member' | 'auth';
}

const { title, noPadding = false, requiredRole = 'auth' } = Astro.props;

// DashboardLayout is SSG-first - user data comes from client-side script
// For Mode A (SSR), pages can pass initialUser via props if needed
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{title} — {config.site.name}</title>
  <link rel="icon" href="/favicon.svg" />
  <slot name="head" />
  <script is:inline>
    // Set sidebar state sebelum render — tidak ada FOUC
    (function() {
      const saved = localStorage.getItem('sidebar-collapsed');
      const w = window.innerWidth;
      let state;
      if (w < 640) state = 'hidden';
      else if (w < 1024) state = 'minimized';
      else state = (saved === 'true') ? 'minimized' : 'expanded';
      document.documentElement.setAttribute('data-sidebar', state);
    })();
  </script>
  <style is:global>
    /* ── Sidebar states ── */
    :root[data-sidebar="hidden"]    #sidebar { width: 16rem; transform: translateX(-100%); }
    :root[data-sidebar="minimized"] #sidebar { width: 4rem;  transform: translateX(0); }
    :root[data-sidebar="expanded"]  #sidebar { width: 16rem; transform: translateX(0); }
    :root[data-sidebar="overlay"]   #sidebar { width: 16rem; transform: translateX(0); z-index: 60; }

    /* ── Main content offset ── */
    :root[data-sidebar="hidden"]    #main-content { margin-left: 0; }
    :root[data-sidebar="minimized"] #main-content { margin-left: 4rem; }
    :root[data-sidebar="expanded"]  #main-content { margin-left: 16rem; }
    :root[data-sidebar="overlay"]   #main-content { margin-left: 4rem; }

    /* ── Label visibility ── */
    :root[data-sidebar="minimized"] #sidebar .sidebar-label { display: none; }
    :root[data-sidebar="expanded"]  #sidebar .sidebar-label,
    :root[data-sidebar="overlay"]   #sidebar .sidebar-label { display: unset; }

    /* ── Nav items: minimized = icon only ── */
    :root[data-sidebar="minimized"] #sidebar-nav { padding: 0.5rem; display: flex; flex-direction: column; gap: 0.25rem; }
    :root[data-sidebar="minimized"] #sidebar-nav a { justify-content: center; padding: 0; width: 2.5rem; height: 2.5rem; margin: 0 auto; }
    :root[data-sidebar="minimized"] #sidebar-header { padding: 1rem 0.5rem; }
    :root[data-sidebar="minimized"] #sidebar-header a { justify-content: center; }
    :root[data-sidebar="minimized"] #sidebar-user { padding: 0.5rem; }
    :root[data-sidebar="minimized"] #sidebar-user button { justify-content: center; padding: 0.5rem; }

    /* ── Nav items: overlay = full expanded (explicit reset) ── */
    :root[data-sidebar="overlay"] #sidebar-nav { padding: 1rem; display: flex; flex-direction: column; gap: 0.25rem; }
    :root[data-sidebar="overlay"] #sidebar-nav a { justify-content: flex-start; padding: 0.625rem 0.75rem; width: auto; height: auto; margin: 0; }
    :root[data-sidebar="overlay"] #sidebar-header { padding: 0 0.75rem; }
    :root[data-sidebar="overlay"] #sidebar-header a { justify-content: flex-start; }
    :root[data-sidebar="overlay"] #sidebar-user { padding: 1rem; }
    :root[data-sidebar="overlay"] #sidebar-user button { justify-content: flex-start; padding: 0.5rem; }

    #main-content { transition: margin-left 0.3s; }
    #sidebar { transition: width 0.3s, transform 0.3s; }

    .skeleton { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    /* Mobile: add padding bottom to prevent BottomNav overlay */
    #dashboard-content {
      padding-bottom: calc(72px + env(safe-area-inset-bottom)) !important;
    }
    /* Desktop/tablet: reset padding bottom (no BottomNav) */
    @media (min-width: 640px) {
      #dashboard-content { padding-bottom: 1rem !important; }
    }
    /* ── Navigation progress bar ── */
    #nav-progress {
      position: fixed;
      top: 0;
      left: 0;
      height: 2px;
      background: linear-gradient(90deg, #3b82f6, #8b5cf6, #3b82f6);
      background-size: 200% 100%;
      z-index: 9999;
      width: 0;
      transition: width 0.3s ease, opacity 0.3s ease;
      opacity: 0;
      pointer-events: none;
    }
    #nav-progress.active {
      opacity: 1;
      animation: progress-indeterminate 1.5s ease infinite;
    }
    @keyframes progress-indeterminate {
      0% { width: 0%; background-position: 0% 0; }
      30% { width: 50%; }
      70% { width: 70%; }
      100% { width: 85%; background-position: 200% 0; }
    }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased overflow-hidden">
  <div id="nav-progress"></div>
  <div class="flex h-dvh"  style="height: 100dvh">
    <!-- Sidebar, Topbar, BottomNav get user data from client-side script via dashboard-meta -->
    <Sidebar role="member" userName="" userEmail="" userAvatarUrl="" />

    <main id="main-content" class="flex-1 flex flex-col">
      <Topbar userName="" userAvatarUrl="">
        <Fragment slot="title"><slot name="title">{title}</slot></Fragment>
        <slot name="topbar-actions" slot="actions" />
      </Topbar>

      <div class={noPadding ? 'flex-1 overflow-hidden' : 'flex-1 overflow-y-auto p-4'} id="dashboard-content" style="-webkit-overflow-scrolling: touch;">
        <slot />
      </div>
    </main>
  </div>

  <BottomNav role="member" />

  <div id="notification-dropdown" class="hidden fixed right-4 sm:right-6 top-16 w-80 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto">
    <div class="p-3 border-b border-gray-800">
      <h3 class="font-semibold text-sm">Notifikasi</h3>
    </div>
    <div id="notification-list" class="p-2">
      <p class="text-sm text-gray-500 text-center py-4">Tidak ada notifikasi</p>
    </div>
  </div>

  <div id="dashboard-meta" data-role={role} data-username={userName} data-api-url={import.meta.env.PUBLIC_API_URL || ''} style="display:none"></div>
  <div id="page-requirements" data-required-role={requiredRole} style="display:none"></div>

  <Toast />

  <!-- Global confirm action sheet — gantikan confirm() native -->
  <Modal id="confirm-modal" title="Konfirmasi" showCloseButton={false} closeOnBackdrop={false}>
    <p id="confirm-msg" class="text-sm text-gray-300 mb-6"></p>
    <div class="flex gap-3">
      <button id="confirm-cancel" type="button"
        class="flex-1 px-4 py-2.5 bg-gray-800 text-gray-300 rounded-lg text-sm font-medium hover:bg-gray-700 transition">Batal</button>
      <button id="confirm-ok" type="button"
        class="flex-1 px-4 py-2.5 text-white rounded-lg text-sm font-medium transition bg-red-600 hover:bg-red-500">Hapus</button>
    </div>
  </Modal>

  <script>
    import { initDashboard } from '@lib/dashboard-init';
    import { setupConfirmModal } from '@lib/ui';
    import { isExternalApiMode } from '@lib/api-client';

    const meta = document.getElementById('dashboard-meta') as HTMLElement | null;
    const hasSSRUser = !!meta?.dataset.username;

    const init = () => {
      initDashboard({
        role: (meta?.dataset.role as 'maintainer' | 'member') || 'member',
        userName: meta?.dataset.username || '',
      });
      setupConfirmModal();
    };

    if (!hasSSRUser) {
      // client-side auth check
      (async () => {
        try {
          const token = localStorage.getItem('auth_token');
          const headers: HeadersInit = { 'Content-Type': 'application/json' };
          const useExternal = isExternalApiMode();
          
          if (token && useExternal) {
            headers['Authorization'] = `Bearer ${token}`;
          }
          
          const apiUrl = meta?.dataset.apiUrl || '';
          const res = await fetch(`${apiUrl}/api/auth/me`, {
            headers,
            credentials: useExternal ? 'same-origin' : 'include'
          });
          
          if (!res.ok) {
            localStorage.removeItem('auth_token');
            window.location.href = '/login';
            return;
          }
          
          const body = await res.json();
          const user = body.data?.user || body.user;
          if (!user) {
            window.location.href = '/login';
            return;
          }
          
          // Check page requirements
          const reqEl = document.getElementById('page-requirements');
          const reqRole = reqEl?.dataset.requiredRole;
          if (reqRole === 'maintainer' && user.role !== 'maintainer') {
            window.location.href = '/app/overview';
            return;
          }
          if (reqRole === 'member' && user.role === 'maintainer') {
            window.location.href = '/app/overview';
            return;
          }
          if (user.status === 'pending') {
            window.location.href = `/check-status?nis=${user.nis}`;
            return;
          }
          if (user.status === 'inactive') {
            window.location.href = '/login?error=inactive';
            return;
          }
          
          // Update DOM elements
          document.documentElement.setAttribute('data-user-role', user.role);
          document.getElementById('sidebar')?.setAttribute('data-user-role', user.role);
          document.getElementById('bottom-nav')?.setAttribute('data-user-role', user.role);
          
          const sidebarUsername = document.getElementById('sidebar-username');
          if (sidebarUsername) sidebarUsername.textContent = user.name;
          const sidebarEmail = document.getElementById('sidebar-email');
          if (sidebarEmail) sidebarEmail.textContent = user.email;
          const popupUsername = document.getElementById('sidebar-popup-username');
          if (popupUsername) popupUsername.textContent = user.name;
          const popupEmail = document.getElementById('sidebar-popup-email');
          if (popupEmail) popupEmail.textContent = user.email;
          const dropdownUsername = document.getElementById('topbar-dropdown-username');
          if (dropdownUsername) dropdownUsername.textContent = user.name;
          
          const avatarContainers = [
            document.getElementById('sidebar-avatar-container'),
            document.getElementById('topbar-avatar-container')
          ];
          avatarContainers.forEach(container => {
            if (!container) return;
            if (user.avatarUrl) {
              container.innerHTML = `<img src="${user.avatarUrl}" alt="${user.name}" class="w-full h-full object-cover rounded-full" />`;
            } else {
              const initial = user.name.charAt(0).toUpperCase();
              container.innerHTML = `<div class="bg-blue-600 w-full h-full flex items-center justify-center rounded-full text-white font-bold flex items-center justify-center">${initial}</div>`;
            }
          });
          
          if (meta) {
            meta.dataset.username = user.name;
            meta.dataset.role = user.role;
            meta.dataset.status = user.status;
            meta.dataset.userId = user.id;
          }
          
          // Re-init dashboard with corrected role
          initDashboard({
            role: user.role as 'maintainer' | 'member',
            userName: user.name,
          });
          setupConfirmModal();
          
          // Notify React Islands
          window.dispatchEvent(new CustomEvent('user-loaded', { detail: user }));
        } catch (e) {
          console.error(e);
          window.location.href = '/login';
        }
      })();
    } else {
      init();
    }

    // ── Navigation progress bar for ViewTransitions ──
    const progressBar = document.getElementById('nav-progress');
    if (progressBar) {
      document.addEventListener('astro:before-swap', () => {
        progressBar.classList.add('active');
      });
      document.addEventListener('astro:after-swap', () => {
        progressBar.classList.remove('active');
        progressBar.style.width = '100%';
        progressBar.style.opacity = '1';
        setTimeout(() => {
          progressBar.style.width = '0';
          progressBar.style.opacity = '0';
        }, 200);
      });
    }
  </script>

  <script is:inline define:vars={{ siteName: config.site.name, githubUrl: config.socials.github }}>
    console.log(
      `%c  ${siteName}  `,
      'background:#3b82f6;color:white;font-size:16px;font-weight:bold;padding:8px 16px;border-radius:6px'
    );
    console.log(
      `%cHei, kamu buka DevTools! 👀\n\nPlatform ini open source — fork, kontribusi, atau sekadar baca kodenya.\n\nAda sesuatu yang tersembunyi di sini → /app/about\n\nGitHub: ${githubUrl}`,
      'color:#94a3b8;font-size:13px;line-height:1.8'
    );
  </script>
</body>
</html>
