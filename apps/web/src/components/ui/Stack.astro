---
/**
 * Stack - Vertical or horizontal stack with consistent spacing
 * 
 * @param direction - Stack direction: 'vertical' | 'horizontal'
 * @param gap - Gap size: 'xs' | 'sm' | 'md' | 'lg' | 'xl'
 * @param align - Alignment: 'start' | 'center' | 'end' | 'stretch'
 * @param justify - Justification: 'start' | 'center' | 'end' | 'between' | 'around'
 * @param class - Additional CSS classes
 * 
 * @slot default - Content to stack
 */
interface Props {
  direction?: 'vertical' | 'horizontal';
  gap?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  align?: 'start' | 'center' | 'end' | 'stretch';
  justify?: 'start' | 'center' | 'end' | 'between' | 'around';
  class?: string;
}

const {
  direction = 'vertical',
  gap = 'md',
  align = 'start',
  justify = 'start',
  class: className = ''
} = Astro.props;

const directionClasses: Record<string, string> = {
  vertical: 'flex flex-col',
  horizontal: 'flex flex-row flex-wrap'
};

const gapClasses: Record<string, string> = {
  xs: 'gap-1',
  sm: 'gap-2',
  md: 'gap-3',
  lg: 'gap-4',
  xl: 'gap-6'
};

const alignClasses: Record<string, string> = {
  start: 'items-start',
  center: 'items-center',
  end: 'items-end',
  stretch: 'items-stretch'
};

const justifyClasses: Record<string, string> = {
  start: 'justify-start',
  center: 'justify-center',
  end: 'justify-end',
  between: 'justify-between',
  around: 'justify-around'
};
---

<div class="{directionClasses[direction]} {gapClasses[gap]} {alignClasses[align]} {justifyClasses[justify]} {className}">
  <slot />
</div>