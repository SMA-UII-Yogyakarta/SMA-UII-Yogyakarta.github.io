---
/**
 * Badge - Reusable badge/tag component
 * 
 * @param label - Badge text
 * @param variant - Badge style: 'default' | 'success' | 'warning' | 'error' | 'info'
 * @param size - Badge size: 'sm' | 'md' | 'lg'
 * @param icon - Optional emoji icon
 * @param class - Additional CSS classes
 */
interface Props {
  label: string;
  variant?: 'default' | 'success' | 'warning' | 'error' | 'info';
  size?: 'sm' | 'md' | 'lg';
  icon?: string;
  class?: string;
}

const {
  label,
  variant = 'default',
  size = 'md',
  icon,
  class: className = ''
} = Astro.props;

const variantClasses: Record<string, string> = {
  default: 'bg-gray-800 text-gray-400',
  success: 'bg-green-500/20 text-green-400',
  warning: 'bg-yellow-500/20 text-yellow-400',
  error: 'bg-red-500/20 text-red-400',
  info: 'bg-blue-500/20 text-blue-400'
};

const sizeClasses: Record<string, string> = {
  sm: 'px-2 py-0.5 text-xs',
  md: 'px-3 py-1 text-sm',
  lg: 'px-4 py-1.5 text-base'
};
---

<span class="inline-flex items-center gap-1 rounded-full {variantClasses[variant]} {sizeClasses[size]} {className}">
  {icon && <span class="flex-shrink-0">{icon}</span>}
  <span>{label}</span>
</span>