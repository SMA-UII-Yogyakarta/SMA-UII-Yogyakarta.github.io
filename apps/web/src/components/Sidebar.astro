---
import { navItems } from '@lib/nav';
import { getSiteConfig } from '@smauii/shared';

const config = getSiteConfig();

interface Props {
  role: 'maintainer' | 'member';
  userName: string;
  userEmail: string;
  userAvatarUrl?: string | null;
}

const { role, userName = '', userEmail = '', userAvatarUrl } = Astro.props;

const allItems = [
  { href: '/app/overview', icon: 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6', label: 'Dashboard', requiredRole: 'all' },
  { href: '/app/learn', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253', label: 'Belajar', requiredRole: 'all' },
  { href: '/app/card', icon: 'M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z', label: 'Member Card', requiredRole: 'member' },
  { href: '/app/members', icon: 'M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z', label: 'Members', requiredRole: 'maintainer' },
  { href: '/app/projects', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4', label: 'Projects', requiredRole: 'all' },
  { href: '/app/activities', icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z', label: 'Activities', requiredRole: 'maintainer' },
  { href: '/app/announcements', icon: 'M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z', label: 'Announcements', requiredRole: 'maintainer' }
];

const initialRole = role || 'member';
---

<style is:global>
  /* ── Role-based visibility ── */
  aside[data-user-role="member"] [data-role-required="maintainer"] {
    display: none !important;
  }
  aside[data-user-role="maintainer"] [data-role-required="member"] {
    display: none !important;
  }

  /* ═══════════════════════════════════════════════════════════════
     SIDEBAR STATE SYSTEM
     State diset via: document.documentElement.setAttribute('data-sidebar', state)

     States:
       hidden    — mobile (<640px), sidebar off-screen
       minimized — tablet (640-1023px) default, atau desktop collapsed: icon only, 4rem
       expanded  — desktop (≥1024px) default: full sidebar, 16rem
       overlay   — tablet saat hamburger diklik: full sidebar di atas konten, 16rem

     CSS-only approach — jangan manipulasi .sidebar-label via JS inline style
     karena inline style mengalahkan CSS rules (specificity lebih tinggi).
  ═══════════════════════════════════════════════════════════════ */

  /* ── Sidebar width & position ── */
  :root[data-sidebar="hidden"]    #sidebar { width: 16rem; transform: translateX(-100%); }
  :root[data-sidebar="minimized"] #sidebar { width: 4rem;  transform: translateX(0); }
  :root[data-sidebar="expanded"]  #sidebar { width: 16rem; transform: translateX(0); }
  :root[data-sidebar="overlay"]   #sidebar { width: 16rem; transform: translateX(0); z-index: 60; }

  /* ── Main content margin (mengikuti lebar sidebar) ── */
  :root[data-sidebar="hidden"]    #main-content { margin-left: 0; }
  :root[data-sidebar="minimized"] #main-content { margin-left: 4rem; }
  :root[data-sidebar="expanded"]  #main-content { margin-left: 16rem; }
  :root[data-sidebar="overlay"]   #main-content { margin-left: 4rem; }

  /* ── Label visibility: hidden di minimized, tampil di expanded & overlay ── */
  :root[data-sidebar="minimized"] #sidebar .sidebar-label { display: none; }
  :root[data-sidebar="expanded"]  #sidebar .sidebar-label,
  :root[data-sidebar="overlay"]   #sidebar .sidebar-label { display: unset; }

  /* ── Nav items: minimized = icon only, centered ── */
  :root[data-sidebar="minimized"] #sidebar-nav { padding: 0.5rem; }
  :root[data-sidebar="minimized"] #sidebar-nav a { justify-content: center; padding: 0; width: 2.5rem; height: 2.5rem; margin: 0 auto; }
  :root[data-sidebar="minimized"] #sidebar-header { padding: 1rem 0.5rem; }
  :root[data-sidebar="minimized"] #sidebar-header a { justify-content: center; }
  :root[data-sidebar="minimized"] #sidebar-user { padding: 0.5rem; }
  :root[data-sidebar="minimized"] #sidebar-user button { justify-content: center; padding: 0.5rem; }

  /* ── Nav items: overlay = full expanded, reset ke nilai normal ── */
  :root[data-sidebar="overlay"] #sidebar-nav a { justify-content: flex-start; padding: 0.625rem 0.75rem; width: auto; height: auto; margin: 0; }
  :root[data-sidebar="overlay"] #sidebar-header { padding: 0 0.75rem; }
  :root[data-sidebar="overlay"] #sidebar-header a { justify-content: flex-start; }
  :root[data-sidebar="overlay"] #sidebar-user { padding: 1rem; }
  :root[data-sidebar="overlay"] #sidebar-user button { justify-content: flex-start; padding: 0.5rem; }

  /* ── Transitions ── */
  #sidebar       { transition: width 0.3s, transform 0.3s; }
  #main-content  { transition: margin-left 0.3s; }
</style>

<!-- Backdrop: muncul saat overlay, klik untuk tutup sidebar -->
<div id="sidebar-backdrop" class="fixed inset-0 bg-black/40 z-[55] hidden"></div>

<aside id="sidebar" class="bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full z-[60]" data-user-role={initialRole}>
  <div id="sidebar-header" class="h-16 px-3 border-b border-gray-800 flex items-center justify-center transition-all duration-300">
    <a href="/" class="font-bold text-white flex items-center gap-2 whitespace-nowrap">
      <span class="text-blue-400 text-xl flex-shrink-0">{config.site.logoSymbol}</span>
      <span class="sidebar-label truncate">{config.site.name}</span>
    </a>
  </div>
  <nav class="flex-1 p-4 space-y-1 overflow-y-auto" id="sidebar-nav">
    {allItems.map(item => (
      <a
        href={item.href}
        class="btn-ripple flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition text-gray-400 hover:text-white touch-manipulation"
        data-nav={item.label.toLowerCase()}
        data-role-required={item.requiredRole}
        title={item.label}
        style="min-height:44px;"
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
        </svg>
        <span class="sidebar-label whitespace-nowrap">{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="p-4 border-t border-gray-800 relative" id="sidebar-user">
    <button id="profile-dropdown-btn" aria-label="Profile menu" aria-expanded="false" aria-haspopup="true" class="btn-ripple w-full flex items-center gap-3 hover:bg-gray-800 p-2 rounded-lg transition group">
      <div id="sidebar-avatar-container" class="shrink-0">
        {userAvatarUrl ? (
          <img src={userAvatarUrl} alt={userName} class="w-8 h-8 rounded-full object-cover group-hover:ring-2 group-hover:ring-blue-500 transition" />
        ) : (
          <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-sm group-hover:ring-2 group-hover:ring-blue-500 transition">
            {userName ? userName.charAt(0).toUpperCase() : '?'}
          </div>
        )}
      </div>
      <div class="flex-1 min-w-0 sidebar-label text-left">
        <p id="sidebar-username" class="text-sm font-medium truncate">{userName}</p>
        <p id="sidebar-email" class="text-xs text-gray-500 truncate">{userEmail}</p>
      </div>
      <svg class="w-4 h-4 text-gray-400 sidebar-label shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      </svg>
    </button>

    <!-- Dropdown: inline saat expanded/overlay, popup saat minimized -->
    <div id="profile-dropdown" class="hidden mt-2 space-y-1">
      <a href="/app/profile" data-role-required="member" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Profile
      </a>
      <a href="/app/settings" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">
        <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Settings
      </a>
      <form action="/api/auth/logout" method="POST">
        <button id="logout-btn" type="submit" aria-label="Logout" class="btn-ripple w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-red-400 hover:bg-gray-800 rounded-lg transition">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </button>
      </form>
    </div>

    <!-- Popup saat minimized (icon-only) — muncul di kanan sidebar -->
    <div id="profile-popup" class="hidden fixed bottom-4 left-[4.5rem] z-[70] bg-gray-900 border border-gray-800 rounded-xl shadow-xl w-56">
      <div class="p-3 border-b border-gray-800">
        <p id="sidebar-popup-username" class="text-sm font-medium truncate">{userName}</p>
        <p id="sidebar-popup-email" class="text-xs text-gray-500 truncate">{userEmail}</p>
      </div>
      <div class="p-1.5 space-y-0.5">
        <a href="/app/profile" data-role-required="member" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">Profile</a>
        <a href="/app/settings" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">Settings</a>
        <form action="/api/auth/logout" method="POST">
          <button type="submit" class="w-full text-left px-3 py-2 text-sm text-gray-400 hover:text-red-400 hover:bg-gray-800 rounded-lg transition">Logout</button>
        </form>
      </div>
    </div>
  </div>

  <!-- Version di luar padding sidebar-user agar benar-benar center -->
  <a href="/app/about" class="sidebar-label block w-full text-center text-gray-700 hover:text-gray-500 transition pb-3" style="font-size:10px">
    v0.1.0 · made with ❤️
  </a>
</aside>

<script>
  const profileBtn = document.getElementById('profile-dropdown-btn');
  const profileDropdown = document.getElementById('profile-dropdown');
  const profilePopup = document.getElementById('profile-popup');

  function isMinimized() {
    const state = document.documentElement.getAttribute('data-sidebar');
    return state === 'minimized';
  }

  profileBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isExpanded = profileBtn.getAttribute('aria-expanded') === 'true';
    profileBtn.setAttribute('aria-expanded', String(!isExpanded));
    if (isMinimized()) {
      profilePopup?.classList.toggle('hidden');
      profileDropdown?.classList.add('hidden');
    } else {
      profileDropdown?.classList.toggle('hidden');
      profilePopup?.classList.add('hidden');
    }
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!profileBtn?.contains(target)) {
      profileDropdown?.classList.add('hidden');
      profilePopup?.classList.add('hidden');
      profileBtn?.setAttribute('aria-expanded', 'false');
    }
  });

  // Handle logout forms - use fetch to bypass CSRF
  document.querySelectorAll('form[action="/api/auth/logout"]').forEach(form => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      // Clear JWT token for SSG/Jamstack mode (no-op in SSR mode)
      localStorage.removeItem('auth_token');
      try {
        await fetch('/api/auth/logout', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
        });
      } catch {
        // In SSG mode the endpoint may not exist — ignore and redirect anyway
      }
      window.location.href = '/login';
    });
  });
</script>
