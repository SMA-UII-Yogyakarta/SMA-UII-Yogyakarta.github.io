---
interface Props {
  subtitle?: string;
  actionLabel?: string;
  actionId?: string;
}
const { subtitle, actionLabel, actionId = 'open-modal' } = Astro.props;
---
{(subtitle || actionLabel) && (
  <div class="flex justify-between items-center mb-4">
    {subtitle ? <p class="text-gray-400 text-sm">{subtitle}</p> : <span />}
    {actionLabel && (
      <button id={actionId} class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2.5 rounded-lg transition flex items-center gap-2 text-sm touch-manipulation" style="min-height:44px;">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
        </svg>
        {actionLabel}
      </button>
    )}
  </div>
)}
