---
// Toast container - renders toast notifications
// Usage: window.showToast(message, type?) where type = 'success' | 'error' | 'warning' | 'info'
---

<div id="toast-container" class="fixed bottom-4 right-4 z-[9999] flex flex-col gap-2 pointer-events-none" aria-live="polite" aria-atomic="true"></div>

<script>
  type ToastType = 'success' | 'error' | 'warning' | 'info';

  const typeStyles: Record<ToastType, string> = {
    success: 'bg-green-600 border-green-500',
    error: 'bg-red-600 border-red-500',
    warning: 'bg-yellow-600 border-yellow-500',
    info: 'bg-blue-600 border-blue-500',
  };

  const typeIcons: Record<ToastType, string> = {
    success: '✓',
    error: '✕',
    warning: '⚠',
    info: 'ℹ',
  };

  function showToast(message: string, type: ToastType = 'info', duration = 2500) {
    const container = document.getElementById('toast-container');
    if (!container) return;

    const toast = document.createElement('div');
    toast.className = `${typeStyles[type]} border px-4 py-3 rounded-lg shadow-lg text-white text-sm font-medium flex items-center gap-2 pointer-events-auto transform translate-x-full opacity-0 transition-all duration-300`;
    toast.setAttribute('role', 'alert');
    toast.innerHTML = `<span class="text-lg">${typeIcons[type]}</span><span>${escapeHtml(message)}</span>`;

    container.appendChild(toast);

    requestAnimationFrame(() => {
      toast.classList.remove('translate-x-full', 'opacity-0');
    });

    setTimeout(() => {
      toast.classList.add('translate-x-full', 'opacity-0');
      setTimeout(() => toast.remove(), 300);
    }, duration);
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  // Expose globally for use in inline scripts
  (window as any).showToast = showToast;
</script>
