---
import AuthLayout from '@layouts/AuthLayout.astro';
// SSG-first: no Astro.locals, client-side redirect for logged-in users
---

<AuthLayout title="Lupa Password" subtitle="Masukkan email kamu untuk menerima tautan reset">
  <form id="forgot-form" class="space-y-4">
    <div>
      <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider">Email</label>
      <input
        type="email"
        id="email"
        name="email"
        class="w-full bg-gray-950/60 border border-gray-800/80 rounded-xl px-4 py-3 text-sm text-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 placeholder-gray-600 hover:border-gray-700/80"
        placeholder="kamu@smauiiyk.sch.id"
        autocomplete="email"
        required
      />
      <p id="email-error" class="text-red-400 text-xs mt-1.5 hidden"></p>
    </div>

    <div id="success-message" class="p-3 bg-green-500/10 border border-green-500/20 rounded-xl text-green-400 text-sm hidden"></div>
    <div id="error-message" class="p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm hidden"></div>

    <button
      type="submit"
      id="submit-btn"
      class="btn-ripple w-full bg-blue-600 hover:bg-blue-500 disabled:opacity-40 disabled:cursor-not-allowed text-white px-5 py-3.5 rounded-xl font-semibold text-sm transition-all duration-300 shadow-lg shadow-blue-600/15 mt-2"
    >
      Kirim Tautan Reset
    </button>
  </form>

  <p class="text-center text-xs text-gray-600 mt-6">
    <a href="/login" class="btn-ripple text-blue-400 hover:text-blue-300 transition-colors inline-block px-3 py-1.5 rounded-lg">← Kembali ke login</a>
  </p>
</AuthLayout>

<script>
  import { apiFetch } from '@lib/api-client';
  const form = document.getElementById('forgot-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;
  const emailInput = document.getElementById('email') as HTMLInputElement;
  const emailError = document.getElementById('email-error') as HTMLParagraphElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMessage.classList.add('hidden');
    successMessage.classList.add('hidden');
    emailError.classList.add('hidden');

    const email = emailInput.value.trim();

    if (!email) {
      emailError.textContent = 'Email harus diisi';
      emailError.classList.remove('hidden');
      emailInput.focus();
      return;
    }

    // Validate email format
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      emailError.textContent = 'Format email tidak valid';
      emailError.classList.remove('hidden');
      emailInput.focus();
      return;
    }

    submitBtn.disabled = true;
    submitBtn.textContent = 'Mengirim...';

    try {
      const { data, error } = await apiFetch<{ message: string }>('/api/auth/forgot-password', {
        method: 'POST',
        body: JSON.stringify({ email }),
      });

      if (error) {
        errorMessage.textContent = error || 'Terjadi kesalahan';
        errorMessage.classList.remove('hidden');
        return;
      }

      successMessage.textContent = data?.message || 'Tautan reset telah dikirim ke email kamu.';
      successMessage.classList.remove('hidden');
    } catch {
      errorMessage.textContent = 'Terjadi kesalahan. Silakan coba lagi.';
      errorMessage.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Kirim Tautan Reset';
    }
  });
// Inline validation on blur
  emailInput.addEventListener('blur', () => {
    const email = emailInput.value.trim();
    if (!email) {
      emailError.textContent = 'Email harus diisi';
      emailError.classList.remove('hidden');
      return;
    }
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      emailError.textContent = 'Format email tidak valid';
      emailError.classList.remove('hidden');
      return;
    }
    emailError.classList.add('hidden');
  });

  emailInput.addEventListener('input', () => {
    if (!emailError.classList.contains('hidden')) {
      emailError.classList.add('hidden');
    }
  });
</script>
