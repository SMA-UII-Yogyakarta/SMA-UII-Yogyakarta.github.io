---
import Layout from '../layouts/Layout.astro';
---
<Layout title="404 - Halaman Tidak Ditemukan">
  <div class="max-w-3xl mx-auto px-4 py-24 text-center">
    <div class="text-8xl font-bold mb-6 bg-linear-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
      404
    </div>
    <h1 class="text-3xl font-bold mb-4">Halaman Tidak Ditemukan</h1>
    <p class="text-gray-400 mb-8">
      Sepertinya halaman yang kamu cari tidak ada atau sudah dipindahkan.
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <a href="/" 
         class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-lg font-semibold transition">
        ← Kembali ke Beranda
      </a>
      <a href="/tracks" 
         class="border border-gray-700 hover:border-blue-500 px-6 py-2.5 rounded-lg font-semibold transition">
        Lihat Track
      </a>
    </div>
    
    <!-- Quick Links -->
    <div class="mt-16 grid md:grid-cols-4 gap-4 text-left">
      <a href="/tracks" class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-blue-500 transition">
        <div class="text-2xl mb-2">🎯</div>
        <h3 class="font-semibold text-sm mb-1">Track</h3>
        <p class="text-xs text-gray-400">6 track minat</p>
      </a>
      <a href="/projects" class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-blue-500 transition">
        <div class="text-2xl mb-2">💻</div>
        <h3 class="font-semibold text-sm mb-1">Proyek</h3>
        <p class="text-xs text-gray-400">Open source</p>
      </a>
      <a href="/members" class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-blue-500 transition">
        <div class="text-2xl mb-2">👥</div>
        <h3 class="font-semibold text-sm mb-1">Anggota</h3>
        <p class="text-xs text-gray-400">Komunitas</p>
      </a>
      <a href="/about" class="bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-blue-500 transition">
        <div class="text-2xl mb-2">📖</div>
        <h3 class="font-semibold text-sm mb-1">Tentang</h3>
        <p class="text-xs text-gray-400">Filosofi</p>
      </a>
    </div>
  </div>
</Layout>
