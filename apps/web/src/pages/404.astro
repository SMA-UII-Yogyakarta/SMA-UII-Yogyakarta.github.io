---
import Layout from '@layouts/Layout.astro';
---
<Layout title="404 - Halaman Tidak Ditemukan">
  <div class="max-w-3xl mx-auto px-4 py-24 text-center">
    <div class="text-8xl font-bold mb-6 bg-linear-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
      404
    </div>
    <h1 class="text-3xl font-bold mb-4">Halaman Tidak Ditemukan</h1>
    <p class="text-gray-400 mb-8">
      Sepertinya halaman yang kamu cari tidak ada atau sudah dipindahkan.
    </p>
    <div class="flex gap-3 justify-center flex-wrap">
      <a href="/" 
         class="btn-ripple bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-xl font-semibold transition-all duration-300 shadow-lg shadow-blue-600/10">
        ← Kembali ke Beranda
      </a>
      <a href="/tracks" 
         class="btn-ripple border border-gray-800 bg-gray-900/40 hover:bg-gray-900/80 px-6 py-2.5 rounded-xl font-semibold transition-all duration-300 hover:border-blue-500/60 hover:text-white">
        Lihat Track
      </a>
    </div>
    
    <!-- Quick Links -->
    <div class="mt-16 grid md:grid-cols-4 gap-4 text-left">
      <a href="/tracks" class="btn-ripple bg-gray-900/60 border border-gray-800/80 rounded-2xl p-4 hover:border-blue-500/60 hover:shadow-md transition-all duration-300 block group relative overflow-hidden">
        <div class="text-2xl mb-2">🎯</div>
        <h3 class="font-bold text-sm mb-1 text-gray-200 group-hover:text-blue-400 transition-colors">Track</h3>
        <p class="text-xs text-gray-400">6 track minat</p>
      </a>
      <a href="/projects" class="btn-ripple bg-gray-900/60 border border-gray-800/80 rounded-2xl p-4 hover:border-blue-500/60 hover:shadow-md transition-all duration-300 block group relative overflow-hidden">
        <div class="text-2xl mb-2">💻</div>
        <h3 class="font-bold text-sm mb-1 text-gray-200 group-hover:text-blue-400 transition-colors">Proyek</h3>
        <p class="text-xs text-gray-400">Open source</p>
      </a>
      <a href="/members" class="btn-ripple bg-gray-900/60 border border-gray-800/80 rounded-2xl p-4 hover:border-blue-500/60 hover:shadow-md transition-all duration-300 block group relative overflow-hidden">
        <div class="text-2xl mb-2">👥</div>
        <h3 class="font-bold text-sm mb-1 text-gray-200 group-hover:text-blue-400 transition-colors">Anggota</h3>
        <p class="text-xs text-gray-400">Komunitas</p>
      </a>
      <a href="/about" class="btn-ripple bg-gray-900/60 border border-gray-800/80 rounded-2xl p-4 hover:border-blue-500/60 hover:shadow-md transition-all duration-300 block group relative overflow-hidden">
        <div class="text-2xl mb-2">📖</div>
        <h3 class="font-bold text-sm mb-1 text-gray-200 group-hover:text-blue-400 transition-colors">Tentang</h3>
        <p class="text-xs text-gray-400">Filosofi</p>
      </a>
    </div>
  </div>
</Layout>
