---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Anggota">
  <div id="members-content" class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Anggota Lab</h1>
    <p class="text-gray-400 mb-12">Siswa yang aktif berkontribusi di komunitas</p>

    <!-- Skeleton Loading - Use JSX syntax, NOT template strings -->
    <div id="members-loading" class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {Array.from({ length: 6 }).map(() => (
        <div class="bg-gray-900/40 border border-gray-800/80 rounded-2xl p-5 animate-pulse">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-full bg-gray-800"></div>
            <div class="flex-1">
              <div class="h-4 bg-gray-800 rounded w-24 mb-1"></div>
              <div class="h-3 bg-gray-800 rounded w-16"></div>
            </div>
          </div>
          <div class="flex gap-1">
            <div class="h-5 bg-gray-800 rounded w-16"></div>
            <div class="h-5 bg-gray-800 rounded w-20"></div>
          </div>
        </div>
      ))}
    </div>

    <div id="members-grid" class="hidden grid sm:grid-cols-2 md:grid-cols-3 gap-4"></div>

    <div id="members-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-4">👥</div>
      <p class="text-gray-400">Belum ada anggota aktif</p>
    </div>

    <div id="members-error" class="hidden text-center py-12">
      <div class="text-4xl mb-4">⚠️</div>
      <p class="text-red-400">Gagal memuat data anggota</p>
    </div>

    <div id="pagination" class="hidden flex items-center justify-center gap-4 mt-10">
      <button id="prev-btn" disabled aria-label="Previous page"
        class="btn-ripple px-4 py-2.5 rounded-xl border border-gray-800/80 bg-gray-900/40 hover:bg-gray-900/80 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500/60 hover:text-white transition-all duration-300">
        ← Sebelumnya
      </button>
      <span id="page-indicator" class="text-sm text-gray-400 font-medium"></span>
      <button id="next-btn" disabled aria-label="Next page"
        class="btn-ripple px-4 py-2.5 rounded-xl border border-gray-800/80 bg-gray-900/40 hover:bg-gray-900/80 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500/60 hover:text-white transition-all duration-300">
        Selanjutnya →
      </button>
    </div>
  </div>

  <script>
    import { esc } from '@lib/ui';

    const loadingEl = document.getElementById('members-loading') as HTMLElement;
    const gridEl = document.getElementById('members-grid') as HTMLElement;
    const emptyEl = document.getElementById('members-empty') as HTMLElement;
    const errorEl = document.getElementById('members-error') as HTMLElement;
    const paginationEl = document.getElementById('pagination') as HTMLElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const pageIndicator = document.getElementById('page-indicator') as HTMLElement;

    let currentPage = 1;
    const PAGE_SIZE = 6;

    async function loadMembers() {
      try {
        const res = await fetch(`/api/members?page=${currentPage}&limit=${PAGE_SIZE}&status=active`);
        const { data } = await res.json();
        const members = data?.members || [];
        const total = data?.total || 0;
        const totalPages = Math.ceil(total / PAGE_SIZE);

        if (members.length === 0) {
          showEmpty();
          return;
        }

        renderMembers(members);
        updatePagination(currentPage, totalPages);
      } catch (error) {
        console.error('Failed to load members:', error);
        showError();
      }
    }

    function renderMembers(members: any[]) {
      gridEl.innerHTML = members.map(m => {
        const isMaintainer = m.role === 'maintainer';
        const roleBadgeClass = isMaintainer 
          ? 'bg-purple-500/15 text-purple-400 border-purple-500/20' 
          : 'bg-blue-500/15 text-blue-400 border-blue-500/20';
        
        // Generate a subtle gradient for user avatar based on their name letter
        const charCode = m.name.charCodeAt(0) % 5;
        const gradients = [
          'from-blue-600 to-indigo-600',
          'from-purple-600 to-pink-600',
          'from-teal-600 to-emerald-600',
          'from-orange-600 to-red-600',
          'from-indigo-600 to-purple-600'
        ];
        const gradient = gradients[charCode] || gradients[0];

        return `
          <a href="/app/members/${m.id}" class="bg-gray-900/60 border border-gray-800/80 rounded-2xl p-5 hover:border-blue-500/60 hover:shadow-lg hover:shadow-black/20 transition-all duration-300 block group relative overflow-hidden">
            <div class="absolute inset-0 bg-linear-to-b from-white/1 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
            <div class="flex items-center gap-4 mb-4 relative z-10">
              <div class="w-12 h-12 rounded-full bg-gradient-to-br ${gradient} flex items-center justify-center text-white font-bold text-lg shadow-inner group-hover:scale-105 transition-transform duration-300">
                ${esc(m.name.charAt(0).toUpperCase())}
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="font-bold text-gray-100 truncate group-hover:text-blue-400 transition-colors text-sm">${esc(m.name)}</h3>
                <p class="text-xs text-gray-400 mt-0.5">${esc(m.class || 'Alumni')}</p>
              </div>
            </div>
            <div class="flex gap-1.5 flex-wrap relative z-10">
              <span class="px-2.5 py-0.5 border rounded-lg text-xs font-semibold ${roleBadgeClass}">${esc(isMaintainer ? 'Maintainer' : 'Member')}</span>
              ${m.tracks?.slice(0, 2).map((t: string) => 
                `<span class="px-2.5 py-0.5 bg-gray-800 text-gray-300 border border-gray-700/40 rounded-lg text-xs font-medium">${esc(t)}</span>`
              ).join('') || ''}
            </div>
          </a>
        `;
      }).join('');
    }

    function showEmpty() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.add('hidden');
    }

    function showError() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      paginationEl.classList.add('hidden');
    }

    function showContent() {
      loadingEl.classList.add('hidden');
      gridEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.remove('hidden');
    }

    function updatePagination(page: number, total: number) {
      pageIndicator.textContent = `Halaman ${page} dari ${total}`;
      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === total || total === 0;
      showContent();
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        loadMembers();
      }
    });

    nextBtn?.addEventListener('click', () => {
      currentPage++;
      loadMembers();
    });

    // Initial load
    loadMembers();
  </script>
</Layout>
