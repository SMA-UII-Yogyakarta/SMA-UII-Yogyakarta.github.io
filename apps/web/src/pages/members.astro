---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Anggota">
  <div id="members-content" class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Anggota Lab</h1>
    <p class="text-gray-400 mb-12">Siswa yang aktif berkontribusi di komunitas</p>

    <!-- Skeleton Loading - Use JSX syntax, NOT template strings -->
    <div id="members-loading" class="grid sm:grid-cols-2 md:grid-cols-3 gap-4">
      {Array.from({ length: 6 }).map(() => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 animate-pulse">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-full bg-gray-800"></div>
            <div class="flex-1">
              <div class="h-4 bg-gray-800 rounded w-24 mb-1"></div>
              <div class="h-3 bg-gray-800 rounded w-16"></div>
            </div>
          </div>
          <div class="flex gap-1">
            <div class="h-5 bg-gray-800 rounded w-16"></div>
            <div class="h-5 bg-gray-800 rounded w-20"></div>
          </div>
        </div>
      ))}
    </div>

    <div id="members-grid" class="hidden grid sm:grid-cols-2 md:grid-cols-3 gap-4"></div>

    <div id="members-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-4">👥</div>
      <p class="text-gray-400">Belum ada anggota aktif</p>
    </div>

    <div id="members-error" class="hidden text-center py-12">
      <div class="text-4xl mb-4">⚠️</div>
      <p class="text-red-400">Gagal memuat data anggota</p>
    </div>

    <div id="pagination" class="hidden flex items-center justify-center gap-4 mt-10">
      <button id="prev-btn" disabled
        class="px-4 py-2 rounded-lg border border-gray-700 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500 hover:text-white transition">
        ← Sebelumnya
      </button>
      <span id="page-indicator" class="text-sm text-gray-400"></span>
      <button id="next-btn" disabled
        class="px-4 py-2 rounded-lg border border-gray-700 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500 hover:text-white transition">
        Selanjutnya →
      </button>
    </div>
  </div>

  <script>
    import { esc, fmtDate } from '@lib/ui';

    const loadingEl = document.getElementById('members-loading');
    const gridEl = document.getElementById('members-grid');
    const emptyEl = document.getElementById('members-empty');
    const errorEl = document.getElementById('members-error');
    const paginationEl = document.getElementById('pagination');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const pageIndicator = document.getElementById('page-indicator');

    let currentPage = 1;
    const PAGE_SIZE = 6;

    async function loadMembers() {
      try {
        const res = await fetch(`/api/members?page=${currentPage}&limit=${PAGE_SIZE}&status=active`);
        const { data } = await res.json();
        const members = data?.members || [];
        const total = data?.total || 0;
        const totalPages = Math.ceil(total / PAGE_SIZE);

        if (members.length === 0) {
          showEmpty();
          return;
        }

        renderMembers(members);
        updatePagination(currentPage, totalPages);
      } catch (error) {
        console.error('Failed to load members:', error);
        showError();
      }
    }

    function renderMembers(members: any[]) {
      gridEl.innerHTML = members.map(m => `
        <a href="/app/members/${m.id}" class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-500 transition block group">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-12 h-12 rounded-full bg-blue-900/30 flex items-center justify-center text-blue-400 font-bold text-lg">
              ${m.name.charAt(0).toUpperCase()}
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="font-semibold text-gray-100 truncate group-hover:text-blue-400 transition">${esc(m.name)}</h3>
              <p class="text-xs text-gray-400">${esc(m.class || 'Alumni')}</p>
            </div>
          </div>
          <div class="flex gap-1 flex-wrap">
            <span class="px-2 py-1 bg-blue-900/30 text-blue-400 rounded text-xs font-medium">${m.role === 'maintainer' ? 'Maintainer' : 'Member'}</span>
            ${m.tracks?.slice(0, 2).map((t: string) => 
              `<span class="px-2 py-1 bg-gray-800 text-gray-400 rounded text-xs">${t}</span>`
            ).join('') || ''}
          </div>
        </a>
      `).join('');
    }

    function showLoading() {
      loadingEl.classList.remove('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.add('hidden');
    }

    function showEmpty() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.add('hidden');
    }

    function showError() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      paginationEl.classList.add('hidden');
    }

    function showContent() {
      loadingEl.classList.add('hidden');
      gridEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.remove('hidden');
    }

    function updatePagination(page: number, total: number) {
      pageIndicator.textContent = `Halaman ${page} dari ${total}`;
      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === total || total === 0;
      showContent();
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        loadMembers();
      }
    });

    nextBtn?.addEventListener('click', () => {
      currentPage++;
      loadMembers();
    });

    // Initial load
    loadMembers();
  </script>
</Layout>
