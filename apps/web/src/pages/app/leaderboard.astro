---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import { db } from '@smauii/db';
import { users, badges, userBadges } from '@smauii/db';
import { desc, eq } from 'drizzle-orm';
import { requireMember } from '@lib/guards';

const redirect = requireMember(Astro);
if (redirect) return redirect;

const [leaderboard, allBadges, recentBadges] = await Promise.all([
  db.select({
    id: users.id,
    name: users.name,
    avatarUrl: users.avatarUrl,
    class: users.class,
    badgeScore: users.badgeScore,
  })
    .from(users)
    .where(eq(users.status, 'active'))
    .orderBy(desc(users.badgeScore))
    .limit(50),

  db.select().from(badges),

  db.select({
    userId: userBadges.userId,
    userName: users.name,
    badgeName: badges.name,
    badgeIcon: badges.icon,
    badgeTier: badges.tier,
    awardedAt: userBadges.awardedAt,
  })
    .from(userBadges)
    .innerJoin(users, eq(userBadges.userId, users.id))
    .innerJoin(badges, eq(userBadges.badgeId, badges.id))
    .orderBy(desc(userBadges.awardedAt))
    .limit(10),
]);

const tierColors: Record<string, string> = {
  bronze: 'text-amber-600 bg-amber-600/20',
  silver: 'text-gray-400 bg-gray-400/20',
  gold: 'text-yellow-400 bg-yellow-400/20',
  diamond: 'text-cyan-400 bg-cyan-400/20',
};
---

<DashboardLayout title="Leaderboard">
  <PageHeader subtitle="Member paling aktif berdasarkan achievement badges" />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Leaderboard -->
    <div class="lg:col-span-2">
      <div class="bg-gray-900 border border-gray-800 rounded-xl overflow-hidden">
        <div class="p-4 border-b border-gray-800">
          <h2 class="font-semibold">Top Contributors</h2>
        </div>
        <div class="divide-y divide-gray-800">
          {leaderboard.map((user, index) => (
            <div class="flex items-center gap-4 p-4 hover:bg-gray-800/50 transition">
              <div class={`w-8 h-8 rounded-full flex items-center justify-center font-bold text-sm
                ${index === 0 ? 'bg-yellow-500 text-gray-900' : ''}
                ${index === 1 ? 'bg-gray-400 text-gray-900' : ''}
                ${index === 2 ? 'bg-amber-600 text-white' : ''}
                ${index > 2 ? 'bg-gray-800 text-gray-400' : ''}`}>
                {index + 1}
              </div>
              {user.avatarUrl ? (
                <img src={user.avatarUrl} alt={user.name} class="w-10 h-10 rounded-full object-cover" />
              ) : (
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold">
                  {user.name.charAt(0).toUpperCase()}
                </div>
              )}
              <div class="flex-1 min-w-0">
                <p class="font-medium truncate">{user.name}</p>
                <p class="text-sm text-gray-500 truncate">{user.class}</p>
              </div>
              <div class="text-right">
                <p class="font-bold text-blue-400">{user.badgeScore}</p>
                <p class="text-xs text-gray-500">points</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Recent Badges -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <h3 class="font-semibold mb-4">Recent Badges</h3>
        <div class="space-y-3">
          {recentBadges.map((b) => (
            <div class="flex items-center gap-3">
              <span class="text-2xl">{b.badgeIcon}</span>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium truncate">{b.userName}</p>
                <p class="text-xs text-gray-500">{b.badgeName}</p>
              </div>
              <span class={`text-xs px-2 py-0.5 rounded ${tierColors[b.badgeTier] || 'text-gray-400'}`}>
                {b.badgeTier}
              </span>
            </div>
          ))}
        </div>
      </div>

      <!-- All Badges -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
        <h3 class="font-semibold mb-4">All Badges ({allBadges.length})</h3>
        <div class="grid grid-cols-4 gap-2">
          {allBadges.map((badge) => (
            <div class="flex flex-col items-center p-2 rounded-lg bg-gray-800/50" title={badge.name}>
              <span class="text-2xl">{badge.icon}</span>
              <span class={`text-xs mt-1 px-1.5 py-0.5 rounded ${tierColors[badge.tier] || ''}`}>
                {badge.tier}
              </span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
