---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import LeaderboardDashboard from '@components/app/LeaderboardDashboard';
import { requireMember } from '@lib/guards';
import { db } from '@smauii/db';
import { users, badges, userBadges } from '@smauii/db';
import { desc, eq } from 'drizzle-orm';

const redirect = requireMember(Astro); if (redirect) return redirect;

// SSR Data fetching (skipped in SSG mode)
let leaderboardData = null;
const isSSG = import.meta.env.DEPLOY_MODE === 'ssg';

if (!isSSG) {
  try {
    const [leaderboard, allBadges, recentBadges] = await Promise.all([
      db.select({
        id: users.id,
        name: users.name,
        avatarUrl: users.avatarUrl,
        class: users.class,
        badgeScore: users.badgeScore,
      })
        .from(users)
        .where(eq(users.status, 'active'))
        .orderBy(desc(users.badgeScore))
        .limit(50),

      db.select().from(badges),

      db.select({
        userId: userBadges.userId,
        userName: users.name,
        badgeName: badges.name,
        badgeIcon: badges.icon,
        badgeTier: badges.tier,
        awardedAt: userBadges.awardedAt,
      })
        .from(userBadges)
        .innerJoin(users, eq(userBadges.userId, users.id))
        .innerJoin(badges, eq(userBadges.badgeId, badges.id))
        .orderBy(desc(userBadges.awardedAt))
        .limit(10),
    ]);

    const ranked = leaderboard.map((user, index) => ({
      rank: index + 1,
      ...user,
    }));

    leaderboardData = {
      leaderboard: ranked,
      allBadges,
      recentBadges,
    };
  } catch (error) {
    console.error('SSR leaderboard query failed, falling back to client-side load:', error);
  }
}
---

<DashboardLayout title="Leaderboard" requiredRole="member">
  <LeaderboardDashboard client:load initialData={leaderboardData} />
</DashboardLayout>
