---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import CardDashboard from '@components/app/CardDashboard';
import { requireMember } from '@lib/guards';
import { db } from '@smauii/db';
import { memberCards } from '@smauii/db';
import { eq } from 'drizzle-orm';

// SSG-first: guards return null in SSG mode
const redirect = requireMember(Astro); if (redirect) return redirect;

// Get user data from DashboardLayout client-side script (SSG) or Astro.locals (SSR)
let user = null;
const isSSG = import.meta.env.DEPLOY_MODE === 'ssg';
if (!isSSG && import.meta.env.DEPLOY_MODE === 'ssr') {
  const locals = Astro.locals;
  user = locals.user;
}

// SSR Data fetching (skipped in SSG mode)
let card = null;
if (!isSSG && user) {
  try {
    const cardRes = await db.query.memberCards.findFirst({ where: eq(memberCards.userId, user.id) });
    if (cardRes) {
      card = {
        cardNumber: cardRes.cardNumber,
        qrCode: cardRes.qrCode,
        issuedAt: cardRes.issuedAt,
      };
    }
  } catch (error) {
    console.error('SSR card query failed, falling back to client-side load:', error);
  }
}
---

<DashboardLayout title="Member Card" requiredRole="member">
  <CardDashboard client:load initialUser={user} initialCard={card} />
</DashboardLayout>
