---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import SkeletonList from '@components/app/SkeletonList.astro';
import Modal from '@components/app/Modal.astro';
import FilterBar from '@components/ui/FilterBar.astro';
import AvatarListItem from '@components/ui/AvatarListItem.astro';
import Badge from '@components/ui/Badge.astro';
import IconButton from '@components/ui/IconButton.astro';
import { requireMaintainer } from '@lib/guards';
import { trackOptions, classOptions } from '@smauii/validation';
const redirect = requireMaintainer(Astro); if (redirect) return redirect;
---

<DashboardLayout title="Members">
  <PageHeader subtitle="Kelola dan pantau seluruh anggota komunitas" />

  <!-- Track filter chips -->
  <div class="flex flex-wrap gap-2 mb-3" id="track-filters" data-testid="track-filters">
    <button data-track="" data-testid="filter-track-all"
      class="track-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-blue-600 text-white border border-blue-600 transition-all duration-300">Semua Track</button>
    {trackOptions.map((opt: {value: string; label: string}) => (
      <button data-track={opt.value} data-testid={`filter-track-${opt.value}`}
        class="track-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-gray-900/60 text-gray-400 hover:text-white border border-gray-800/80 hover:border-gray-700/80 transition-all duration-300">{opt.label.replace(/^[^\s]+\s/, '')}</button>
    ))}
  </div>

  <div class="flex flex-col sm:flex-row gap-3 mb-4">
    <div class="flex gap-2" id="status-filters" data-testid="member-filters">
      <button data-status="" data-testid="filter-all"
        class="filter-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-blue-600 text-white border border-blue-600 transition-all duration-300">Semua</button>
      <button data-status="pending" data-testid="filter-pending"
        class="filter-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-gray-900/60 text-gray-400 hover:text-white border border-gray-800/80 hover:border-gray-700/80 transition-all duration-300">Pending</button>
      <button data-status="active" data-testid="filter-active"
        class="filter-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-gray-900/60 text-gray-400 hover:text-white border border-gray-800/80 hover:border-gray-700/80 transition-all duration-300">Active</button>
      <button data-status="rejected" data-testid="filter-rejected"
        class="filter-btn px-3.5 py-1.5 rounded-xl text-xs font-semibold bg-gray-900/60 text-gray-400 hover:text-white border border-gray-800/80 hover:border-gray-700/80 transition-all duration-300">Rejected</button>
    </div>
    <select id="class-filter" data-testid="class-filter"
      class="px-4 py-2 bg-gray-950/60 border border-gray-800/80 rounded-xl text-sm text-gray-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 hover:border-gray-700/80 cursor-pointer">
      <option value="">Semua Kelas</option>
      {classOptions.map((c: string) => (<option value={c}>{c}</option>))}
    </select>
    <input type="text" id="search-input" data-testid="member-search"
      placeholder="Cari nama, email, NISN..."
      autocomplete="off"
      class="flex-1 px-4 py-2 bg-gray-950/60 border border-gray-800/80 rounded-xl text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 hover:border-gray-700/80">
  </div>

  <div id="members-content" data-testid="members-list"><SkeletonList count={5} /></div>

  <!-- Member Detail Modal -->
  <Modal id="detail-modal" title="Detail Anggota" draggable>
    <div id="detail-content" class="space-y-3">
      <!-- Populated by JS -->
    </div>
  </Modal>

  <Modal id="password-modal" title="Set Password Anggota" draggable>
    <p class="text-sm text-gray-400 mb-4">Set password untuk: <span id="modal-member-name" class="text-white font-medium"></span></p>
    <input type="password" id="new-password" placeholder="Password baru (min. 6 karakter)" data-validate="min:6"
      class="w-full px-4 py-3 bg-gray-950/60 border border-gray-800/80 rounded-xl text-sm text-gray-200 placeholder-gray-600 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 mb-2 invalid:border-red-500 hover:border-gray-700/80">
    <p class="text-xs text-red-400 mb-4 hidden" data-error="password"></p>
    <div class="flex gap-3">
      <button id="cancel-password" class="btn-ripple flex-1 px-4 py-2.5 bg-gray-850 border border-gray-800/85 hover:bg-gray-800 text-gray-300 rounded-xl text-sm font-semibold transition-all duration-300">Batal</button>
      <button id="confirm-password" class="btn-ripple flex-1 px-4 py-2.5 bg-blue-600 hover:bg-blue-500 text-white rounded-xl text-sm font-semibold transition-all duration-300">Set Password</button>
    </div>
  </Modal>

  <script>
    declare function showToast(message: string, type?: string, duration?: number): void;

    import { esc, renderPagination, setBtnLoading, confirmAction, setupPullToRefresh, staggerList, setupSwipeAction } from '@lib/ui';
    import { apiFetch, getCachedData } from '@lib/api-client';

    const contentEl = document.getElementById('members-content') as HTMLElement;
    const pwInput = document.getElementById('new-password') as HTMLInputElement;
    const classFilter = document.getElementById('class-filter') as HTMLSelectElement;
    const confirmBtn = document.getElementById('confirm-password') as HTMLButtonElement;

    let currentStatus = '';
    let currentTrack = '';
    let currentClass = '';
    let currentSearch = '';
    let currentPage = 1;
    let selectedUserId = '';
    const PAGE_LIMIT = 20;

    // Pull-to-refresh
    setupPullToRefresh(contentEl.parentElement as HTMLElement, async () => {
      await load();
    });

    // Swipe-to-action (for quick approve/reject on mobile)
    setupSwipeAction(contentEl, async (id, action) => {
      if (action === 'approve' || action === 'reject') {
        const ok = await confirmAction({ 
          message: action === 'approve' ? 'Setujui anggota ini?' : 'Tolak dan hapus anggota ini?',
          confirmText: action === 'approve' ? 'Approve' : 'Reject'
        });
        if (!ok) return;
        const { error } = await apiFetch('/api/admin/approve', { 
          method: 'POST', 
          body: JSON.stringify({ userId: id, action }) 
        });
        if (!error) load();
        else showToast('Gagal', 'error');
      }
    });

    const statusColors: Record<string, string> = {
      pending: 'text-yellow-400 bg-yellow-400/10',
      active:  'text-green-400 bg-green-400/10',
      rejected:'text-red-400 bg-red-400/10',
    };

    function renderMember(m: any): string {
      const isPending = m.status === 'pending';
      return `
        <div class="bg-gray-900/60 border border-gray-800/80 rounded-2xl p-5 flex items-center justify-between hover:border-gray-750 hover:shadow-md transition-all duration-300 cursor-pointer" data-action="view-detail" data-id="${m.id}" data-swipe-id="${m.id}">
          ${isPending ? `
            <!-- Swipe action for pending members -->
            <div class="swipe-action" data-action="approve" data-id="${m.id}">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
          ` : ''}
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold flex-shrink-0">
              ${esc(m.name).charAt(0).toUpperCase()}
            </div>
            <div>
              <p class="font-semibold text-sm">${esc(m.name)}</p>
              <p class="text-xs text-gray-400">${esc(m.class)} · ${esc(m.email)}</p>
              ${m.tracks?.length ? `<p class="text-xs text-gray-500">${(m.tracks as string[]).map(esc).join(', ')}</p>` : ''}
            </div>
          </div>
          <div class="flex items-center gap-2 flex-shrink-0" onclick="event.stopPropagation()">
            <span class="px-2 py-0.5 rounded text-xs font-medium ${statusColors[m.status] || 'text-gray-400 bg-gray-800'}">${esc(m.status)}</span>
            ${isPending ? `
              <button data-action="approve" data-id="${m.id}"
                class="btn-ripple bg-green-600 hover:bg-green-500 text-white px-3 py-1 rounded text-xs transition">Approve</button>
              <button data-action="reject" data-id="${m.id}"
                class="btn-ripple bg-red-600 hover:bg-red-500 text-white px-3 py-1 rounded text-xs transition">Reject</button>
            ` : ''}
            <button data-action="set-password" data-id="${m.id}" data-name="${esc(m.name)}"
              class="btn-ripple bg-gray-700 hover:bg-gray-600 text-white px-3 py-1 rounded text-xs transition" title="Set Password">🔑</button>
          </div>
        </div>`;
    }

    function renderMembersUI(data: any): void {
      const { members = [], total = 0, page = 1, limit = PAGE_LIMIT } = data || {};

      // Update status filter buttons
      document.querySelectorAll<HTMLElement>('.filter-btn').forEach(btn => {
        const active = btn.dataset.status === currentStatus;
        btn.className = `filter-btn btn-ripple px-3.5 py-1.5 rounded-xl text-xs font-semibold border transition-all duration-300 ${active ? 'bg-blue-600 text-white border-blue-600' : 'bg-gray-900/60 text-gray-400 hover:text-white border-gray-800/80 hover:border-gray-700/80'}`;
      });

      // Update track filter buttons
      document.querySelectorAll<HTMLElement>('.track-btn').forEach(btn => {
        const active = btn.dataset.track === currentTrack;
        btn.className = `track-btn btn-ripple px-3.5 py-1.5 rounded-xl text-xs font-semibold border transition-all duration-300 ${active ? 'bg-blue-600 text-white border-blue-600' : 'bg-gray-900/60 text-gray-400 hover:text-white border-gray-800/80 hover:border-gray-700/80'}`;
      });

      contentEl.innerHTML = members.length
        ? '<div class="space-y-3">' + members.map(renderMember).join('') + '</div>'
        : `<div class="text-center py-16">
            <svg class="w-20 h-20 mx-auto text-gray-700 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            <p class="text-gray-400 text-sm mb-1">Tidak ada anggota ditemukan</p>
            <p class="text-gray-500 text-xs mb-4">Coba ubah filter atau kata kunci pencarian</p>
            <button onclick="currentStatus='';currentTrack='';currentClass='';currentSearch='';currentPage=1;load();" 
              class="btn-ripple bg-blue-600 hover:bg-blue-500 text-white px-5 py-2 rounded-lg text-sm font-medium transition inline-flex items-center gap-2">
              Reset Filter
            </button>
          </div>`;

      // Staggered entry animation
      const container = contentEl.firstElementChild as HTMLElement;
      if (container && members.length) {
        const items = Array.from(container.children) as HTMLElement[];
        staggerList(container, items);
      }

      renderPagination('members-pagination', 'members-content', total, page, limit, 'anggota', 'window.goToPage');
    }

    async function load() {
      const params = new URLSearchParams({ admin: '1', page: String(currentPage), limit: String(PAGE_LIMIT) });
      if (currentStatus) params.set('status', currentStatus);
      if (currentTrack) params.set('track', currentTrack);
      if (currentClass) params.set('class', currentClass);
      if (currentSearch) params.set('search', currentSearch);

      const { data, error } = await apiFetch<any>(`/api/members?${params}`);
      if (error) {
        showToast('Gagal memuat data anggota', 'error');
        return;
      }
      renderMembersUI(data);
    }

    window.goToPage = (page: number) => { currentPage = page; load(); window.scrollTo(0, 0); };

    // --- Event delegation untuk list ---

    contentEl.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!btn) return;
      const { action, id, name } = btn.dataset;

      if (action === 'view-detail') {
        const { data, error } = await apiFetch<any>(`/api/admin/users?id=${id}`);
        if (error) {
          showToast('Gagal memuat detail anggota', 'error');
          return;
        }
        if (data?.user) {
          const detailContent = document.getElementById('detail-content');
          if (detailContent) {
            detailContent.innerHTML = `
              <div class="flex items-center gap-3 mb-4">
                <div class="w-12 h-12 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-lg">${esc(data.user.name).charAt(0).toUpperCase()}</div>
                <div>
                  <p class="font-semibold text-white">${esc(data.user.name)}</p>
                  <p class="text-xs text-gray-400">${esc(data.user.email)}</p>
                </div>
              </div>
              <div class="grid grid-cols-2 gap-2 text-sm">
                <p class="text-gray-400">NISN:</p><p class="text-white">${esc(data.user.nisn || '-')}</p>
                <p class="text-gray-400">NIS:</p><p class="text-white">${esc(data.user.nis || '-')}</p>
                <p class="text-gray-400">Kelas:</p><p class="text-white">${esc(data.user.class || '-')}</p>
                <p class="text-gray-400">Status:</p><p class="text-white">${esc(data.user.status)}</p>
                <p class="text-gray-400">Role:</p><p class="text-white">${esc(data.user.role)}</p>
                <p class="text-gray-400">Track:</p><p class="text-white">${data.tracks?.length ? data.tracks.map(esc).join(', ') : '-'}</p>
                <p class="text-gray-400">Bergabung:</p><p class="text-white">${data.user.joinedAt ? new Date(data.user.joinedAt).toLocaleDateString('id-ID') : '-'}</p>
              </div>
              <p class="text-xs text-gray-400 mt-4">Disetujui oleh: ${data.user.approvedBy ? esc(data.user.approvedBy) : 'Belum disetujui'}</p>
              ${data.user.status === 'active' && data.user.role !== 'maintainer' ? `
                <div class="border-t border-gray-800 pt-3 mt-4">
                  <button data-action="toggle-alumni" data-id="${esc(data.user.id)}" data-name="${esc(data.user.name)}" data-role="${esc(data.user.role)}"
                    class="w-full py-2 rounded-lg text-sm font-medium transition ${data.user.role === 'alumni' ? 'bg-blue-600 hover:bg-blue-500 text-white' : 'bg-gray-800 hover:bg-gray-700 text-yellow-400'}">
                    ${data.user.role === 'alumni' ? 'Kembalikan ke Member' : 'Jadikan Alumni'}
                  </button>
                  ${data.user.role !== 'alumni' ? '<p class="text-xs text-gray-500 mt-2 text-center">Alumni tidak bisa log aktivitas baru</p>' : ''}
                </div>
              ` : ''}
            `;
          }
          __modal['detail-modal'].open();
        }
      }
      if (action === 'approve') {
        const card = btn.closest<HTMLElement>('[data-swipe-id]');
        const ok = await confirmAction({ message: 'Setujui anggota ini?', confirmText: 'Approve' });
        if (!ok) return;
        
        // Optimistic update
        const statusBadge = card?.querySelector('[class*="bg-yellow-400"]');
        if (statusBadge) {
          statusBadge.className = 'px-2 py-0.5 rounded text-xs font-medium text-green-400 bg-green-400/10';
          statusBadge.textContent = 'active';
        }
        card?.querySelector('[data-action="approve"]')?.remove();
        card?.querySelector('[data-action="reject"]')?.remove();
        
        const { error } = await apiFetch('/api/admin/approve', { 
          method: 'POST', 
          body: JSON.stringify({ userId: id, action: 'approve' }) 
        });
        if (error) {
          load(); // Rollback
          showToast('Gagal approve member', 'error');
        }
      }
      if (action === 'reject') {
        const card = btn.closest<HTMLElement>('[data-swipe-id]');
        const ok = await confirmAction({ message: 'Tolak dan hapus anggota ini?', confirmText: 'Reject' });
        if (!ok) return;
        
        // Optimistic delete
        const nextSibling = card?.nextElementSibling;
        const parent = card?.parentElement;
        card?.remove();
        
        const { error } = await apiFetch('/api/admin/approve', { 
          method: 'POST', 
          body: JSON.stringify({ userId: id, action: 'reject' }) 
        });
        if (error) {
          // Rollback
          if (nextSibling) parent?.insertBefore(card, nextSibling);
          else parent?.appendChild(card);
          showToast('Gagal reject member', 'error');
        }
      }
      if (action === 'set-password') {
        selectedUserId = id!;
        const nameEl = document.getElementById('modal-member-name');
        if (nameEl) nameEl.textContent = name || '';
        pwInput.value = '';
        __modal['password-modal'].open();
      }
      if (action === 'toggle-alumni') {
        const role = btn.dataset.role === 'alumni' ? 'member' : 'alumni';
        const ok = await confirmAction({ 
          message: `${role === 'alumni' ? 'Jadikan' : 'Kembalikan'} ${esc(name || '')} sebagai ${role}?`,
          confirmText: role === 'alumni' ? 'Jadikan Alumni' : 'Kembalikan'
        });
        if (!ok) return;
        const { error } = await apiFetch<any>('/api/admin/users', {
          method: 'PATCH',
          body: JSON.stringify({ userId: id, role }),
        });
        if (!error) { __modal['detail-modal'].close(); load(); }
        else { showToast(error || 'Gagal mengubah role', 'error'); }
      }
    });

    // --- Filter & search ---

    document.getElementById('status-filters')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.filter-btn');
      if (!btn) return;
      currentStatus = btn.dataset.status || '';
      currentPage = 1;
      load();
    });

    document.getElementById('track-filters')?.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('.track-btn');
      if (!btn) return;
      currentTrack = btn.dataset.track || '';
      currentPage = 1;
      load();
    });

    classFilter?.addEventListener('change', (e) => {
      currentClass = (e.target as HTMLSelectElement).value;
      currentPage = 1;
      load();
    });

    document.getElementById('search-input')?.addEventListener('input', (e) => {
      currentSearch = (e.target as HTMLInputElement).value;
      currentPage = 1;
      load();
    });

    // --- Password modal dengan validation ---

function validatePassword(password: string): string | null {
      if (!password.trim()) return 'Password tidak boleh kosong';
      if (password.length < 6) return 'Password minimal 6 karakter';
      return null;
    }

    const passwordErrorEl = document.querySelector('[data-error="password"]') as HTMLElement | null;

    pwInput?.addEventListener('blur', () => {
      const error = validatePassword(pwInput.value);
      if (error) {
        passwordErrorEl?.classList.remove('hidden');
        passwordErrorEl!.textContent = error;
        pwInput.classList.add('border-red-500');
      } else {
        passwordErrorEl?.classList.add('hidden');
        pwInput.classList.remove('border-red-500');
      }
    });

    document.getElementById('cancel-password')?.addEventListener('click', () => {
      __modal['password-modal'].close();
      selectedUserId = '';
    });

    document.getElementById('confirm-password')?.addEventListener('click', async () => {
      const password = pwInput.value;
      const error = validatePassword(password);
      if (error) {
        passwordErrorEl?.classList.remove('hidden');
        passwordErrorEl!.textContent = error;
        pwInput.classList.add('border-red-500');
        return;
      }

      setBtnLoading(confirmBtn, true, 'Menyimpan...');
      const { error: apiError } = await apiFetch<any>('/api/admin/set-password', {
        method: 'POST',
        body: JSON.stringify({ userId: selectedUserId, password }),
      });
      setBtnLoading(confirmBtn, false);

      if (!apiError) {
        showToast('Password berhasil diatur', 'success');
        __modal['password-modal'].close();
        selectedUserId = '';
      } else {
        showToast(apiError || 'Gagal set password', 'error');
      }
    });

    // Expose untuk backward compat (E2E tests)
    window.filterMembers = (s: string) => { currentStatus = s; currentPage = 1; load(); };
    window.searchMembers = (v: string) => { currentSearch = v; currentPage = 1; load(); };

    // Sync cache: render cached data immediately to skip skeleton flash on ViewTransitions
    const defaultCacheKey = `/api/members?admin=1&page=${currentPage}&limit=${PAGE_LIMIT}`;
    const cached = getCachedData<any>(defaultCacheKey);
    if (cached?.data) renderMembersUI(cached.data);
    // Background refresh: fetch fresh data without showing loading
    load();
  </script>
</DashboardLayout>
