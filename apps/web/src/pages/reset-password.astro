---
import AuthLayout from '@layouts/AuthLayout.astro';

const token = Astro.url.searchParams.get('token');

if (!token) {
  return Astro.redirect('/forgot-password');
}
---

<AuthLayout title="Reset Password" subtitle="Masukkan password baru untuk akun kamu">
  <form id="reset-form" class="space-y-4">
    <input type="hidden" id="token" value={token} />

    <div>
      <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider">Password Baru</label>
      <input
        type="password"
        id="password"
        name="password"
        class="w-full bg-gray-950/60 border border-gray-800/80 rounded-xl px-4 py-3 text-sm text-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 placeholder-gray-600 hover:border-gray-700/80"
        placeholder="••••••••"
        autocomplete="new-password"
        required
        minlength="8"
      />
      <p id="password-error" class="text-red-400 text-xs mt-1.5 hidden"></p>
    </div>

    <div>
      <label class="block text-xs font-medium text-gray-400 mb-1.5 uppercase tracking-wider">Konfirmasi Password</label>
      <input
        type="password"
        id="confirm-password"
        name="confirm-password"
        class="w-full bg-gray-950/60 border border-gray-800/80 rounded-xl px-4 py-3 text-sm text-gray-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-blue-500/40 focus:border-blue-500/60 focus:bg-gray-900/60 transition-all duration-300 placeholder-gray-600 hover:border-gray-700/80"
        placeholder="••••••••"
        autocomplete="new-password"
        required
        minlength="8"
      />
      <p id="confirm-error" class="text-red-400 text-xs mt-1.5 hidden"></p>
    </div>

    <div id="success-message" class="p-3 bg-green-500/10 border border-green-500/20 rounded-xl text-green-400 text-sm hidden"></div>
    <div id="error-message" class="p-3 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm hidden"></div>

    <button
      type="submit"
      id="submit-btn"
      class="btn-ripple w-full bg-blue-600 hover:bg-blue-500 disabled:opacity-40 disabled:cursor-not-allowed text-white px-5 py-3.5 rounded-xl font-semibold text-sm transition-all duration-300 shadow-lg shadow-blue-600/15 mt-2"
    >
      Reset Password
    </button>
  </form>

  <p class="text-center text-xs text-gray-600 mt-6">
    <a href="/login" class="btn-ripple text-blue-400 hover:text-blue-300 transition-colors inline-block px-3 py-1.5 rounded-lg">← Kembali ke login</a>
  </p>
</AuthLayout>

<script>
  import { apiFetch } from '@lib/api-client';
  const form = document.getElementById('reset-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const errorMessage = document.getElementById('error-message') as HTMLDivElement;
  const successMessage = document.getElementById('success-message') as HTMLDivElement;
  const passwordInput = document.getElementById('password') as HTMLInputElement;
  const confirmInput = document.getElementById('confirm-password') as HTMLInputElement;
  const passwordError = document.getElementById('password-error') as HTMLParagraphElement;
  const confirmError = document.getElementById('confirm-error') as HTMLParagraphElement;
  const tokenInput = document.getElementById('token') as HTMLInputElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorMessage.classList.add('hidden');
    successMessage.classList.add('hidden');
    passwordError.classList.add('hidden');
    confirmError.classList.add('hidden');

    const password = passwordInput.value;
    const confirm = confirmInput.value;

    let hasError = false;

    if (!password || password.length < 8) {
      passwordError.textContent = 'Password minimal 8 karakter';
      passwordError.classList.remove('hidden');
      passwordInput.focus();
      hasError = true;
    }

    if (!confirm) {
      confirmError.textContent = 'Konfirmasi password harus diisi';
      confirmError.classList.remove('hidden');
      confirmInput.focus();
      hasError = true;
    }

    if (password !== confirm) {
      confirmError.textContent = 'Password tidak cocok';
      confirmError.classList.remove('hidden');
      confirmInput.focus();
      hasError = true;
    }

    if (hasError) return;

    submitBtn.disabled = true;
    submitBtn.textContent = 'Memproses...';

    try {
      const { data, error, code } = await apiFetch<{ message: string }>('/api/auth/reset-password', {
        method: 'POST',
        body: JSON.stringify({ token: tokenInput.value, password }),
      });

      if (error) {
        if (code === 'INVALID_TOKEN' || code === 'TOKEN_EXPIRED') {
          errorMessage.textContent = error + ' Silakan minta tautan baru.';
          errorMessage.innerHTML += ' <a href="/forgot-password" class="text-blue-400 underline">Minta tautan baru</a>';
        } else {
          errorMessage.textContent = error || 'Terjadi kesalahan';
        }
        errorMessage.classList.remove('hidden');
        return;
      }

      successMessage.textContent = data?.message || 'Password berhasil direset.';
      successMessage.classList.remove('hidden');

      form.querySelectorAll('input[type="password"]').forEach((el) => {
        (el as HTMLInputElement).value = '';
      });

      setTimeout(() => {
        window.location.href = '/login';
      }, 2000);
    } catch {
      errorMessage.textContent = 'Terjadi kesalahan. Silakan coba lagi.';
      errorMessage.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Reset Password';
    }
  });
// Inline validation on blur
  passwordInput.addEventListener('blur', () => {
    const password = passwordInput.value;
    if (!password) {
      passwordError.textContent = 'Password harus diisi';
      passwordError.classList.remove('hidden');
      return;
    }
    if (password.length < 8) {
      passwordError.textContent = 'Password minimal 8 karakter';
      passwordError.classList.remove('hidden');
      return;
    }
    passwordError.classList.add('hidden');
  });

  confirmInput.addEventListener('blur', () => {
    const confirm = confirmInput.value;
    if (!confirm) {
      confirmError.textContent = 'Konfirmasi password harus diisi';
      confirmError.classList.remove('hidden');
      return;
    }
    if (confirm !== passwordInput.value) {
      confirmError.textContent = 'Password tidak cocok';
      confirmError.classList.remove('hidden');
      return;
    }
    confirmError.classList.add('hidden');
  });

  passwordInput.addEventListener('input', () => {
    if (!passwordError.classList.contains('hidden')) {
      passwordError.classList.add('hidden');
    }
  });

  confirmInput.addEventListener('input', () => {
    if (!confirmError.classList.contains('hidden')) {
      confirmError.classList.add('hidden');
    }
  });
</script>
