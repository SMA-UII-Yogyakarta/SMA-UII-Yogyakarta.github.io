---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Proyek">
  <div id="projects-content" class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Proyek Open Source</h1>
    <p class="text-gray-400 mb-4">Karya nyata dari komunitas SMA UII Lab</p>
    <p class="text-sm text-gray-500 mb-12">
      Semua proyek terbuka di GitHub. Kamu bisa belajar dari kode, kontribusi, atau fork untuk proyek sendiri.
    </p>

    <div id="projects-loading" class="grid sm:grid-cols-2 gap-6">
      {Array.from({ length: 4 }).map(() => `
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 animate-pulse">
          <div class="flex items-start justify-between mb-3">
            <div class="h-5 bg-gray-800 rounded w-32"></div>
            <div class="h-5 bg-gray-800 rounded w-14"></div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="h-4 bg-gray-800 rounded w-full"></div>
            <div class="h-4 bg-gray-800 rounded w-3/4"></div>
          </div>
          <div class="flex gap-2 mb-3">
            <div class="h-5 bg-gray-800 rounded w-12"></div>
            <div class="h-5 bg-gray-800 rounded w-16"></div>
          </div>
          <div class="h-3 bg-gray-800 rounded w-20"></div>
        </div>
      `).join('')}
    </div>

    <div id="projects-grid" class="hidden grid sm:grid-cols-2 gap-6"></div>

    <div id="projects-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-4">📂</div>
      <p class="text-gray-400">Belum ada proyek</p>
    </div>

    <div id="projects-error" class="hidden text-center py-12">
      <div class="text-4xl mb-4">⚠️</div>
      <p class="text-red-400">Gagal memuat data proyek</p>
    </div>

    <div id="pagination" class="hidden flex items-center justify-center gap-4 mt-10">
      <button id="prev-btn" disabled
        class="px-4 py-2 rounded-lg border border-gray-700 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500 hover:text-white transition">
        ← Sebelumnya
      </button>
      <span id="page-indicator" class="text-sm text-gray-400"></span>
      <button id="next-btn" disabled
        class="px-4 py-2 rounded-lg border border-gray-700 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500 hover:text-white transition">
        Selanjutnya →
      </button>
    </div>

    <section class="mt-16 text-center border-t border-gray-800 pt-16">
      <h2 class="text-2xl font-bold mb-4">Punya Ide Proyek?</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Usulkan proyek baru atau mulai proyek sendiri di track yang kamu minati.
        Kami siap bantu dari ide sampai deployment!
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CONTRIBUTING.md"
           target="_blank"
           class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-lg font-semibold transition">
          Panduan Kontribusi
        </a>
        <a href="/tracks"
           class="border border-gray-700 hover:border-blue-500 px-6 py-2.5 rounded-lg font-semibold transition">
          Lihat Track
        </a>
      </div>
    </section>
  </div>

  <script>
    function escapeHtml(str: string): string {
      if (!str) return '';
      const htmlEntities: Record<string, string> = {
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#x27;',
        '/': '&#x2F;',
      };
      return str.replace(/[&<>"'/]/g, (char) => htmlEntities[char] || char);
    }

    function formatDate(ts: number): string {
      return new Date(ts).toLocaleDateString('id-ID', { year: 'numeric', month: 'long' });
    }

    function renderProjectCard(p: any): string {
      const hasUrl = p.url && p.url.length > 0;
      const cardContent = `
        <div class="flex items-start justify-between mb-3">
          <h3 class="font-mono font-semibold text-blue-400 ${hasUrl ? 'group-hover:text-blue-300' : ''} transition">${escapeHtml(p.title)}</h3>
          ${p.createdAt ? `<span class="text-xs text-gray-500">${formatDate(p.createdAt)}</span>` : ''}
        </div>
        ${p.description ? `<p class="text-sm text-gray-400 mb-4">${escapeHtml(p.description)}</p>` : ''}
        ${p.userName ? `
          <div class="flex items-center gap-2 mb-3">
            <span class="text-xs text-gray-500">👤 ${escapeHtml(p.userName)}</span>
          </div>
        ` : ''}
        ${p.url ? `
          <div class="flex items-center gap-3 text-xs text-gray-500">
            <span class="text-blue-400 group-hover:text-blue-300 transition">${escapeHtml(new URL(p.url).hostname + new URL(p.url).pathname)} →</span>
          </div>
        ` : ''}
      `;

      const wrapperClass = 'bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-500 transition block group';

      if (hasUrl) {
        return `
          <a href="${escapeHtml(p.url)}" target="_blank" rel="noopener noreferrer" class="${wrapperClass}">
            ${cardContent}
          </a>
        `;
      }
      return `
        <div class="${wrapperClass}">
          ${cardContent}
        </div>
      `;
    }

    async function loadProjects(page: number = 1) {
      const loading = document.getElementById('projects-loading')!;
      const grid = document.getElementById('projects-grid')!;
      const empty = document.getElementById('projects-empty')!;
      const error = document.getElementById('projects-error')!;
      const pagination = document.getElementById('pagination')!;
      const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
      const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
      const indicator = document.getElementById('page-indicator')!;

      loading.classList.remove('hidden');
      grid.classList.add('hidden');
      empty.classList.add('hidden');
      error.classList.add('hidden');
      pagination.classList.add('hidden');

      try {
        const response = await fetch(`/api/public/projects?page=${page}&limit=12`);
        if (!response.ok) throw new Error('Failed to load projects');

        const result = await response.json();
        const { data, total, limit } = result.data;
        const totalPages = Math.max(1, Math.ceil(total / limit));

        loading.classList.add('hidden');

        if (data.length === 0) {
          empty.classList.remove('hidden');
          return;
        }

        grid.innerHTML = data.map(renderProjectCard).join('');
        grid.classList.remove('hidden');

        indicator.textContent = `Halaman ${page} dari ${totalPages} (${total} proyek)`;
        prevBtn.disabled = page <= 1;
        nextBtn.disabled = page >= totalPages;
        pagination.classList.remove('hidden');

        prevBtn.onclick = () => { if (page > 1) loadProjects(page - 1); };
        nextBtn.onclick = () => { if (page < totalPages) loadProjects(page + 1); };

        window.scrollTo({ top: 0, behavior: 'smooth' });
      } catch (err) {
        loading.classList.add('hidden');
        grid.classList.add('hidden');
        error.classList.remove('hidden');
      }
    }

    loadProjects();
  </script>
</Layout>
