---
import Layout from '@layouts/Layout.astro';
---

<Layout title="Proyek">
  <div id="projects-content" class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Proyek Open Source</h1>
    <p class="text-gray-400 mb-4">Karya nyata dari komunitas SMA UII Lab</p>
    <p class="text-sm text-gray-500 mb-12">
      Semua proyek terbuka di GitHub. Kamu bisa belajar dari kode, kontribusi, atau fork untuk proyek sendiri.
    </p>

    <!-- Skeleton Loading - FIXED: Use JSX syntax, NOT template strings -->
    <div id="projects-loading" class="grid sm:grid-cols-2 gap-6">
      {Array.from({ length: 4 }).map(() => (
        <div class="bg-gray-900/40 border border-gray-800/80 rounded-2xl p-5 animate-pulse">
          <div class="flex items-start justify-between mb-3">
            <div class="h-5 bg-gray-800 rounded w-32"></div>
            <div class="h-5 bg-gray-800 rounded w-14"></div>
          </div>
          <div class="space-y-2 mb-4">
            <div class="h-4 bg-gray-800 rounded w-full"></div>
            <div class="h-4 bg-gray-800 rounded w-3/4"></div>
          </div>
          <div class="flex gap-2 mb-3">
            <div class="h-5 bg-gray-800 rounded w-12"></div>
            <div class="h-5 bg-gray-800 rounded w-16"></div>
          </div>
          <div class="h-3 bg-gray-800 rounded w-20"></div>
        </div>
      ))}
    </div>

    <div id="projects-grid" class="hidden grid sm:grid-cols-2 gap-6"></div>

    <div id="projects-empty" class="hidden text-center py-12">
      <div class="text-4xl mb-4">📂</div>
      <p class="text-gray-400">Belum ada proyek</p>
    </div>

    <div id="projects-error" class="hidden text-center py-12">
      <div class="text-4xl mb-4">⚠️</div>
      <p class="text-red-400">Gagal memuat data proyek</p>
    </div>

    <div id="pagination" class="hidden flex items-center justify-center gap-4 mt-10">
      <button id="prev-btn" disabled aria-label="Previous page"
        class="btn-ripple px-4 py-2.5 rounded-xl border border-gray-800/80 bg-gray-900/40 hover:bg-gray-900/80 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500/60 hover:text-white transition-all duration-300">
        ← Sebelumnya
      </button>
      <span id="page-indicator" class="text-sm text-gray-400 font-medium"></span>
      <button id="next-btn" disabled aria-label="Next page"
        class="btn-ripple px-4 py-2.5 rounded-xl border border-gray-800/80 bg-gray-900/40 hover:bg-gray-900/80 text-gray-400 disabled:opacity-30 disabled:cursor-not-allowed hover:border-blue-500/60 hover:text-white transition-all duration-300">
        Selanjutnya →
      </button>
    </div>

    <section class="mt-16 text-center border-t border-gray-800 pt-16">
      <h2 class="text-2xl font-bold mb-4">Punya Ide Proyek?</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Usulkan proyek baru atau mulai proyek sendiri di track yang kamu minati.
        Kami siap bantu dari ide sampai deployment!
      </p>
      <div class="flex gap-4 justify-center">
        <a href="/tracks" class="btn-ripple px-6 py-3 bg-blue-600 hover:bg-blue-500 text-white rounded-xl font-semibold transition shadow-lg shadow-blue-600/10">
          Lihat Track
        </a>
        <a href="https://github.com/SMA-UII-Yogyakarta" target="_blank" rel="noopener"
          class="btn-ripple px-6 py-3 bg-gray-900/60 border border-gray-850 hover:bg-gray-800 text-white rounded-xl font-semibold transition">
          GitHub Org
        </a>
      </div>
    </section>
  </div>

  <script>
    import { esc } from '@lib/ui';

    const loadingEl = document.getElementById('projects-loading') as HTMLElement;
    const gridEl = document.getElementById('projects-grid') as HTMLElement;
    const emptyEl = document.getElementById('projects-empty') as HTMLElement;
    const errorEl = document.getElementById('projects-error') as HTMLElement;
    const paginationEl = document.getElementById('pagination') as HTMLElement;
    const prevBtn = document.getElementById('prev-btn') as HTMLButtonElement;
    const nextBtn = document.getElementById('next-btn') as HTMLButtonElement;
    const pageIndicator = document.getElementById('page-indicator') as HTMLElement;

    let currentPage = 1;
    const PAGE_SIZE = 6;

    async function loadProjects() {
      try {
        const res = await fetch(`/api/public/projects?page=${currentPage}&limit=${PAGE_SIZE}`);
        const { data } = await res.json();
        const projects = data?.projects || [];
        const total = data?.total || 0;
        const totalPages = Math.ceil(total / PAGE_SIZE);

        if (projects.length === 0) {
          showEmpty();
          return;
        }

        renderProjects(projects);
        updatePagination(currentPage, totalPages);
      } catch (error) {
        console.error('Failed to load projects:', error);
        showError();
      }
    }

    function renderProjects(projects: any[]) {
      gridEl.innerHTML = projects.map(p => `
        <a href="${esc(p.url || '#')}" target="_blank" rel="noopener noreferrer"
          class="bg-gray-900/60 border border-gray-800/80 rounded-2xl p-6 hover:border-blue-500/60 hover:shadow-lg hover:shadow-black/20 transition-all duration-300 block group relative overflow-hidden">
          <div class="absolute inset-0 bg-linear-to-b from-white/1 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none"></div>
          <div class="flex items-start justify-between gap-4 mb-3 relative z-10">
            <h3 class="font-bold text-gray-100 group-hover:text-blue-400 transition-colors text-base">${esc(p.title)}</h3>
            <span class="text-xs bg-gray-800/70 border border-gray-700/40 px-2 py-1 rounded-md text-gray-400 flex-shrink-0">@${esc(p.userName || 'Unknown')}</span>
          </div>
          ${p.description ? `<p class="text-sm text-gray-400 mb-5 line-clamp-2 leading-relaxed relative z-10">${esc(p.description)}</p>` : ''}
          <div class="flex items-center gap-2 relative z-10">
            <span class="px-2.5 py-1 bg-blue-900/30 text-blue-400 rounded-lg text-xs font-semibold border border-blue-500/20">Open Source</span>
            ${p.url ? `
              <span class="px-2.5 py-1 bg-gray-800 text-gray-300 rounded-lg text-xs border border-gray-700/40 inline-flex items-center gap-1.5 font-medium">
                <svg class="w-3.5 h-3.5 text-gray-400 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                GitHub
              </span>
            ` : ''}
          </div>
          ${p.imageUrl ? `<div class="relative overflow-hidden rounded-xl mt-4 border border-gray-800/80"><img src="${esc(p.imageUrl)}" alt="${esc(p.title)}" class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-500"></div>` : ''}
        </a>
      `).join('');
    }

    function showEmpty() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.remove('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.add('hidden');
    }

    function showError() {
      loadingEl.classList.add('hidden');
      gridEl.classList.add('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.remove('hidden');
      paginationEl.classList.add('hidden');
    }

    function showContent() {
      loadingEl.classList.add('hidden');
      gridEl.classList.remove('hidden');
      emptyEl.classList.add('hidden');
      errorEl.classList.add('hidden');
      paginationEl.classList.remove('hidden');
    }

    function updatePagination(page: number, total: number) {
      pageIndicator.textContent = `Halaman ${page} dari ${total}`;
      prevBtn.disabled = page === 1;
      nextBtn.disabled = page === total || total === 0;
      showContent();
    }

    prevBtn?.addEventListener('click', () => {
      if (currentPage > 1) {
        currentPage--;
        loadProjects();
      }
    });

    nextBtn?.addEventListener('click', () => {
      currentPage++;
      loadProjects();
    });

    // Initial load
    loadProjects();
  </script>
</Layout>
