---
import Layout from '@layouts/Layout.astro';
import { getSiteConfig } from '@smauii/shared';

const config = getSiteConfig();

const activities = [
  {
    icon: "💻",
    title: "Sesi Praktikum Lab",
    description: "Pertemuan rutin mingguan untuk eksplorasi langsung. Belajar coding, instalasi server, analisis data, hingga merakit hardware IoT secara kolaboratif."
  },
  {
    icon: "🌐",
    title: "Proyek Nyata & Open Source",
    description: "Kami percaya portofolio terbaik adalah kode yang hidup. Semua platform dan aplikasi yang kami kembangkan dirilis secara terbuka di GitHub."
  },
  {
    icon: "🏆",
    title: "Riset & Kompetisi",
    description: "Pendampingan terarah untuk berpartisipasi dalam ajang bergengsi seperti OSN Informatika, OPSI (Riset Teknologi), Hackathon, dan Capture The Flag (CTF)."
  },
  {
    icon: "🤝",
    title: "Mentorship Alumni",
    description: "Hubungan erat dengan jaringan alumni yang kini menempuh studi di perguruan tinggi top maupun berkarier langsung di industri teknologi global."
  }
];

const principles = [
  {
    number: "01",
    title: "Open Source First",
    color: "text-blue-400 border-blue-500/20",
    hoverColor: "hover:border-blue-500/40",
    description: "Seluruh proyek kami terbuka untuk umum. Transparansi dan kolaborasi global adalah cara terbaik untuk melatih kemampuan engineering."
  },
  {
    number: "02",
    title: "Learning by Building",
    color: "text-purple-400 border-purple-500/20",
    hoverColor: "hover:border-purple-500/40",
    description: "Kami meminimalkan teori pasif. Pembelajaran terbaik didapatkan saat memecahkan masalah nyata, menulis baris kode, dan memperbaiki bug."
  },
  {
    number: "03",
    title: "Peer-to-Peer Learning",
    color: "text-emerald-400 border-emerald-500/20",
    hoverColor: "hover:border-emerald-500/40",
    description: "Kami belajar bersama sebagai satu komunitas. Siswa senior mendampingi junior, dan kolaborasi lintas track adalah hal yang lumrah."
  },
  {
    number: "04",
    title: "Persistensi & Eksplorasi",
    color: "text-amber-400 border-amber-500/20",
    hoverColor: "hover:border-amber-500/40",
    description: "Rasa ingin tahu dan konsistensi harian jauh lebih bernilai dibanding bakat instan. Kami menghargai setiap proses trial-and-error."
  }
];

const tracks = [
  { icon: "🤖", name: "Robotika & IoT", desc: "Eksplorasi sensor, mikrokontroler Arduino/ESP32, aktuator, hingga integrasi Internet of Things (IoT) untuk merancang alat otomatisasi fisik dan robot cerdas siap kompetisi nasional." },
  { icon: "🧠", name: "Kecerdasan Buatan (AI)", desc: "Pengembangan model kognitif cerdas, jaringan saraf tiruan, serta implementasi otomasi cerdas." },
  { icon: "📊", name: "Data Science", desc: "Mempelajari analisis statistik, pembersihan data mentah, visualisasi interaktif dengan pandas/SQL, hingga melatih model Machine Learning dasar untuk memecahkan masalah industri." },
  { icon: "🌐", name: "Jaringan Komputer", desc: "Arsitektur server, manajemen cloud, sistem operasi berbasis open source, dan keamanan transmisi data." },
  { icon: "🔐", name: "Keamanan Siber", desc: "Mempelajari penetration testing, investigasi forensik digital, analisis kerentanan sistem, dan persiapan intensif menghadapi kompetisi siber Capture The Flag (CTF)." },
  { icon: "💻", name: "Software Engineering", desc: "Pembuatan aplikasi web dan mobile modern, kontribusi repositori open-source, dan orkestrasi cloud." }
];
---

<Layout title="Tentang Kami">
  <div class="max-w-5xl mx-auto px-4 py-16 space-y-16">

    <!-- ── HERO SECTION ── -->
    <header class="text-center max-w-3xl mx-auto space-y-4">
      <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-[11px] font-semibold tracking-wider uppercase bg-blue-500/10 border border-blue-500/20 text-blue-400">
        Profil Komunitas
      </span>
      <h1 class="text-3xl sm:text-5xl font-extrabold tracking-tight text-white leading-tight">
        Membentuk Praktisi Teknologi <span class="bg-gradient-to-r from-blue-400 via-indigo-400 to-purple-400 bg-clip-text text-transparent">Masa Depan</span>
      </h1>
      <p class="text-sm sm:text-base text-gray-400 leading-relaxed">
        SMA UII Lab adalah wadah eksplorasi teknologi dan pengembangan bakat teknologi informasi bagi siswa SMA UII Yogyakarta. Kami membimbing siswa dari nol untuk siap berinovasi secara nyata, berkontribusi secara global, dan berkompetisi di tingkat nasional.
      </p>
    </header>

    <!-- ── STATS BADGES ── -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 max-w-4xl mx-auto">
      <div class="flex flex-col items-center justify-center p-4 rounded-2xl border border-gray-800/80 bg-gray-900/30">
        <span class="text-2xl font-bold text-white">6</span>
        <span class="text-xs text-gray-500 mt-1">Pilihan Track Belajar</span>
      </div>
      <div class="flex flex-col items-center justify-center p-4 rounded-2xl border border-gray-800/80 bg-gray-900/30">
        <span class="text-2xl font-bold text-white">100%</span>
        <span class="text-xs text-gray-500 mt-1">Open Source & Terbuka</span>
      </div>
      <div class="flex flex-col items-center justify-center p-4 rounded-2xl border border-gray-800/80 bg-gray-900/30">
        <span class="text-2xl font-bold text-white">P2P</span>
        <span class="text-xs text-gray-500 mt-1">Mentorship & Sharing</span>
      </div>
      <div class="flex flex-col items-center justify-center p-4 rounded-2xl border border-gray-800/80 bg-gray-900/30">
        <span class="text-2xl font-bold text-white">Aktif</span>
        <span class="text-xs text-gray-500 mt-1">Eksplorasi & Kompetisi</span>
      </div>
    </div>

    <!-- ── VISION & MISSION ── -->
    <section class="grid md:grid-cols-12 gap-6 items-stretch border-t border-gray-800/60 pt-12">
      <!-- Visi -->
      <div class="md:col-span-5 flex flex-col justify-between p-6 sm:p-8 rounded-2xl border border-gray-800/80 bg-gradient-to-b from-gray-900/40 to-transparent relative overflow-hidden group">
        <div class="absolute -right-10 -top-10 w-32 h-32 bg-blue-500/5 rounded-full blur-2xl group-hover:bg-blue-500/10 transition-colors duration-300"></div>
        <div>
          <span class="text-xs font-bold text-blue-400 uppercase tracking-widest">Arah Juang</span>
          <h2 class="text-2xl font-bold text-white mt-2 mb-4">Visi Kami</h2>
          <p class="text-sm sm:text-base text-gray-300 leading-relaxed font-medium">
            Membangun ekosistem developer dan open source contributor sejak bangku SMA, menghasilkan kreator teknologi yang adaptif, persistent, dan berdaya saing global.
          </p>
        </div>
        <div class="text-[5rem] font-bold text-blue-500/5 select-none absolute bottom-0 right-4 leading-none pointer-events-none">VISI</div>
      </div>

      <!-- Misi -->
      <div class="md:col-span-7 p-6 sm:p-8 rounded-2xl border border-gray-800/80 bg-gray-900/10 flex flex-col justify-between">
        <div>
          <span class="text-xs font-bold text-purple-400 uppercase tracking-widest">Langkah Nyata</span>
          <h2 class="text-2xl font-bold text-white mt-2 mb-6">Misi Utama</h2>
          <div class="space-y-4">
            <div class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 flex items-center justify-center text-xs">✓</span>
              <div>
                <h4 class="text-sm font-semibold text-white">Eksplorasi Berbasis Proyek</h4>
                <p class="text-xs sm:text-sm text-gray-400 mt-0.5">Memfasilitasi siswa belajar pemrograman, sistem komputer, dan AI melalui proyek aplikatif langsung.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 flex items-center justify-center text-xs">✓</span>
              <div>
                <h4 class="text-sm font-semibold text-white">Persiapan Kompetisi & Prestasi</h4>
                <p class="text-xs sm:text-sm text-gray-400 mt-0.5">Membimbing siswa mempersiapkan kompetisi sains, riset ilmiah, keamanan siber, dan inovasi nasional.</p>
              </div>
            </div>
            <div class="flex gap-3">
              <span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 flex items-center justify-center text-xs">✓</span>
              <div>
                <h4 class="text-sm font-semibold text-white">Penyusunan Portofolio Digital</h4>
                <p class="text-xs sm:text-sm text-gray-400 mt-0.5">Membantu siswa memiliki rekam jejak kontribusi publik di GitHub sebagai portofolio akademik masa depan.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── WHAT WE DO (ACTIVITIES) ── -->
    <section class="border-t border-gray-800/60 pt-12 space-y-8">
      <div class="max-w-xl">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Bagaimana Kami Bergerak</h2>
        <p class="text-sm text-gray-400">
          Proses pembelajaran dan kolaborasi di SMA UII Lab dibangun untuk menyerupai kultur riset lab modern dan industri IT.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        {activities.map((act) => (
          <div class="p-5 rounded-2xl border border-gray-800/80 bg-gray-900/20 flex gap-4 items-start hover:border-gray-700/60 transition-colors duration-200">
            <span class="text-2xl p-2.5 rounded-xl bg-gray-800/60 leading-none">{act.icon}</span>
            <div class="space-y-1">
              <h3 class="text-sm font-semibold text-white">{act.title}</h3>
              <p class="text-xs sm:text-sm text-gray-400 leading-relaxed">{act.description}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── CORE PRINCIPLES ── -->
    <section class="border-t border-gray-800/60 pt-12 space-y-8">
      <div class="max-w-xl">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Prinsip Fundamental</h2>
        <p class="text-sm text-gray-400">
          Nilai-nilai dasar yang dipegang erat oleh setiap anggota dalam berinteraksi, belajar, dan berkarya bersama.
        </p>
      </div>

      <!-- Mobile: carousel -->
      <div class="relative sm:hidden">
        <div class="pointer-events-none absolute left-0 top-0 bottom-4 w-8 z-10 bg-gradient-to-r from-gray-950 to-transparent" aria-hidden="true"></div>
        <div class="pointer-events-none absolute right-0 top-0 bottom-4 w-8 z-10 bg-gradient-to-l from-gray-950 to-transparent" aria-hidden="true"></div>
        <div id="principles-carousel" class="flex gap-3 overflow-x-auto pb-4 px-4"
             style="scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;">
          {principles.map((pr) => (
            <div class={`flex-none w-[78vw] max-w-[300px] p-6 rounded-2xl border bg-gray-900/20 relative ${pr.color}`} style="scroll-snap-align: center;">
              <span class="absolute right-6 top-6 text-sm font-mono opacity-20 font-bold">{pr.number}</span>
              <h3 class="text-sm font-semibold text-white mb-2">{pr.title}</h3>
              <p class="text-xs text-gray-400 leading-relaxed">{pr.description}</p>
            </div>
          ))}
        </div>
        <div class="flex justify-center gap-2 mt-0.5" id="principles-dots" role="tablist">
          {principles.map((_, idx) => (
            <button class="principles-dot h-1.5 rounded-full transition-all duration-300" data-index={idx} aria-label={`Slide ${idx + 1}`} aria-selected={idx === 0 ? "true" : "false"}></button>
          ))}
        </div>
      </div>

      <!-- Desktop: grid -->
      <div class="hidden sm:grid sm:grid-cols-2 gap-4">
        {principles.map((pr) => (
          <div class={`p-6 rounded-2xl border bg-gray-900/20 transition-all duration-300 group relative ${pr.color} ${pr.hoverColor}`}>
            <span class="absolute right-6 top-6 text-sm font-mono opacity-20 font-bold group-hover:opacity-40 transition-opacity">{pr.number}</span>
            <h3 class="text-sm font-semibold text-white mb-2">{pr.title}</h3>
            <p class="text-xs sm:text-sm text-gray-400 leading-relaxed">{pr.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ── SPESIALISASI TRACK ── -->
    <section class="border-t border-gray-800/60 pt-12 space-y-8">
      <div class="max-w-xl">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Bidang Keahlian</h2>
        <p class="text-sm text-gray-400">
          Anggota diarahkan untuk memfokuskan eksplorasi mereka pada salah satu dari beberapa jalur keahlian berikut:
        </p>
      </div>
      <div class="columns-2 sm:columns-3 gap-4">
        {tracks.map((t) => (
          <div class="break-inside-avoid block mb-4 p-5 rounded-2xl border border-gray-800/80 bg-gray-900/10 hover:bg-gray-900/30 hover:border-gray-700/60 transition-all duration-200">
            <span class="text-2xl block mb-2">{t.icon}</span>
            <h3 class="text-sm font-semibold text-white mb-1">{t.name}</h3>
            <p class="text-xs text-gray-400 leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center pt-2">
        <a href="/tracks" class="inline-flex items-center gap-1.5 text-xs font-semibold text-blue-400 hover:text-blue-300 transition-colors">
          Bandingkan semua jalur spesialisasi detail
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/></svg>
        </a>
      </div>
    </section>

    <!-- ── RESOURCES / DOCUMENTATION ── -->
    <section class="border-t border-gray-800/60 pt-12 space-y-8">
      <div class="max-w-xl">
        <h2 class="text-xl sm:text-2xl font-bold text-white mb-2">Dokumentasi & Panduan Resmi</h2>
        <p class="text-sm text-gray-400">
          Pelajari tata tertib, budaya, dan filosofi komunitas kami secara lengkap melalui dokumen resmi repositori.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 gap-4">
        <a href={`${config.deployment.repository}/blob/main/PHILOSOPHY.md`}
           target="_blank"
           class="group block p-5 rounded-2xl border border-gray-800/80 bg-gray-900/20 hover:border-blue-500/40 hover:bg-gray-900/40 transition-all duration-300">
          <h3 class="text-sm font-semibold text-white group-hover:text-blue-400 transition-colors flex items-center gap-1.5">
            📖 Filosofi Lab
            <span class="text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
          </h3>
          <p class="text-xs sm:text-sm text-gray-400 mt-2 leading-relaxed">Panduan lengkap mengenai visi jangka panjang, nilai intrinsik, dan kurikulum mandiri kami.</p>
        </a>

        <a href={`${config.deployment.repository}/blob/main/CONTRIBUTING.md`}
           target="_blank"
           class="group block p-5 rounded-2xl border border-gray-800/80 bg-gray-900/20 hover:border-indigo-500/40 hover:bg-gray-900/40 transition-all duration-300">
          <h3 class="text-sm font-semibold text-white group-hover:text-indigo-400 transition-colors flex items-center gap-1.5">
            🤝 Panduan Kontribusi
            <span class="text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
          </h3>
          <p class="text-xs sm:text-sm text-gray-400 mt-2 leading-relaxed">Tata cara bergabung, setup repository lokal, mengajukan Pull Request, dan etika berkontribusi.</p>
        </a>

        <a href={`${config.deployment.repository}/blob/main/CODE_OF_CONDUCT.md`}
           target="_blank"
           class="group block p-5 rounded-2xl border border-gray-800/80 bg-gray-900/20 hover:border-purple-500/40 hover:bg-gray-900/40 transition-all duration-300">
          <h3 class="text-sm font-semibold text-white group-hover:text-purple-400 transition-colors flex items-center gap-1.5">
            ⚖️ Kode Etik Anggota
            <span class="text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
          </h3>
          <p class="text-xs sm:text-sm text-gray-400 mt-2 leading-relaxed">Aturan berperilaku, berdiskusi, dan kolaborasi yang sehat demi kenyamanan seluruh anggota lab.</p>
        </a>

        <a href={config.socials.github}
           target="_blank"
           class="group block p-5 rounded-2xl border border-gray-800/80 bg-gray-900/20 hover:border-emerald-500/40 hover:bg-gray-900/40 transition-all duration-300">
          <h3 class="text-sm font-semibold text-white group-hover:text-emerald-400 transition-colors flex items-center gap-1.5">
            🌍 Repositori GitHub Utama
            <span class="text-xs opacity-0 group-hover:opacity-100 group-hover:translate-x-1 transition-all">→</span>
          </h3>
          <p class="text-xs sm:text-sm text-gray-400 mt-2 leading-relaxed">Lihat seluruh kode sumber aplikasi, modul pembelajaran, dan proyek hardware yang sedang kami kembangkan.</p>
        </a>
      </div>
    </section>

    <!-- ── CALL TO ACTION ── -->
    <footer class="pt-8 text-center max-w-xl mx-auto space-y-6">
      <div class="space-y-2">
        <h2 class="text-xl sm:text-2xl font-bold text-white">Siap Mulai Perjalanan Belajarmu?</h2>
        <p class="text-xs sm:text-sm text-gray-400 leading-relaxed">
          Tidak perlu menjadi ahli sejak awal. Yang kamu butuhkan hanyalah rasa ingin tahu dan komitmen untuk terus mencoba. Pilih track-mu sekarang.
        </p>
      </div>
      <a href="/tracks"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-xl font-semibold text-sm text-white bg-blue-600 hover:bg-blue-500 transition-colors duration-200 shadow-lg shadow-blue-600/10">
        Pilih Jalur Belajar
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
      </a>
    </footer>

  </div>
</Layout>

<style>
  /* hide scrollbars for native carousel */
  #principles-carousel::-webkit-scrollbar { display: none; }
  #principles-carousel { scrollbar-width: none; -ms-overflow-style: none; }
  .principles-dot[aria-selected="true"]  { width: 1.5rem; background-color: #3b82f6; }
  .principles-dot[aria-selected="false"] { width: 0.5rem; background-color: #374151; }
</style>

<script>
  // Principles Carousel dots controller
  const carousel = document.getElementById('principles-carousel');
  const dots = document.querySelectorAll('.principles-dot');

  if (carousel && dots.length) {
    const updateDots = () => {
      const card = carousel.querySelector('div');
      if (card) {
        const cardWidth = card.getBoundingClientRect().width + 12; // width + gap (12px)
        const active = Math.round(carousel.scrollLeft / cardWidth);
        dots.forEach((d, idx) => {
          d.setAttribute('aria-selected', idx === active ? 'true' : 'false');
        });
      }
    };

    carousel.addEventListener('scroll', updateDots, { passive: true });

    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const card = carousel.querySelector('div');
        if (card) {
          const cardWidth = card.getBoundingClientRect().width + 12;
          const idx = Number(d.getAttribute('data-index'));
          carousel.scrollTo({ left: cardWidth * idx, behavior: 'smooth' });
        }
      });
    });
  }
</script>
