---
import Layout from '../layouts/Layout.astro';

const projects = [
  { 
    name: "smauii-agent", 
    desc: "Autonomous AI agent untuk operasional sekolah via Telegram. Mengelola perpustakaan, elearning, dan monitoring server.", 
    lang: "TypeScript", 
    stars: 0, 
    url: "https://github.com/sandikodev/smauii-agent", 
    status: "active",
    tags: ["AI", "Automation", "Telegram Bot"]
  },
  { 
    name: "smauii-lab", 
    desc: "Website komunitas SMAUII Lab — ruang eksplorasi digital untuk siswa yang menekuni teknologi.", 
    lang: "Astro", 
    stars: 0, 
    url: "https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io", 
    status: "active",
    tags: ["Web", "Open Source", "Community"]
  },
];
---
<Layout title="Proyek">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Proyek Open Source</h1>
    <p class="text-gray-400 mb-4">Karya nyata dari komunitas SMA UII Lab</p>
    <p class="text-sm text-gray-500 mb-12">
      Semua proyek terbuka di GitHub. Kamu bisa belajar dari kode, kontribusi, atau fork untuk proyek sendiri.
    </p>

    <div class="grid md:grid-cols-2 gap-6">
      {projects.map(p => (
        <a href={p.url} target="_blank"
           class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-500 transition block group">
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-mono font-semibold text-blue-400 group-hover:text-blue-300 transition">{p.name}</h3>
            <span class={`text-xs px-2 py-0.5 rounded-full ${p.status === 'active' ? 'bg-green-500/10 text-green-400 border border-green-500/20' : 'bg-gray-800 text-gray-400'}`}>
              {p.status}
            </span>
          </div>
          <p class="text-sm text-gray-400 mb-4">{p.desc}</p>
          <div class="flex flex-wrap gap-2 mb-3">
            {p.tags.map(tag => (
              <span class="text-xs bg-gray-800 text-gray-400 px-2 py-0.5 rounded">{tag}</span>
            ))}
          </div>
          <div class="flex items-center gap-3 text-xs text-gray-500">
            <span class="flex items-center gap-1">
              <span class="w-2 h-2 rounded-full bg-blue-400 inline-block"></span>
              {p.lang}
            </span>
            <span>★ {p.stars}</span>
          </div>
        </a>
      ))}

      <!-- Placeholder untuk proyek berikutnya -->
      <div class="bg-gray-900/50 border border-dashed border-gray-700 rounded-xl p-5 flex flex-col items-center justify-center text-center min-h-[200px]">
        <div class="text-3xl mb-3">+</div>
        <p class="text-sm text-gray-400 mb-2">Proyek berikutnya dari komunitas</p>
        <p class="text-xs text-gray-500 mb-4">Robotika, AI, Data Science, atau lainnya?</p>
        <a href="https://github.com/SMA-UII-Yogyakarta" target="_blank"
           class="text-xs text-blue-400 hover:text-blue-300 transition">Mulai Kontribusi →</a>
      </div>
    </div>

    <!-- CTA Section -->
    <section class="mt-16 text-center border-t border-gray-800 pt-16">
      <h2 class="text-2xl font-bold mb-4">Punya Ide Proyek?</h2>
      <p class="text-gray-400 mb-8 max-w-2xl mx-auto">
        Usulkan proyek baru atau mulai proyek sendiri di track yang kamu minati. 
        Kami siap bantu dari ide sampai deployment!
      </p>
      <div class="flex gap-3 justify-center flex-wrap">
        <a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CONTRIBUTING.md" 
           target="_blank"
           class="bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-lg font-semibold transition">
          Panduan Kontribusi
        </a>
        <a href="/tracks" 
           class="border border-gray-700 hover:border-blue-500 px-6 py-2.5 rounded-lg font-semibold transition">
          Lihat Track
        </a>
      </div>
    </section>
  </div>
</Layout>
