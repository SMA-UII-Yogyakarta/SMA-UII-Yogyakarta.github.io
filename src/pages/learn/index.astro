---
import Layout from '@layouts/Layout.astro';
import { getCollection } from 'astro:content';

// Ambil semua _index.md track (tidak punya field 'module')
const allLessons = await getCollection('lessons');
const trackIndexes = allLessons.filter(l => l.id.endsWith('/README') && !l.data.module && l.data.track === undefined);

// Hitung jumlah lesson per track
const trackStats: Record<string, number> = {};
for (const l of allLessons) {
  if (!l.id.endsWith('/README') && l.data.track) {
    trackStats[l.data.track] = (trackStats[l.data.track] || 0) + 1;
  }
}
---

<Layout title="Belajar">
  <div class="max-w-5xl mx-auto px-4 py-16">
    <div class="text-center mb-12">
      <h1 class="text-3xl font-bold mb-3">Materi Pembelajaran</h1>
      <p class="text-gray-400">Konten open source yang bisa diakses, diaudit, dan dikembangkan bersama.</p>
      <a href="https://github.com/SMA-UII-Yogyakarta/smauii-dev-content" target="_blank"
        class="inline-flex items-center gap-2 mt-4 text-sm text-blue-400 hover:text-blue-300 transition">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        Kontribusi konten di GitHub
      </a>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {trackIndexes.map(track => {
        const slug = track.id.replace('/README', '');
        const count = trackStats[slug] || 0;
        return (
          <a href={`/learn/${slug}`}
            class="bg-gray-900 border border-gray-800 rounded-xl p-6 hover:border-blue-500/50 transition group">
            <div class="text-3xl mb-3">{track.data.icon || '📚'}</div>
            <h2 class="font-bold mb-1 group-hover:text-blue-400 transition">{track.data.title}</h2>
            <p class="text-sm text-gray-400 mb-3 line-clamp-2">{track.data.description}</p>
            <p class="text-xs text-gray-600">{count} materi</p>
          </a>
        );
      })}
    </div>
  </div>
</Layout>
