---
const { user } = Astro.locals;
if (!user) return Astro.redirect('/login');
if (user.status === 'pending') return Astro.redirect(`/check-status?nisn=${user.nisn}`);
if (user.status === 'inactive') return Astro.redirect('/login?error=inactive');
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #030712; color: #f9fafb; font-family: system-ui, sans-serif; }
    .splash {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 1.5rem;
    }
    .logo {
      font-size: 3rem;
      color: #60a5fa;
      animation: pulse 1.5s ease-in-out infinite;
    }
    .name {
      font-size: 1.5rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      opacity: 0;
      animation: fadeIn 0.6s ease 0.3s forwards;
    }
    .bar-wrap {
      width: 160px;
      height: 2px;
      background: #1f2937;
      border-radius: 9999px;
      overflow: hidden;
      opacity: 0;
      animation: fadeIn 0.3s ease 0.5s forwards;
    }
    .bar {
      height: 100%;
      background: #3b82f6;
      border-radius: 9999px;
      animation: load 1.2s ease 0.6s forwards;
      width: 0;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.6} }
    @keyframes fadeIn { to{opacity:1} }
    @keyframes load { to{width:100%} }
  </style>
</head>
<body>
  <div class="splash">
    <div class="logo">⬡</div>
    <div class="name">SMA UII Lab</div>
    <div class="bar-wrap"><div class="bar"></div></div>
  </div>
  <script>
    // Redirect after animation completes
    setTimeout(() => { window.location.replace('/app/overview'); }, 1800);
  </script>
</body>
</html>
