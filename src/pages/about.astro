---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Tentang">
  <div class="max-w-4xl mx-auto px-4 py-16">
    <h1 class="text-3xl font-bold mb-2">Tentang SMA UII Lab</h1>
    <p class="text-gray-400 mb-12">Ruang eksplorasi digital untuk siswa yang menekuni teknologi</p>

    <!-- Vision -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-4 text-blue-400">Visi</h2>
      <p class="text-gray-300 leading-relaxed">
        Membangun ekosistem developer dan open source contributor sejak SMA. 
        Kami percaya bahwa passion dan komitmen sejak dini adalah kunci untuk menghasilkan 
        developer dan researcher berkelas dunia.
      </p>
    </section>

    <!-- Mission -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-4 text-purple-400">Misi</h2>
      <div class="space-y-3">
        <div class="flex gap-3">
          <span class="text-blue-400 mt-1">→</span>
          <p class="text-gray-300">Mengantarkan siswa ke olimpiade nasional/internasional (OPSI, OSN, IOI, CTF)</p>
        </div>
        <div class="flex gap-3">
          <span class="text-blue-400 mt-1">→</span>
          <p class="text-gray-300">Mempersiapkan siswa masuk perguruan tinggi top dengan portofolio nyata</p>
        </div>
        <div class="flex gap-3">
          <span class="text-blue-400 mt-1">→</span>
          <p class="text-gray-300">Memfasilitasi kontribusi ke komunitas open source global</p>
        </div>
        <div class="flex gap-3">
          <span class="text-blue-400 mt-1">→</span>
          <p class="text-gray-300">Membangun skill yang relevan dengan industri teknologi</p>
        </div>
      </div>
    </section>

    <!-- Principles -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-6 text-green-400">Prinsip Inti</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
          <h3 class="font-bold mb-2">1. Open Source First</h3>
          <p class="text-sm text-gray-400">Semua proyek terbuka di GitHub. Transparansi, kolaborasi, kontribusi global.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
          <h3 class="font-bold mb-2">2. Learning by Building</h3>
          <p class="text-sm text-gray-400">Tidak ada teori tanpa praktik. Proyek nyata, kompetisi, kontribusi.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
          <h3 class="font-bold mb-2">3. Komunitas, Bukan Kelas</h3>
          <p class="text-sm text-gray-400">Peer learning, mentorship alumni, kolaborasi lintas track.</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-5">
          <h3 class="font-bold mb-2">4. Komitmen > Bakat</h3>
          <p class="text-sm text-gray-400">Konsisten, curious, collaborative, persistent — bukan jenius.</p>
        </div>
      </div>
    </section>

    <!-- Tracks -->
    <section class="mb-12">
      <h2 class="text-xl font-bold mb-4 text-orange-400">Track yang Tersedia</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">🤖</div>
          <p class="text-sm font-semibold">Robotika/IoT</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">🧠</div>
          <p class="text-sm font-semibold">AI</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">📊</div>
          <p class="text-sm font-semibold">Data Science</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">🌐</div>
          <p class="text-sm font-semibold">Jaringan</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">🔐</div>
          <p class="text-sm font-semibold">Keamanan Siber</p>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 text-center">
          <div class="text-2xl mb-1">💻</div>
          <p class="text-sm font-semibold">Software Eng</p>
        </div>
      </div>
      <div class="text-center mt-6">
        <a href="/tracks" class="text-blue-400 hover:text-blue-300 text-sm font-semibold">
          Lihat detail track →
        </a>
      </div>
    </section>

    <!-- Links -->
    <section class="border-t border-gray-800 pt-12">
      <h2 class="text-xl font-bold mb-6">Dokumentasi Lengkap</h2>
      <div class="grid md:grid-cols-2 gap-4">
        <a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/PHILOSOPHY.md" 
           target="_blank"
           class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-500 transition group">
          <h3 class="font-bold mb-2 group-hover:text-blue-400 transition">📖 Filosofi Foundation</h3>
          <p class="text-sm text-gray-400">Visi, prinsip, roadmap, dan kultur komunitas</p>
        </a>
        <a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CONTRIBUTING.md" 
           target="_blank"
           class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-500 transition group">
          <h3 class="font-bold mb-2 group-hover:text-blue-400 transition">🤝 Panduan Kontribusi</h3>
          <p class="text-sm text-gray-400">Cara bergabung dan berkontribusi ke proyek</p>
        </a>
        <a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CODE_OF_CONDUCT.md" 
           target="_blank"
           class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-500 transition group">
          <h3 class="font-bold mb-2 group-hover:text-blue-400 transition">⚖️ Code of Conduct</h3>
          <p class="text-sm text-gray-400">Standar perilaku dan etika komunitas</p>
        </a>
        <a href="https://github.com/SMA-UII-Yogyakarta" 
           target="_blank"
           class="bg-gray-900 border border-gray-800 rounded-lg p-5 hover:border-blue-500 transition group">
          <h3 class="font-bold mb-2 group-hover:text-blue-400 transition">🌍 GitHub Organization</h3>
          <p class="text-sm text-gray-400">Semua proyek open source kami</p>
        </a>
      </div>
    </section>

    <!-- CTA -->
    <section class="mt-16 text-center">
      <h2 class="text-2xl font-bold mb-4">Tertarik Bergabung?</h2>
      <p class="text-gray-400 mb-8">
        Mulai dari proyek kecil, konsisten berkontribusi, dan berkembang bersama komunitas.
      </p>
      <a href="/tracks" 
         class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-6 py-2.5 rounded-lg font-semibold transition">
        Mulai Eksplorasi →
      </a>
    </section>
  </div>
</Layout>
