---
import { db } from '@db';
import { users } from '@db/schema';
import { eq } from 'drizzle-orm';

// Redirect jika sudah login
if (Astro.locals.user) {
  return Astro.redirect('/app');
}

const nisn = Astro.url.searchParams.get('nisn') || '';

// Validasi NISN di server
if (!nisn) {
  return Astro.redirect('/register');
}

const user = await db.query.users.findFirst({
  where: eq(users.nisn, nisn),
  columns: { nisn: true, name: true, status: true },
});

// NISN tidak ada → redirect register
if (!user) {
  return Astro.redirect('/register');
}

// Sudah bukan pending → redirect check-status
if (user.status !== 'pending') {
  return Astro.redirect(`/check-status?nisn=${encodeURIComponent(nisn)}`);
}
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Pendaftaran Berhasil — SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
  <style>
    @import "tailwindcss";
    body {
      margin: 0;
      overflow: hidden;
      background: #030712;
    }
    @keyframes bounce {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-20px); }
    }
    .animate-bounce {
      animation: bounce 1s infinite;
    }
  </style>
</head>
<body>
  <div class="fixed inset-0 bg-gray-950 overflow-hidden">
    <canvas id="confetti-canvas" class="w-full h-full"></canvas>
  </div>

  <div class="relative z-10 h-screen flex items-center justify-center px-4">
    <div class="max-w-2xl mx-auto text-center">
      <div class="text-8xl mb-8 animate-bounce">🎉</div>
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-white">Pendaftaran Berhasil!</h1>
      
      <div id="greeting-section">
        <div class="inline-block bg-gray-900 border border-gray-700 rounded-lg px-4 py-3 mb-4 text-left" style="min-width: 200px;">
          <div class="flex items-center gap-2 mb-2">
            <span class="w-3 h-3 rounded-full bg-red-500"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-500"></span>
            <span class="w-3 h-3 rounded-full bg-green-500"></span>
          </div>
          <p class="text-gray-400 text-sm mb-1">$ whoami</p>
          <p class="text-lg text-blue-400 font-mono">{user.name}</p>
        </div>
        <p class="text-xl text-gray-300 mb-6">
          Pendaftaranmu sedang diproses. Tunggu persetujuan dari maintainer.
        </p>
      </div>

      <a 
        href={`/check-status?nisn=${encodeURIComponent(nisn)}`}
        class="inline-block bg-blue-600 hover:bg-blue-500 text-white px-8 py-3 rounded-lg font-semibold transition text-lg"
      >
        Cek Status Pendaftaran →
      </a>
    </div>
  </div>

  <script>
    const canvas = document.getElementById('confetti-canvas') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d');
    
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;

    const particles: Array<{
      x: number;
      y: number;
      vx: number;
      vy: number;
      color: string;
      size: number;
      rotation: number;
      rotationSpeed: number;
    }> = [];

    const colors = ['#FF6B6B', '#4ECDC4', '#45B7D1', '#96CEB4', '#FFEAA7', '#DDA0DD', '#98D8C8'];

    for (let i = 0; i < 150; i++) {
      particles.push({
        x: Math.random() * canvas.width,
        y: -20 - Math.random() * 100,
        vx: (Math.random() - 0.5) * 4,
        vy: Math.random() * 3 + 2,
        color: colors[Math.floor(Math.random() * colors.length)],
        size: Math.random() * 8 + 4,
        rotation: Math.random() * 360,
        rotationSpeed: (Math.random() - 0.5) * 10,
      });
    }

    function animate() {
      ctx!.clearRect(0, 0, canvas.width, canvas.height);
      
      let stillFalling = false;
      
      particles.forEach((p) => {
        p.x += p.vx;
        p.y += p.vy;
        p.vy += 0.1;
        p.rotation += p.rotationSpeed;

        if (p.y < canvas.height + 50) {
          stillFalling = true;
        }

        ctx!.save();
        ctx!.translate(p.x, p.y);
        ctx!.rotate((p.rotation * Math.PI) / 180);
        ctx!.fillStyle = p.color;
        ctx!.fillRect(-p.size / 2, -p.size / 2, p.size, p.size * 0.6);
        ctx!.restore();
      });

      if (stillFalling) {
        requestAnimationFrame(animate);
      }
    }

    animate();

    window.addEventListener('resize', () => {
      canvas.width = window.innerWidth;
      canvas.height = window.innerHeight;
    });
  </script>
</body>
</html>