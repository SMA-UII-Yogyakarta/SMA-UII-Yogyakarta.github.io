---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { db } from '@db';
import { memberTracks, memberCards } from '@db/schema';
import { eq } from 'drizzle-orm';
import { requireMember } from '@lib/guards';
import { fmtDate } from '@lib/format';
import { STATUS_COLORS } from '@lib/constants';

const redirect = requireMember(Astro); if (redirect) return redirect;
const { user } = Astro.locals;

const [tracks, card] = await Promise.all([
  db.select({ track: memberTracks.track }).from(memberTracks).where(eq(memberTracks.userId, user!.id)),
  db.query.memberCards.findFirst({ where: eq(memberCards.userId, user!.id) }),
]);
---

<DashboardLayout title="Profile">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Avatar + status -->
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 flex flex-col items-center text-center self-start">
      <div class="w-20 h-20 rounded-full bg-blue-600 flex items-center justify-center text-white text-3xl font-bold mb-4">
        {user!.name.charAt(0).toUpperCase()}
      </div>
      <h2 class="text-xl font-bold mb-1">{user.name}</h2>
      <p class="text-sm text-gray-400 mb-3">{user.email}</p>
      <span class={`px-3 py-1 rounded-full text-xs font-medium ${STATUS_COLORS[user!.status] || 'text-gray-400 bg-gray-800'}`}>
        {user!.status.toUpperCase()}
      </span>
      {user!.githubUsername && (
        <a href={`https://github.com/${user!.githubUsername}`} target="_blank"
          class="mt-3 text-sm text-gray-400 hover:text-white flex items-center gap-1.5 transition">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
          @{user!.githubUsername}
        </a>
      )}
    </div>

    <!-- Detail info -->
    <div class="lg:col-span-2 space-y-4">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h3 class="font-semibold mb-4 text-sm text-gray-400 uppercase tracking-wider">Informasi Akademik</h3>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <p class="text-xs text-gray-500 mb-1">NISN</p>
            <p class="font-mono font-medium">{user.nisn}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1">Kelas</p>
            <p class="font-medium">{user.class}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1">Role</p>
            <p class="font-medium capitalize">{user.role}</p>
          </div>
          <div>
            <p class="text-xs text-gray-500 mb-1">Bergabung</p>
            <p class="font-medium">{fmtDate(user!.joinedAt ?? null)}</p>
          </div>
        </div>
      </div>

      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h3 class="font-semibold mb-3 text-sm text-gray-400 uppercase tracking-wider">Track Minat</h3>
        {tracks.length > 0 ? (
          <div class="flex flex-wrap gap-2">
            {tracks.map(t => (
              <span class="px-3 py-1 bg-blue-500/20 text-blue-400 rounded-full text-sm">{t.track}</span>
            ))}
          </div>
        ) : (
          <p class="text-sm text-gray-500">Belum ada track</p>
        )}
      </div>

      {card && (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 flex items-center justify-between">
          <div>
            <h3 class="font-semibold mb-1">Kartu Anggota</h3>
            <p class="font-mono text-sm text-gray-400">{card.cardNumber}</p>
          </div>
          <a href="/app/card" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">
            Lihat Kartu →
          </a>
        </div>
      )}
    </div>
  </div>
</DashboardLayout>
