---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import Modal from '@components/app/Modal.astro';
import SkeletonList from '@components/app/SkeletonList.astro';
import { requireMaintainer } from '@lib/guards';
const redirect = requireMaintainer(Astro); if (redirect) return redirect;

---

<DashboardLayout title="Announcements">
  <PageHeader subtitle="Kirim pengumuman ke seluruh anggota aktif" actionLabel="Buat Pengumuman" />

  <div id="announcements-list">
    <SkeletonList count={4} />
  </div>

  <!-- Modal Buat/Edit Pengumuman -->
  <Modal id="add-modal" title="Buat Pengumuman">
    <form id="announcement-form" class="space-y-3">
      <input type="hidden" name="id" value="">
      <div>
        <label class="block text-xs text-gray-400 mb-1">Judul *</label>
        <input type="text" name="title" required class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500 text-gray-100">
      </div>
      <div>
        <label class="block text-xs text-gray-400 mb-1">Isi *</label>
        <textarea name="content" rows="5" required class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500 text-gray-100"></textarea>
      </div>
      <div class="flex gap-3 pt-2">
        <button type="submit" id="submit-btn" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-2 rounded-lg text-sm transition">Publish</button>
        <button type="button" id="close-modal" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg text-sm hover:bg-gray-700 transition">Batal</button>
      </div>
    </form>
  </Modal>

  <script>
    function esc(str: string): string {
      if (!str) return '';
      return String(str).replace(/[&<>"']/g, (c: string) => (({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#x27;'} as Record<string,string>)[c] ?? c));
    }

    function fmtDate(ts: number): string {
      return new Date(ts).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
    }

    let currentPage = 1;
    const PAGE_LIMIT = 10;

    async function load() {
      const params = new URLSearchParams({ page: String(currentPage), limit: String(PAGE_LIMIT) });
      const res = await fetch(`/api/announcements?${params}`);
      const json = await res.json();
      const list = json.data?.announcements || json.data || [];
      const total: number = json.data?.total || 0;
      const el = document.getElementById('announcements-list') as HTMLElement | null;
      if (!el) return;

      if (!list.length) {
        el.innerHTML = '<div class="text-center py-10"><p class="text-gray-500 text-sm">Belum ada pengumuman</p></div>';
        renderPagination(0, currentPage, PAGE_LIMIT);
        return;
      }

      el.innerHTML = list.map((a: any) => `
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-gray-700 transition">
          <div class="flex justify-between items-start mb-2 gap-3">
            <h3 class="font-semibold">${esc(a.title)}</h3>
            <div class="flex items-center gap-2 flex-shrink-0">
              <span class="text-xs text-gray-500">${fmtDate(a.createdAt)}</span>
              <button onclick="window.editAnnouncement('${esc(a.id)}', '${esc(a.title)}', ${JSON.stringify(a.content)})"
                class="text-gray-500 hover:text-blue-400 transition p-1" title="Edit">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              </button>
              <button onclick="window.deleteAnnouncement('${esc(a.id)}', '${esc(a.title)}')"
                class="text-gray-500 hover:text-red-400 transition p-1" title="Hapus">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              </button>
            </div>
          </div>
          <p class="text-sm text-gray-300 whitespace-pre-wrap">${esc(a.content)}</p>
          <p class="text-xs text-gray-500 mt-2">oleh ${esc(a.creatorName || 'Admin')}</p>
        </div>
      `).join('');
      renderPagination(total, currentPage, PAGE_LIMIT);
    }

    function renderPagination(total: number, page: number, limit: number) {
      let container = document.getElementById('ann-pagination');
      if (!container) {
        container = document.createElement('div');
        container.id = 'ann-pagination';
        document.getElementById('announcements-list')?.after(container);
      }
      const totalPages = Math.ceil(total / limit);
      if (total === 0 || totalPages <= 1) { container.innerHTML = ''; return; }
      const start = (page - 1) * limit + 1;
      const end = Math.min(page * limit, total);
      container.className = 'flex items-center justify-between mt-6 pt-4 border-t border-gray-800';
      container.innerHTML = `
        <p class="text-xs text-gray-500">Menampilkan ${start}–${end} dari ${total} pengumuman</p>
        <div class="flex gap-2">
          <button onclick="window.annPage(${page - 1})" ${page <= 1 ? 'disabled' : ''}
            class="px-3 py-1.5 rounded-lg text-sm ${page <= 1 ? 'bg-gray-800 text-gray-600 cursor-not-allowed' : 'bg-gray-800 text-gray-300 hover:bg-gray-700 transition'}">← Prev</button>
          <span class="px-3 py-1.5 text-sm text-gray-400">${page} / ${totalPages}</span>
          <button onclick="window.annPage(${page + 1})" ${page >= totalPages ? 'disabled' : ''}
            class="px-3 py-1.5 rounded-lg text-sm ${page >= totalPages ? 'bg-gray-800 text-gray-600 cursor-not-allowed' : 'bg-gray-800 text-gray-300 hover:bg-gray-700 transition'}">Next →</button>
        </div>
      `;
    }

    window.annPage = (page: number) => { currentPage = page; load(); window.scrollTo(0, 0); };

    const modal = document.getElementById('add-modal');
    const form = document.getElementById('announcement-form') as HTMLFormElement | null;
    const submitBtn = document.getElementById('submit-btn');
    const modalTitle = modal?.querySelector('h2');

    function openCreate() {
      form?.reset();
      const idField = form?.querySelector('[name="id"]') as HTMLInputElement | null;
      if (idField) idField.value = '';
      if (modalTitle) modalTitle.textContent = 'Buat Pengumuman';
      if (submitBtn) submitBtn.textContent = 'Publish';
      modal?.classList.remove('hidden');
    }

    window.editAnnouncement = (id: string, title: string, content: string) => {
      const idField = form?.querySelector('[name="id"]') as HTMLInputElement | null;
      const titleField = form?.querySelector('[name="title"]') as HTMLInputElement | null;
      const contentField = form?.querySelector('[name="content"]') as HTMLTextAreaElement | null;
      if (idField) idField.value = id;
      if (titleField) titleField.value = title;
      if (contentField) contentField.value = content;
      if (modalTitle) modalTitle.textContent = 'Edit Pengumuman';
      if (submitBtn) submitBtn.textContent = 'Simpan';
      modal?.classList.remove('hidden');
    };

    window.deleteAnnouncement = async (id: string, title: string) => {
      if (!confirm(`Hapus pengumuman "${title}"?`)) return;
      const res = await fetch(`/api/announcements/${id}`, { method: 'DELETE' });
      if (res.ok) load();
      else alert('Gagal menghapus pengumuman');
    };

    document.getElementById('open-modal')?.addEventListener('click', openCreate);
    document.getElementById('close-modal')?.addEventListener('click', () => modal?.classList.add('hidden'));

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form!);
      const id = fd.get('id') as string;
      const isEdit = !!id;

      const res = await fetch(isEdit ? `/api/announcements/${id}` : '/api/announcements', {
        method: isEdit ? 'PATCH' : 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ title: fd.get('title'), content: fd.get('content') }),
      });
      if (res.ok) {
        modal?.classList.add('hidden');
        form!.reset();
        load();
      } else {
        alert(isEdit ? 'Gagal mengupdate pengumuman' : 'Gagal membuat pengumuman');
      }
    });
  </script>
</DashboardLayout>
