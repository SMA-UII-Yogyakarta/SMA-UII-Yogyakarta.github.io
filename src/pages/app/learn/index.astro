---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import { requireAuth } from '@lib/guards';
import { getCollection } from 'astro:content';
import { db } from '@db';
import { learningProgress, readingSessions } from '@db/schema';
import { eq, gte } from 'drizzle-orm';

const redirect = requireAuth(Astro);
if (redirect) return redirect;

const { user } = Astro.locals;
const all = await getCollection('lessons');

const trackEntries = all
  .filter(l => l.id.endsWith('/README') && !l.data.module && l.data.track === undefined)
  .sort((a, b) => (a.data.order ?? 0) - (b.data.order ?? 0));

const progress = await db.select().from(learningProgress).where(eq(learningProgress.userId, user!.id));
const completedSlugs = new Set(progress.map(p => p.lessonSlug));

const trackStats = trackEntries.map(track => {
  const trackSlug = track.id.replace('/README', '');
  const lessons = all.filter(l => l.data.track === trackSlug && !l.id.endsWith('/README'));
  const completed = lessons.filter(l => completedSlugs.has(l.id)).length;
  return { track, trackSlug, total: lessons.length, completed };
});

// Contribution graph
const oneYearAgo = Date.now() - 365 * 24 * 60 * 60 * 1000;
const allSessions = await db.select().from(readingSessions)
  .where(gte(readingSessions.startedAt, oneYearAgo));

const minutesPerDay: Record<string, number> = {};
for (const s of allSessions.filter(s => s.userId === user!.id)) {
  const day = new Date(s.startedAt).toISOString().slice(0, 10);
  minutesPerDay[day] = (minutesPerDay[day] ?? 0) + Math.round((s.duration ?? 0) / 60);
}
for (const p of progress) {
  const day = new Date(p.completedAt).toISOString().slice(0, 10);
  if (!minutesPerDay[day]) minutesPerDay[day] = 1;
}

const today = new Date();
today.setHours(0, 0, 0, 0);
const startDay = new Date(today);
startDay.setDate(startDay.getDate() - 364);
startDay.setDate(startDay.getDate() - startDay.getDay());

const weeks: { date: string; mins: number }[][] = [];
const cur = new Date(startDay);
const endMs = today.getTime() + 86400000;
while (cur.getTime() < endMs) {
  const week: { date: string; mins: number }[] = [];
  Array.from({ length: 7 }).forEach(() => {
    const dateStr = cur.toISOString().slice(0, 10);
    week.push({ date: dateStr, mins: minutesPerDay[dateStr] ?? 0 });
    cur.setDate(cur.getDate() + 1);
  });
  weeks.push(week);
}

const totalActiveDays = Object.values(minutesPerDay).filter(m => m > 0).length;
const totalMinutes = Object.values(minutesPerDay).reduce((a, b) => a + b, 0);

const activeDaySet = new Set(Object.keys(minutesPerDay).filter(d => minutesPerDay[d] > 0));
const streak = Array.from({ length: 366 }, (_, i) =>
  new Date(today.getTime() - i * 86400000).toISOString().slice(0, 10)
).reduce((acc, key, i) => {
  if (acc.done) return acc;
  if (activeDaySet.has(key)) return { count: acc.count + 1, done: false };
  if (i > 0) return { count: acc.count, done: true };
  return acc;
}, { count: 0, done: false }).count;

function intensityClass(mins: number): string {
  if (mins === 0) return 'bg-gray-800';
  if (mins < 5) return 'bg-blue-900';
  if (mins < 15) return 'bg-blue-700';
  if (mins < 30) return 'bg-blue-500';
  return 'bg-blue-400';
}

const monthLabels: { label: string; col: number }[] = [];
let lastMonth = -1;
weeks.forEach((week, i) => {
  const month = new Date(week[0].date).getMonth();
  if (month !== lastMonth) {
    monthLabels.push({
      label: new Date(week[0].date).toLocaleDateString('id-ID', { month: 'short' }),
      col: i,
    });
    lastMonth = month;
  }
});
---

<DashboardLayout title="Belajar">
  <PageHeader subtitle="Pilih track yang ingin kamu pelajari" />

  <div class="flex gap-6 items-start">
    <!-- Track cards -->
    <div class="flex-1 min-w-0">
      <div class="grid gap-4" style="grid-template-columns: repeat(auto-fill, minmax(240px, 1fr))">
        {trackStats.map(({ track, trackSlug, total, completed }) => {
          const pct = total > 0 ? Math.round((completed / total) * 100) : 0;
          return (
            <a href={`/app/learn/${trackSlug}`}
              class="bg-gray-900 border border-gray-800 rounded-xl p-5 hover:border-blue-500/40 transition group block">
              <div class="flex items-start gap-3 mb-4">
                <span class="text-3xl flex-shrink-0">{track.data.icon}</span>
                <div class="flex-1 min-w-0">
                  <h2 class="font-semibold group-hover:text-blue-400 transition">{track.data.title}</h2>
                  <p class="text-xs text-gray-500 mt-1 line-clamp-2 leading-relaxed">{track.data.description}</p>
                </div>
              </div>
              <div class="space-y-1.5">
                <div class="flex justify-between text-xs">
                  <span class="text-gray-500">{completed}/{total} selesai</span>
                  <span class={pct === 100 ? 'text-green-400' : pct > 0 ? 'text-blue-400' : 'text-gray-600'}>{pct}%</span>
                </div>
                <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden">
                  <div
                    class={`h-full rounded-full transition-all ${pct === 100 ? 'bg-green-500' : 'bg-blue-500'}`}
                    style={`width: ${pct}%`}
                  ></div>
                </div>
              </div>
            </a>
          );
        })}
      </div>
    </div>

    <!-- Contribution graph (xl+) -->
    <div class="hidden xl:block w-72 flex-shrink-0">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 sticky top-0" style="max-height: calc(100vh - 56px - 2rem); overflow-y: auto">
        <div class="mb-4">
          <h2 class="font-semibold">Aktivitas Belajar</h2>
          <p class="text-sm text-gray-500 mt-0.5">{totalActiveDays} hari aktif · {Math.round(totalMinutes / 60)} jam</p>
          {streak > 0 && <p class="text-sm text-orange-400 mt-1">🔥 {streak} hari streak</p>}
        </div>

        <div class="overflow-x-auto">
          <div style={`width: ${weeks.length * 13}px`}>
            <div class="relative h-4 mb-1">
              {monthLabels.map(({ label, col }) => (
                <span class="absolute text-xs text-gray-500" style={`left: ${col * 13}px`}>{label}</span>
              ))}
            </div>
            <div class="flex gap-0.5">
              {weeks.map(week => (
                <div class="flex flex-col gap-0.5">
                  {week.map(day => (
                    <div class={`w-3 h-3 rounded-sm ${intensityClass(day.mins)}`} title={`${day.date}: ${day.mins}m`}></div>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>

        <div class="flex items-center gap-1.5 text-xs text-gray-500 mt-3">
          <span>Kurang</span>
          {['bg-gray-800','bg-blue-900','bg-blue-700','bg-blue-500','bg-blue-400'].map(c => (
            <div class={`w-3 h-3 rounded-sm ${c}`}></div>
          ))}
          <span>Banyak</span>
        </div>
      </div>
    </div>
  </div>
</DashboardLayout>
