---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import { db } from '@db';
import { memberCards } from '@db/schema';
import { eq } from 'drizzle-orm';
import { requireMember } from '@lib/guards';
import { fmtDate } from '@lib/format';

const redirect = requireMember(Astro); if (redirect) return redirect;
const { user } = Astro.locals;
const card = await db.query.memberCards.findFirst({ where: eq(memberCards.userId, user!.id) });
---

<DashboardLayout title="Member Card">
  {card && (
    <div slot="topbar-actions">
      <div class="flex bg-gray-800 rounded-lg p-0.5">
        <button id="tab-card" class="px-3 py-1 rounded-md text-xs font-medium transition bg-gray-700 text-white">Kartu</button>
        <button id="tab-qr" class="px-3 py-1 rounded-md text-xs font-medium transition text-gray-400 hover:text-white">QR Code</button>
      </div>
    </div>
  )}

  <PageHeader subtitle="Kartu identitas digital anggota komunitas" />
  {!card ? (
    <div class="text-center py-16">
      <div class="text-6xl mb-4">🎫</div>
      <h2 class="text-xl font-bold mb-2">Kartu Belum Tersedia</h2>
      <p class="text-gray-400 text-sm">Kartu anggota akan dibuat setelah akun disetujui.</p>
    </div>
  ) : (
    <div class="flex justify-center">
      <div class="w-full max-w-sm space-y-4">
        <!-- Card visual -->
        <div id="panel-card" class="bg-linear-to-br from-blue-900 to-indigo-950 rounded-2xl p-6 text-white shadow-2xl relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 bg-white/5 rounded-full"></div>
          <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-white/5 rounded-full"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
              <div>
                <p class="text-xs opacity-60">SMA UII Lab</p>
                <p class="font-bold">Member Card</p>
              </div>
              <span class="text-2xl">⬡</span>
            </div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-full bg-blue-500/50 flex items-center justify-center text-2xl font-bold flex-shrink-0">
                {user!.name.charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0">
                <p class="font-bold text-lg leading-tight truncate">{user!.name}</p>
                <p class="text-xs opacity-60">{user!.class}</p>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div>
                <p class="text-xs opacity-60">Card Number</p>
                <p class="font-mono text-sm font-bold truncate">{card.cardNumber}</p>
              </div>
              <div>
                <p class="text-xs opacity-60">NISN</p>
                <p class="font-mono text-sm truncate">{user!.nisn}</p>
              </div>
            </div>
            <div class="flex justify-between items-end">
              <div>
                <p class="text-xs opacity-60">Issued</p>
                <p class="text-sm">{fmtDate(card.issuedAt)}</p>
              </div>
              <span class="px-2 py-0.5 bg-green-500/20 text-green-400 rounded text-xs">ACTIVE</span>
            </div>
          </div>
        </div>

        <!-- QR Code -->
        <div id="panel-qr" class="hidden bg-gray-900 border border-gray-800 rounded-xl p-6 text-center">
          <p class="text-sm font-medium mb-4">QR Code Verifikasi</p>
          <div class="inline-block p-3 bg-white rounded-lg">
            <img src={card.qrCode} alt="QR Code" class="w-48 h-48">
          </div>
          <p class="text-xs text-gray-500 mt-3">Tunjukkan kode ini untuk verifikasi keanggotaan</p>
        </div>
      </div>
    </div>

    <script>
      const tabCard = document.getElementById('tab-card')!;
      const tabQr = document.getElementById('tab-qr')!;
      const panelCard = document.getElementById('panel-card')!;
      const panelQr = document.getElementById('panel-qr')!;

      const active = 'px-3 py-1 rounded-md text-xs font-medium transition bg-gray-700 text-white';
      const inactive = 'px-3 py-1 rounded-md text-xs font-medium transition text-gray-400 hover:text-white';

      tabCard.addEventListener('click', () => {
        panelCard.classList.remove('hidden');
        panelQr.classList.add('hidden');
        tabCard.className = active;
        tabQr.className = inactive;
      });

      tabQr.addEventListener('click', () => {
        panelQr.classList.remove('hidden');
        panelCard.classList.add('hidden');
        tabQr.className = active;
        tabCard.className = inactive;
      });
    </script>
  )}
</DashboardLayout>
