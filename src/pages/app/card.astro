---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import { db } from '@db';
import { memberCards } from '@db/schema';
import { eq } from 'drizzle-orm';
import { requireMember } from '@lib/guards';
import { fmtDate } from '@lib/format';

const redirect = requireMember(Astro); if (redirect) return redirect;
const { user } = Astro.locals;
const card = await db.query.memberCards.findFirst({ where: eq(memberCards.userId, user!.id) });
---

<DashboardLayout title="Member Card">
  {card && (
    <div slot="topbar-actions">
      <div class="flex items-center gap-2">
        <div class="flex bg-gray-800 rounded-lg p-0.5">
          <button id="tab-card" class="px-3 py-1 rounded-md text-xs font-medium transition bg-gray-700 text-white">Kartu</button>
          <button id="tab-qr" class="px-3 py-1 rounded-md text-xs font-medium transition text-gray-400 hover:text-white">QR Code</button>
        </div>
        <button id="btn-print" class="p-2 rounded-lg bg-gray-800 text-gray-300 hover:text-white hover:bg-gray-700 transition print:hidden" title="Print">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
          </svg>
        </button>
        <button id="btn-download" class="p-2 rounded-lg bg-gray-800 text-gray-300 hover:text-white hover:bg-gray-700 transition print:hidden" title="Download as PDF">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
          </svg>
        </button>
      </div>
    </div>
  )}

  <PageHeader subtitle="Kartu identitas digital anggota komunitas" />
  {!card ? (
    <div class="text-center py-16">
      <div class="text-6xl mb-4">🎫</div>
      <h2 class="text-xl font-bold mb-2">Kartu Belum Tersedia</h2>
      <p class="text-gray-400 text-sm">Kartu anggota akan dibuat setelah akun disetujui.</p>
    </div>
  ) : (
    <div class="flex justify-center">
      <div class="w-full max-w-sm space-y-4">
        <!-- Card visual -->
        <div id="panel-card" class="bg-linear-to-br from-blue-900 to-indigo-950 rounded-2xl p-6 text-white shadow-2xl relative overflow-hidden">
          <div class="absolute -top-8 -right-8 w-32 h-32 bg-white/5 rounded-full"></div>
          <div class="absolute -bottom-8 -left-8 w-24 h-24 bg-white/5 rounded-full"></div>
          <div class="relative z-10">
            <div class="flex items-center justify-between mb-8">
              <div>
                <p class="text-xs opacity-60">SMA UII Lab</p>
                <p class="font-bold">Member Card</p>
              </div>
              <span class="text-2xl">⬡</span>
            </div>
            <div class="flex items-center gap-3 mb-6">
              <div class="w-14 h-14 rounded-full bg-blue-500/50 flex items-center justify-center text-2xl font-bold flex-shrink-0">
                {user!.name.charAt(0).toUpperCase()}
              </div>
              <div class="min-w-0">
                <p class="font-bold text-lg leading-tight truncate">{user!.name}</p>
                <p class="text-xs opacity-60">{user!.class}</p>
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3 mb-4">
              <div>
                <p class="text-xs opacity-60">Card Number</p>
                <p class="font-mono text-sm font-bold truncate">{card.cardNumber}</p>
              </div>
              <div>
                <p class="text-xs opacity-60">NISN</p>
                <p class="font-mono text-sm truncate">{user!.nisn}</p>
              </div>
            </div>
            <div class="flex justify-between items-end">
              <div>
                <p class="text-xs opacity-60">Issued</p>
                <p class="text-sm">{fmtDate(card.issuedAt)}</p>
              </div>
              <span class="px-2 py-0.5 bg-green-500/20 text-green-400 rounded text-xs">ACTIVE</span>
            </div>
          </div>
        </div>

        <!-- QR Code -->
        <div id="panel-qr" class="hidden bg-gray-900 border border-gray-800 rounded-xl p-6 text-center">
          <p class="text-sm font-medium mb-4">QR Code Verifikasi</p>
          <div class="inline-block p-3 bg-white rounded-lg">
            <img src={card.qrCode} alt="QR Code" class="w-48 h-48">
          </div>
          <p class="text-xs text-gray-500 mt-3">Tunjukkan kode ini untuk verifikasi keanggotaan</p>
        </div>
      </div>
    </div>

    <style>
      @media print {
        /* Hide sidebar, topbar, bottom nav */
        #sidebar,
        #topbar,
        #bottom-nav {
          display: none !important;
        }

        /* Reset main content margins */
        #main-content {
          margin-left: 0 !important;
        }

        /* Hide page header and action buttons */
        .page-header,
        .print\:hidden {
          display: none !important;
        }

        /* Show only the card container */
        #dashboard-content {
          padding: 0 !important;
          overflow: visible !important;
        }

        /* Center the card and ensure it prints nicely */
        .flex.justify-center {
          display: flex !important;
          justify-content: center !important;
          align-items: center !important;
          min-height: 100vh !important;
          padding: 20px !important;
        }

        /* Ensure card prints with proper sizing */
        #panel-card,
        #panel-qr {
          width: 100% !important;
          max-width: 400px !important;
          page-break-inside: avoid !important;
          box-shadow: none !important;
          border: 2px solid #1e3a8a !important;
        }

        /* Ensure QR panel is visible if active */
        #panel-qr:not(.hidden) {
          display: block !important;
        }

        /* Background colors for print */
        #panel-card {
          background: linear-gradient(135deg, #1e3a8a 0%, #1e1b4b 100%) !important;
          -webkit-print-color-adjust: exact !important;
          print-color-adjust: exact !important;
        }
      }
    </style>

    <script>
      const tabCard = document.getElementById('tab-card')!;
      const tabQr = document.getElementById('tab-qr')!;
      const panelCard = document.getElementById('panel-card')!;
      const panelQr = document.getElementById('panel-qr')!;
      const btnPrint = document.getElementById('btn-print')!;
      const btnDownload = document.getElementById('btn-download')!;

      const active = 'px-3 py-1 rounded-md text-xs font-medium transition bg-gray-700 text-white';
      const inactive = 'px-3 py-1 rounded-md text-xs font-medium transition text-gray-400 hover:text-white';

      tabCard.addEventListener('click', () => {
        panelCard.classList.remove('hidden');
        panelQr.classList.add('hidden');
        tabCard.className = active;
        tabQr.className = inactive;
      });

      tabQr.addEventListener('click', () => {
        panelQr.classList.remove('hidden');
        panelCard.classList.add('hidden');
        tabQr.className = active;
        tabCard.className = inactive;
      });

      // Print functionality
      btnPrint.addEventListener('click', () => {
        window.print();
      });

      // Download functionality - triggers print dialog with instructions to save as PDF
      btnDownload.addEventListener('click', () => {
        // Show a brief instruction before printing
        const instruction = document.createElement('div');
        instruction.id = 'pdf-instruction';
        instruction.className = 'fixed inset-0 bg-black/80 flex items-center justify-center z-[100] print:hidden';
        instruction.innerHTML = `
          <div class="bg-gray-900 border border-gray-700 rounded-xl p-6 max-w-sm text-center">
            <div class="text-4xl mb-3">📄</div>
            <h3 class="text-lg font-bold mb-2">Simpan sebagai PDF</h3>
            <p class="text-gray-400 text-sm mb-4">Pilih "Save as PDF" atau "Simpan sebagai PDF" pada dialog print yang akan muncul.</p>
            <button id="start-print" class="px-4 py-2 bg-blue-600 hover:bg-blue-500 rounded-lg text-sm font-medium transition">Lanjutkan</button>
          </div>
        `;
        document.body.appendChild(instruction);

        document.getElementById('start-print')!.addEventListener('click', () => {
          instruction.remove();
          window.print();
        });
      });
    </script>
  )}
</DashboardLayout>
