---
import DashboardLayout from '@layouts/DashboardLayout.astro';
const { user } = Astro.locals;
if (!user) return Astro.redirect('/login');
if (user.status === 'pending') return Astro.redirect(`/check-status?nisn=${user.nisn}`);
if (user.status === 'inactive') return Astro.redirect('/login?error=inactive');
const userData = { id: user.id, name: user.name, role: user.role, status: user.status };
---

<DashboardLayout title="Projects">
  <div id="projects-content">
    <div class="text-center py-12">
      <div class="text-4xl mb-4">⏳</div>
      <p class="text-gray-400">Loading...</p>
    </div>
  </div>

  <!-- Add Project Modal -->
  <div id="add-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 w-full max-w-md mx-4">
      <h2 class="text-xl font-bold mb-4">Add New Project</h2>
      <form id="project-form" class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1">Project Title *</label>
          <input type="text" name="title" required
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Description</label>
          <textarea name="description" rows="3"
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500"></textarea>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Project URL</label>
          <input type="url" name="url"
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Image URL</label>
          <input type="url" name="imageUrl"
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
        </div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-2 rounded-lg transition">Add Project</button>
          <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg hover:bg-gray-700 transition">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script define:vars={{ userData }}>
    let currentUser = userData;

    async function init() {
      loadProjects();
    }

    async function loadProjects() {
      try {
        const response = await fetch('/api/projects');
        const result = await response.json();
        const projects = result.data || [];
        renderProjects(projects);
      } catch (error) {
        console.error('Failed to load projects:', error);
      }
    }

    function escapeHtml(str: string): string {
      if (!str) return '';
      const htmlEntities: Record<string, string> = {
        '&': '&amp;', '<': '&lt;', '>': '&gt;',
        '"': '&quot;', "'": '&#x27;', '/': '&#x2F;',
      };
      return str.replace(/[&<>"'/]/g, (char) => htmlEntities[char] || char);
    }

    function renderProjects(projects) {
      const content = document.getElementById('projects-content');
      const isAdmin = currentUser?.role === 'maintainer';
      const showAddBtn = currentUser?.status === 'active';

      const projectsHtml = projects.length === 0
        ? '<p class="text-gray-500 text-center py-8">No projects yet</p>'
        : `<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          ${projects.map(p => `
            <div class="bg-gray-900 border border-gray-800 rounded-lg overflow-hidden hover:border-gray-700 transition group">
              ${p.imageUrl ? `
                <div class="aspect-video bg-gray-800 overflow-hidden">
                  <img src="${escapeHtml(p.imageUrl)}" alt="${escapeHtml(p.title)}" class="w-full h-full object-cover group-hover:scale-105 transition" onerror="this.parentElement.parentElement.classList.add('aspect-auto')">
                </div>
              ` : ''}
              <div class="p-4">
                <h3 class="font-semibold text-white mb-1">${escapeHtml(p.title)}</h3>
                <p class="text-sm text-gray-400 mb-3">${escapeHtml(p.description || '')}</p>
                <div class="flex items-center justify-between">
                  <span class="text-xs text-gray-500">by ${escapeHtml(p.userName || 'Unknown')}</span>
                  ${p.url ? `<a href="${escapeHtml(p.url)}" target="_blank" class="text-blue-400 hover:text-blue-300 text-sm">View →</a>` : ''}
                </div>
              </div>
            </div>
          `).join('')}
        </div>`;

      content!.innerHTML = `
        <div class="flex justify-between items-center mb-6">
          <div>
            <h1 class="text-2xl font-bold mb-2">Projects</h1>
            <p class="text-gray-400">Showcase your work</p>
          </div>
          ${showAddBtn ? `
            <button onclick="openModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Add Project
            </button>
          ` : ''}
        </div>
        ${projectsHtml}
      `;
    }

    window.openModal = () => document.getElementById('add-modal')?.classList.remove('hidden');
    window.closeModal = () => document.getElementById('add-modal')?.classList.add('hidden');

    document.getElementById('project-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);

      try {
        const response = await fetch('/api/projects', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            title: formData.get('title'),
            description: formData.get('description'),
            url: formData.get('url'),
            imageUrl: formData.get('imageUrl'),
          }),
        });

        if (!response.ok) throw new Error('Failed to add project');

        closeModal();
        form.reset();
        loadProjects();
      } catch (error) {
        alert('Failed to add project');
      }
    });

    init();
  </script>
</DashboardLayout>