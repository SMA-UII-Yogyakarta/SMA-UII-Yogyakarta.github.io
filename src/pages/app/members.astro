---
import DashboardLayout from '@layouts/DashboardLayout.astro';
const { user } = Astro.locals;
if (!user) return Astro.redirect('/login');
if (user.role !== 'maintainer') return Astro.redirect('/app/overview');
---

<DashboardLayout title="Members">
  <!-- Filter bar statis -->
  <div class="flex flex-col sm:flex-row gap-3 mb-4">
    <div class="flex gap-2" id="status-filters">
      <button onclick="filterMembers('')" data-status="" class="filter-btn px-3 py-1.5 rounded-lg text-sm bg-blue-600 text-white transition">Semua</button>
      <button onclick="filterMembers('pending')" data-status="pending" class="filter-btn px-3 py-1.5 rounded-lg text-sm bg-gray-800 text-gray-400 hover:text-white transition">Pending</button>
      <button onclick="filterMembers('active')" data-status="active" class="filter-btn px-3 py-1.5 rounded-lg text-sm bg-gray-800 text-gray-400 hover:text-white transition">Active</button>
    </div>
    <input type="text" id="search-input" placeholder="Cari nama, email, NISN..."
      class="flex-1 px-4 py-1.5 bg-gray-900 border border-gray-800 rounded-lg text-sm text-gray-100 placeholder-gray-500 focus:outline-none focus:border-blue-500"
      oninput="searchMembers(this.value)">
  </div>

  <div id="members-content">
    <div class="space-y-3">
      {Array.from({length: 5}).map(() => (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 flex items-center gap-4 animate-pulse">
          <div class="w-12 h-12 rounded-full bg-gray-800 flex-shrink-0"></div>
          <div class="flex-1 space-y-2">
            <div class="h-4 bg-gray-800 rounded w-1/3"></div>
            <div class="h-3 bg-gray-800 rounded w-1/2"></div>
          </div>
          <div class="h-6 w-16 bg-gray-800 rounded"></div>
        </div>
      ))}
    </div>
  </div>

  <script>
    let currentStatus = '';
    let currentSearch = '';

    function esc(str) {
      if (!str) return '';
      return String(str).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#x27;'}[c]));
    }

    const statusColors = {
      pending: 'text-yellow-400 bg-yellow-400/10',
      active: 'text-green-400 bg-green-400/10',
      rejected: 'text-red-400 bg-red-400/10',
    };

    async function load() {
      const params = new URLSearchParams();
      if (currentStatus) params.set('status', currentStatus);
      if (currentSearch) params.set('search', currentSearch);

      const res = await fetch(`/api/members?${params}`);
      const json = await res.json();
      const { members = [], total = 0 } = json.data || {};
      const content = document.getElementById('members-content');

      // Update filter button styles
      document.querySelectorAll('.filter-btn').forEach(btn => {
        const s = btn.dataset.status;
        btn.className = `filter-btn px-3 py-1.5 rounded-lg text-sm transition ${s === currentStatus ? 'bg-blue-600 text-white' : 'bg-gray-800 text-gray-400 hover:text-white'}`;
      });

      if (!members.length) {
        content.innerHTML = '<p class="text-gray-500 text-center py-8 text-sm">Tidak ada anggota ditemukan</p>';
        return;
      }

      content.innerHTML = `
        <p class="text-xs text-gray-500 mb-3">Total: ${total} anggota</p>
        <div class="space-y-3">
          ${members.map(m => `
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 flex items-center justify-between hover:border-gray-700 transition">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold flex-shrink-0">
                  ${esc(m.name).charAt(0).toUpperCase()}
                </div>
                <div>
                  <p class="font-semibold text-sm">${esc(m.name)}</p>
                  <p class="text-xs text-gray-400">${esc(m.class)} · ${esc(m.email)}</p>
                  ${m.tracks?.length ? `<p class="text-xs text-gray-500">${m.tracks.map(t => esc(t)).join(', ')}</p>` : ''}
                </div>
              </div>
              <div class="flex items-center gap-3 flex-shrink-0">
                <span class="px-2 py-0.5 rounded text-xs font-medium ${statusColors[m.status] || 'text-gray-400 bg-gray-800'}">${esc(m.status)}</span>
                ${m.status === 'pending' ? `
                  <button onclick="approve('${m.id}')" class="bg-green-600 hover:bg-green-500 text-white px-3 py-1 rounded text-xs transition">Approve</button>
                  <button onclick="reject('${m.id}')" class="bg-red-600 hover:bg-red-500 text-white px-3 py-1 rounded text-xs transition">Reject</button>
                ` : ''}
              </div>
            </div>
          `).join('')}
        </div>
      `;
    }

    window.filterMembers = (status) => { currentStatus = status; load(); };
    window.searchMembers = (val) => { currentSearch = val; load(); };

    window.approve = async (id) => {
      if (!confirm('Setujui anggota ini?')) return;
      const res = await fetch('/api/admin/approve', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ userId: id, action: 'approve' }) });
      if (res.ok) load(); else alert('Gagal');
    };

    window.reject = async (id) => {
      if (!confirm('Tolak dan hapus anggota ini?')) return;
      const res = await fetch('/api/admin/approve', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ userId: id, action: 'reject' }) });
      if (res.ok) load(); else alert('Gagal');
    };

    load();
  </script>
</DashboardLayout>