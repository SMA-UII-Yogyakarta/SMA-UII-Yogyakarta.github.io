---
import DashboardLayout from '@layouts/DashboardLayout.astro';
---

<DashboardLayout title="Activities">
  <div id="activities-content">
    <div class="text-center py-12">
      <div class="text-4xl mb-4">⏳</div>
      <p class="text-gray-400">Loading...</p>
    </div>
  </div>

  <!-- Add Activity Modal -->
  <div id="add-modal" class="hidden fixed inset-0 bg-black/50 flex items-center justify-center z-50">
    <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 w-full max-w-md mx-4">
      <h2 class="text-xl font-bold mb-4">Log Activity</h2>
      <form id="activity-form" class="space-y-4">
        <div>
          <label class="block text-sm text-gray-400 mb-1">Activity Type *</label>
          <select name="type" required
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
            <option value="contribution">Contribution</option>
            <option value="event">Event</option>
            <option value="workshop">Workshop</option>
            <option value="meeting">Meeting</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Title *</label>
          <input type="text" name="title" required
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Description</label>
          <textarea name="description" rows="3"
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500"></textarea>
        </div>
        <div>
          <label class="block text-sm text-gray-400 mb-1">Related URL</label>
          <input type="url" name="url"
            class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
        </div>
        <div class="flex gap-3">
          <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-2 rounded-lg transition">Log Activity</button>
          <button type="button" onclick="closeModal()" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg hover:bg-gray-700 transition">Cancel</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let currentUser = null;

    async function init() {
      try {
        const response = await fetch('/api/auth/me');
        if (!response.ok) {
          window.location.href = '/login';
          return;
        }

        const result = await response.json();
        currentUser = result.data;
        loadActivities();
      } catch (error) {
        console.error('Failed to load:', error);
        window.location.href = '/login';
      }
    }

    async function loadActivities() {
      try {
        const response = await fetch('/api/activities');
        const result = await response.json();
        const { activities, stats } = result.data || { activities: [], stats: [] };
        renderActivities(activities, stats);
      } catch (error) {
        console.error('Failed to load activities:', error);
      }
    }

    function escapeHtml(str: string): string {
      if (!str) return '';
      const htmlEntities: Record<string, string> = {
        '&': '&amp;', '<': '&lt;', '>': '&gt;',
        '"': '&quot;', "'": '&#x27;', '/': '&#x2F;',
      };
      return str.replace(/[&<>"'/]/g, (char) => htmlEntities[char] || char);
    }

    function formatDate(timestamp: number): string {
      return new Date(timestamp).toLocaleDateString('id-ID', {
        day: 'numeric', month: 'short', year: 'numeric'
      });
    }

    function renderActivities(activities, stats) {
      const content = document.getElementById('activities-content');
      const isAdmin = currentUser?.role === 'maintainer';
      const canLog = currentUser?.status === 'active';

      const typeColors: Record<string, string> = {
        contribution: 'bg-purple-500/20 text-purple-400',
        event: 'bg-blue-500/20 text-blue-400',
        workshop: 'bg-green-500/20 text-green-400',
        meeting: 'bg-yellow-500/20 text-yellow-400',
        other: 'bg-gray-500/20 text-gray-400',
      };

      const activitiesHtml = activities.length === 0
        ? '<p class="text-gray-500 text-center py-8">No activities logged yet</p>'
        : activities.map(a => `
          <div class="bg-gray-900 border border-gray-800 rounded-lg p-4 flex items-start gap-4 hover:border-gray-700 transition">
            <div class="w-10 h-10 rounded-lg ${typeColors[a.type] || 'bg-gray-800'} flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <h3 class="font-semibold text-white">${escapeHtml(a.title)}</h3>
                <span class="px-2 py-0.5 rounded text-xs ${typeColors[a.type] || 'bg-gray-800'}">${escapeHtml(a.type)}</span>
              </div>
              <p class="text-sm text-gray-400">${escapeHtml(a.description || '')}</p>
              <div class="flex items-center gap-4 mt-2 text-xs text-gray-500">
                <span>${escapeHtml(a.userName || 'Unknown')}</span>
                <span>${formatDate(a.createdAt)}</span>
                ${a.url ? `<a href="${escapeHtml(a.url)}" target="_blank" class="text-blue-400 hover:text-blue-300">View →</a>` : ''}
              </div>
            </div>
          </div>
        `).join('');

      content!.innerHTML = `
        <div class="flex justify-between items-center mb-6">
          <div>
            <h1 class="text-2xl font-bold mb-2">Activities</h1>
            <p class="text-gray-400">Track your contributions and events</p>
          </div>
          ${canLog ? `
            <button onclick="openModal()" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg transition flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
              </svg>
              Log Activity
            </button>
          ` : ''}
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          ${(stats || []).map(s => `
            <div class="bg-gray-900 border border-gray-800 rounded-lg p-4">
              <div class="text-2xl font-bold">${activities.filter(a => a.type === s.type).length}</div>
              <p class="text-sm text-gray-400 capitalize">${escapeHtml(s.type || '')}</p>
            </div>
          `).join('')}
        </div>
        <div class="space-y-3">
          ${activitiesHtml}
        </div>
      `;
    }

    window.openModal = () => document.getElementById('add-modal')?.classList.remove('hidden');
    window.closeModal = () => document.getElementById('add-modal')?.classList.add('hidden');

    document.getElementById('activity-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);

      try {
        const response = await fetch('/api/activities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: formData.get('type'),
            title: formData.get('title'),
            description: formData.get('description'),
            url: formData.get('url'),
          }),
        });

        if (!response.ok) throw new Error('Failed to log activity');

        closeModal();
        form.reset();
        loadActivities();
      } catch (error) {
        alert('Failed to log activity');
      }
    });

    init();
  </script>
</DashboardLayout>