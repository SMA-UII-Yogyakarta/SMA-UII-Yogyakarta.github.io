---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import Modal from '@components/app/Modal.astro';
import SkeletonList from '@components/app/SkeletonList.astro';
import { requireAuth } from '@lib/guards';
const redirect = requireAuth(Astro); if (redirect) return redirect;
const { user } = Astro.locals;
const canLog = user!.status === 'active' && user!.role !== 'alumni';
---

<DashboardLayout title="Activities">
  <PageHeader subtitle="Log kontribusi dan kegiatan" actionLabel={canLog ? "Log Activity" : undefined} />

  <div id="activities-meta" data-user-id={user!.id} data-user-role={user!.role} style="display:none"></div>

  <!-- Filter chips -->
  <div id="filter-bar" class="flex flex-wrap gap-2 mb-4">
    <button data-filter="" class="filter-chip active px-3 py-1.5 rounded-lg text-xs font-medium transition bg-blue-600 text-white">Semua</button>
    <button data-filter="contribution" class="filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700">Contribution</button>
    <button data-filter="event" class="filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700">Event</button>
    <button data-filter="workshop" class="filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700">Workshop</button>
    <button data-filter="meeting" class="filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700">Meeting</button>
    <button data-filter="other" class="filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700">Other</button>
  </div>

  <div id="activities-list"><SkeletonList count={5} /></div>

  {canLog && (
    <Modal id="add-modal" title="Log Activity">
      <form id="activity-form" class="space-y-3">
        <input type="hidden" name="id" value="">
        <div>
          <label class="block text-xs text-gray-400 mb-1">Tipe *</label>
          <select name="type" required class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500">
            <option value="contribution">Contribution</option>
            <option value="event">Event</option>
            <option value="workshop">Workshop</option>
            <option value="meeting">Meeting</option>
            <option value="other">Other</option>
          </select>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Judul *</label>
          <input type="text" name="title" required class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">Deskripsi</label>
          <textarea name="description" rows="3" class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500"></textarea>
        </div>
        <div>
          <label class="block text-xs text-gray-400 mb-1">URL</label>
          <input type="url" name="url" class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm focus:outline-none focus:border-blue-500">
        </div>
        <div class="flex gap-3 pt-2">
          <button type="submit" class="flex-1 bg-blue-600 hover:bg-blue-500 text-white py-2 rounded-lg text-sm transition">Simpan</button>
          <button type="button" id="close-modal" class="px-4 py-2 bg-gray-800 text-gray-300 rounded-lg text-sm hover:bg-gray-700 transition">Batal</button>
        </div>
      </form>
    </Modal>
  )}

  <script>
    import { esc, fmtDate, renderPagination, icons } from '@lib/ui';

    const meta = document.getElementById('activities-meta') as HTMLElement;
    const currentUserId = meta.dataset.userId || '';
    const isAdmin = meta.dataset.userRole === 'maintainer';
    const listEl = document.getElementById('activities-list') as HTMLElement;
    const modal = document.getElementById('add-modal');
    const form = document.getElementById('activity-form') as HTMLFormElement | null;

    let currentPage = 1;
    let currentFilter = '';
    const PAGE_LIMIT = 20;

    const typeColor: Record<string, string> = {
      contribution: 'bg-purple-500/20 text-purple-400',
      event:        'bg-blue-500/20 text-blue-400',
      workshop:     'bg-green-500/20 text-green-400',
      meeting:      'bg-yellow-500/20 text-yellow-400',
      other:        'bg-gray-500/20 text-gray-400',
    };

    function renderCard(a: any): string {
      const canEdit = a.userId === currentUserId || isAdmin;
      const canDelete = a.userId === currentUserId || isAdmin;
      return `
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 flex items-start gap-3 hover:border-gray-700 transition">
          <span class="px-2 py-0.5 rounded text-xs font-medium mt-0.5 shrink-0 ${typeColor[a.type] || typeColor.other}">${esc(a.type)}</span>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm">${esc(a.title)}</p>
            ${a.description ? `<p class="text-xs text-gray-400 mt-0.5">${esc(a.description)}</p>` : ''}
            <div class="flex items-center gap-3 mt-1 text-xs text-gray-500">
              <span>${esc(a.userName || '')}</span>
              <span>${fmtDate(a.createdAt)}</span>
              ${a.url ? `<a href="${esc(a.url)}" target="_blank" rel="noopener" class="text-blue-400 hover:text-blue-300">Lihat →</a>` : ''}
            </div>
          </div>
          <div class="flex gap-1 shrink-0">
            ${canEdit ? `
              <button data-action="edit"
                data-id="${esc(a.id)}" data-type="${esc(a.type)}" data-title="${esc(a.title)}"
                data-description="${esc(a.description || '')}" data-url="${esc(a.url || '')}"
                class="text-gray-600 hover:text-blue-400 transition p-1" title="Edit">${icons.edit}</button>
            ` : ''}
            ${canDelete ? `
              <button data-action="delete" data-id="${esc(a.id)}" data-title="${esc(a.title)}"
                class="text-gray-600 hover:text-red-400 transition p-1" title="Hapus">${icons.trash}</button>
            ` : ''}
          </div>
        </div>`;
    }

    async function load() {
      const params = new URLSearchParams({ page: String(currentPage), limit: String(PAGE_LIMIT) });
      if (currentFilter) params.set('type', currentFilter);
      const res = await fetch(`/api/activities?${params}`);
      const { data } = await res.json();
      const activities: any[] = data?.activities || [];
      const total: number = data?.total || 0;

      listEl.innerHTML = activities.length
        ? '<div class="space-y-3">' + activities.map(renderCard).join('') + '</div>'
        : '<div class="text-center py-10"><p class="text-gray-500 text-sm">Belum ada aktivitas</p></div>';

      renderPagination('activities-pagination', 'activities-list', total, currentPage, PAGE_LIMIT, 'aktivitas', 'window.actPage');
    }

    window.actPage = (page: number) => { currentPage = page; load(); window.scrollTo(0, 0); };

    // Event delegation
    listEl.addEventListener('click', async (e) => {
      const btn = (e.target as HTMLElement).closest<HTMLElement>('[data-action]');
      if (!btn) return;
      const action = btn.dataset.action;
      const { id, title, type, description, url } = btn.dataset;

      if (action === 'edit') {
        if (!form) return;
        (form.querySelector('[name="id"]') as HTMLInputElement).value = id || '';
        (form.querySelector('[name="title"]') as HTMLInputElement).value = title || '';
        (form.querySelector('[name="type"]') as HTMLSelectElement).value = type || 'contribution';
        (form.querySelector('[name="description"]') as HTMLTextAreaElement).value = description || '';
        (form.querySelector('[name="url"]') as HTMLInputElement).value = url || '';
        modal?.classList.remove('hidden');
        return;
      }

      if (action === 'delete') {
        if (!confirm(`Hapus activity "${title}"?`)) return;
        const res = await fetch(`/api/activities/${id}`, { method: 'DELETE' });
        res.ok ? load() : alert('Gagal menghapus activity');
      }
    });

    document.getElementById('open-modal')?.addEventListener('click', () => {
      form?.reset();
      const idField = form?.querySelector('[name="id"]') as HTMLInputElement | null;
      if (idField) idField.value = '';
      modal?.classList.remove('hidden');
    });
    document.getElementById('close-modal')?.addEventListener('click', () => { modal?.classList.add('hidden'); form?.reset(); });

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(form!);
      const activityId = fd.get('id') as string;
      const method = activityId ? 'PATCH' : 'POST';
      const url = activityId ? `/api/activities/${activityId}` : '/api/activities';

      const res = await fetch(url, {
        method,
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          type: fd.get('type'),
          title: fd.get('title'),
          description: fd.get('description') || null,
          url: fd.get('url') || null,
        }),
      });
      if (res.ok) { modal?.classList.add('hidden'); form.reset(); load(); }
      else alert('Gagal menyimpan');
    });

    // Filter chips
    document.querySelectorAll('.filter-chip').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-chip').forEach(b => {
          b.className = 'filter-chip px-3 py-1.5 rounded-lg text-xs font-medium transition bg-gray-800 text-gray-300 hover:bg-gray-700';
        });
        currentFilter = (btn as HTMLElement).dataset.filter || '';
        btn.className = 'filter-chip active px-3 py-1.5 rounded-lg text-xs font-medium transition bg-blue-600 text-white';
        currentPage = 1;
        load();
      });
    });

    load();
  </script>
</DashboardLayout>
