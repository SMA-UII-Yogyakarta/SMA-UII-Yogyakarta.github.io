---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import { requireMaintainer } from '@lib/guards';
const redirect = requireMaintainer(Astro); if (redirect) return redirect;
const { user } = Astro.locals;
---

<DashboardLayout title="Settings">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Kiri: Akun + Password -->
    <div class="lg:col-span-2 space-y-6">
      <!-- Account -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold mb-4">Akun</h2>
        <form id="account-form" class="space-y-4">
          <div>
            <label class="block text-sm text-gray-400 mb-1">Nama</label>
            <input type="text" name="name" value={user.name}
              class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Email</label>
            <input type="email" value={user.email} disabled
              class="w-full px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-gray-500 cursor-not-allowed">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">GitHub Username</label>
            <input type="text" name="githubUsername" value={user.githubUsername || ''}
              class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500"
              placeholder="username">
          </div>
          <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">
            Simpan Perubahan
          </button>
          <p id="save-msg" class="text-sm hidden"></p>
        </form>
      </div>

      <!-- Set Password -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <h2 class="text-lg font-bold mb-1">Set Password Anggota</h2>
        <p class="text-sm text-gray-400 mb-4">Atur password untuk anggota yang login via NISN/NIS</p>
        <form id="password-form" class="space-y-3">
          <div>
            <label class="block text-sm text-gray-400 mb-1">User ID</label>
            <input type="text" name="userId" required
              class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500"
              placeholder="User ID dari halaman Members">
          </div>
          <div>
            <label class="block text-sm text-gray-400 mb-1">Password Baru</label>
            <input type="password" name="password" required minlength="6"
              class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
          </div>
          <button type="submit" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">
            Set Password
          </button>
          <p id="pw-msg" class="text-sm hidden"></p>
        </form>
      </div>
    </div><!-- end kiri -->

    <!-- Kanan: Sistem -->
      <!-- Info -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6 self-start">
        <h2 class="text-lg font-bold mb-4">Sistem</h2>
        <div class="space-y-3 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-400">Database</span>
            <span class="text-blue-400">Turso (libSQL)</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-400">Framework</span>
            <span>Astro 6 + Node SSR</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-400">Total Anggota</span>
            <a href="/app/members" class="text-blue-400 hover:text-blue-300">Lihat →</a>
          </div>
        </div>
      </div>
    </div>

  <script>
    document.getElementById('account-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const msg = document.getElementById('save-msg');
      const res = await fetch('/api/profile', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: fd.get('name'), githubUsername: fd.get('githubUsername') }),
      });
      msg.textContent = res.ok ? '✓ Tersimpan' : '✗ Gagal menyimpan';
      msg.className = `text-sm ${res.ok ? 'text-green-400' : 'text-red-400'}`;
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 3000);
    });

    document.getElementById('password-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      const msg = document.getElementById('pw-msg');
      const res = await fetch('/api/admin/set-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ userId: fd.get('userId'), password: fd.get('password') }),
      });
      const json = await res.json();
      msg.textContent = res.ok ? '✓ Password berhasil diatur' : `✗ ${json.error || 'Gagal'}`;
      msg.className = `text-sm ${res.ok ? 'text-green-400' : 'text-red-400'}`;
      msg.classList.remove('hidden');
      if (res.ok) e.target.reset();
      setTimeout(() => msg.classList.add('hidden'), 3000);
    });
  </script>
</DashboardLayout>
