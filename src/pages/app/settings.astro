---
import DashboardLayout from '@layouts/DashboardLayout.astro';
const { user } = Astro.locals;
if (!user) return Astro.redirect('/login');
if (user.role !== 'maintainer') return Astro.redirect('/app');
---

<DashboardLayout title="Settings">
  <div id="settings-content">
    <div class="text-center py-12">
      <div class="text-4xl mb-4">⏳</div>
      <p class="text-gray-400">Loading...</p>
    </div>
  </div>

  <script>
    async function init() {
      renderSettings();
    }

    function escapeHtml(str: string): string {
      if (!str) return '';
      const htmlEntities: Record<string, string> = {
        '&': '&amp;', '<': '&lt;', '>': '&gt;',
        '"': '&quot;', "'": '&#x27;', '/': '&#x2F;',
      };
      return str.replace(/[&<>"'/]/g, (char) => htmlEntities[char] || char);
    }

    function renderSettings() {
      const content = document.getElementById('settings-content');

      content!.innerHTML = `
        <div class="max-w-2xl">
          <h1 class="text-2xl font-bold mb-6">Settings</h1>
          
          <div class="space-y-6">
            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
              <h2 class="text-lg font-bold mb-4">Account Settings</h2>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm text-gray-400 mb-1">Display Name</label>
                  <input type="text" value="Admin" 
                    class="w-full px-4 py-2 bg-gray-950 border border-gray-800 rounded-lg text-gray-100 focus:outline-none focus:border-blue-500">
                </div>
                <div>
                  <label class="block text-sm text-gray-400 mb-1">Email</label>
                  <input type="email" value="admin@smauiilab.sch.id" disabled
                    class="w-full px-4 py-2 bg-gray-900 border border-gray-800 rounded-lg text-gray-500 cursor-not-allowed">
                </div>
              </div>
            </div>

            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
              <h2 class="text-lg font-bold mb-4">Appearance</h2>
              <div class="flex items-center justify-between">
                <div>
                  <p class="font-medium">Dark Mode</p>
                  <p class="text-sm text-gray-400">Currently using dark theme</p>
                </div>
                <span class="px-3 py-1 bg-green-500/20 text-green-400 rounded text-sm">Active</span>
              </div>
            </div>

            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
              <h2 class="text-lg font-bold mb-4">Database</h2>
              <div class="space-y-3">
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium">Database Provider</p>
                    <p class="text-sm text-gray-400">SQLite / Turso</p>
                  </div>
                  <span class="text-blue-400">Connected</span>
                </div>
                <div class="flex items-center justify-between">
                  <div>
                    <p class="font-medium">Total Users</p>
                    <p class="text-sm text-gray-400">Registered in system</p>
                  </div>
                  <a href="/app/members" class="text-blue-400 hover:text-blue-300">View →</a>
                </div>
              </div>
            </div>

            <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
              <h2 class="text-lg font-bold mb-4 text-red-400">Danger Zone</h2>
              <div class="space-y-3">
                <button class="w-full text-left px-4 py-3 bg-gray-800 hover:bg-gray-700 rounded-lg transition">
                  <p class="font-medium">Export Data</p>
                  <p class="text-sm text-gray-400">Download all user data</p>
                </button>
                <button class="w-full text-left px-4 py-3 bg-red-900/20 hover:bg-red-900/30 border border-red-800 rounded-lg transition">
                  <p class="font-medium text-red-400">Clear Pending Registrations</p>
                  <p class="text-sm text-gray-400">Remove all pending applications</p>
                </button>
              </div>
            </div>
          </div>
        </div>
      `;
    }

    init();
  </script>
</DashboardLayout>