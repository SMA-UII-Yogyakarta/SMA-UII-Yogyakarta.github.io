---
import DashboardLayout from '@layouts/DashboardLayout.astro';
import PageHeader from '@components/app/PageHeader.astro';
import { requireAuth } from '@lib/guards';
const redirect = requireAuth(Astro); if (redirect) return redirect;
const { user } = Astro.locals;
const isMaintainer = user!.role === 'maintainer';
---

<DashboardLayout title="Settings">
  <PageHeader subtitle={isMaintainer ? 'Kelola akun dan konfigurasi sistem' : 'Kelola informasi akun kamu'} />

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">

      <!-- Akun — semua role -->
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold">Akun</h2>
          <div class="flex items-center gap-3">
            <p id="save-msg" class="text-sm hidden"></p>
            <button type="submit" form="account-form" class="bg-blue-600 hover:bg-blue-500 text-white px-4 py-2 rounded-lg text-sm transition">Simpan</button>
          </div>
        </div>
        <form id="account-form" class="space-y-4">
          <div>
            <label class="block text-xs text-gray-400 mb-1">Nama</label>
            <input type="text" name="name" value={user!.name}
              class="w-full px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm text-gray-100 focus:outline-none focus:border-blue-500">
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">Email</label>
            <input type="email" value={user!.email} disabled
              class="w-full px-3 py-2 bg-gray-900 border border-gray-800 rounded-lg text-sm text-gray-500 cursor-not-allowed">
          </div>
          <div>
            <label class="block text-xs text-gray-400 mb-1">GitHub</label>
            {user!.githubId ? (
              <div class="flex items-center justify-between px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg">
                <div class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  <a href={`https://github.com/${user!.githubUsername}`} target="_blank" class="text-sm text-gray-100 hover:text-blue-400 transition">
                    @{user!.githubUsername}
                  </a>
                  <span class="text-xs text-green-400">✓ Terhubung</span>
                </div>
              </div>
            ) : (
              <a href="/api/auth/github?returnTo=/app/settings"
                class="flex items-center gap-2 px-3 py-2 bg-gray-950 border border-gray-800 rounded-lg text-sm text-gray-400 hover:text-white hover:border-gray-600 transition w-full">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                Hubungkan dengan GitHub
              </a>
            )}
          </div>
        </form>
      </div>

    </div>

    <!-- Kanan: info kontekstual -->
    <div class="space-y-4">
      <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 self-start">
        <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Akun</h2>
        <div class="space-y-2 text-sm">
          <div class="flex justify-between">
            <span class="text-gray-400">Role</span>
            <span class="capitalize">{user!.role}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-400">Status</span>
            <span class={user!.status === 'active' ? 'text-green-400' : 'text-yellow-400'}>{user!.status}</span>
          </div>
          <div class="flex justify-between">
            <span class="text-gray-400">NISN</span>
            <span class="font-mono">{user!.nisn}</span>
          </div>
        </div>
      </div>

      {isMaintainer && (
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-5 self-start">
          <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-3">Sistem</h2>
          <div class="space-y-2 text-sm">
            <div class="flex justify-between">
              <span class="text-gray-400">Database</span>
              <span class="text-blue-400">Turso</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Framework</span>
              <span>Astro 6 SSR</span>
            </div>
            <div class="flex justify-between">
              <span class="text-gray-400">Anggota</span>
              <a href="/app/members" class="text-blue-400 hover:text-blue-300">Lihat →</a>
            </div>
          </div>
        </div>
      )}
    </div>
  </div>

  <script>
    document.getElementById('account-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const fd = new FormData(form);
      const msg = document.getElementById('save-msg') as HTMLElement | null;
      if (!msg) return;
      const res = await fetch('/api/profile', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: fd.get('name') }),
      });
      msg.textContent = res.ok ? '✓ Tersimpan' : '✗ Gagal';
      msg.className = `text-sm ${res.ok ? 'text-green-400' : 'text-red-400'}`;
      msg.classList.remove('hidden');
      setTimeout(() => msg.classList.add('hidden'), 3000);
    });
  </script>
</DashboardLayout>
