---
import '@styles/global.css';
import Sidebar from '@components/Sidebar.astro';
import Topbar from '@components/Topbar.astro';
import BottomNav from '@components/BottomNav.astro';

interface Props {
  title: string;
  noPadding?: boolean;
}

const { title, noPadding = false } = Astro.props;

const user = Astro.locals.user;
const role = (user?.role as 'maintainer' | 'member') ?? 'member';
const userName = user?.name ?? '';
const userEmail = user?.email ?? '';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
  <slot name="head" />
  <script is:inline>
    // Set sidebar state sebelum render — tidak ada FOUC
    (function() {
      const saved = localStorage.getItem('sidebar-collapsed');
      const w = window.innerWidth;
      let state;
      if (w < 640) state = 'hidden';
      else if (w < 1024) state = 'minimized';
      else state = (saved === 'true') ? 'minimized' : 'expanded';
      document.documentElement.setAttribute('data-sidebar', state);
    })();
  </script>
  <style is:global>
    /* ── Sidebar states ── */
    :root[data-sidebar="hidden"]    #sidebar { width: 16rem; transform: translateX(-100%); }
    :root[data-sidebar="minimized"] #sidebar { width: 4rem;  transform: translateX(0); }
    :root[data-sidebar="expanded"]  #sidebar { width: 16rem; transform: translateX(0); }
    :root[data-sidebar="overlay"]   #sidebar { width: 16rem; transform: translateX(0); z-index: 60; }

    /* ── Main content offset ── */
    :root[data-sidebar="hidden"]    #main-content { margin-left: 0; }
    :root[data-sidebar="minimized"] #main-content { margin-left: 4rem; }
    :root[data-sidebar="expanded"]  #main-content { margin-left: 16rem; }
    :root[data-sidebar="overlay"]   #main-content { margin-left: 4rem; }

    /* ── Label visibility ── */
    :root[data-sidebar="minimized"] #sidebar .sidebar-label { display: none; }
    :root[data-sidebar="expanded"]  #sidebar .sidebar-label,
    :root[data-sidebar="overlay"]   #sidebar .sidebar-label { display: unset; }

    /* ── Nav items: minimized = icon only ── */
    :root[data-sidebar="minimized"] #sidebar-nav { padding: 0.5rem; display: flex; flex-direction: column; gap: 0.25rem; }
    :root[data-sidebar="minimized"] #sidebar-nav a { justify-content: center; padding: 0; width: 2.5rem; height: 2.5rem; margin: 0 auto; }
    :root[data-sidebar="minimized"] #sidebar-header { padding: 1rem 0.5rem; }
    :root[data-sidebar="minimized"] #sidebar-header a { justify-content: center; }
    :root[data-sidebar="minimized"] #sidebar-user { padding: 0.5rem; }
    :root[data-sidebar="minimized"] #sidebar-user button { justify-content: center; padding: 0.5rem; }

    /* ── Nav items: overlay = full expanded (explicit reset) ── */
    :root[data-sidebar="overlay"] #sidebar-nav { padding: 1rem; display: flex; flex-direction: column; gap: 0.25rem; }
    :root[data-sidebar="overlay"] #sidebar-nav a { justify-content: flex-start; padding: 0.625rem 0.75rem; width: auto; height: auto; margin: 0; }
    :root[data-sidebar="overlay"] #sidebar-header { padding: 0 0.75rem; }
    :root[data-sidebar="overlay"] #sidebar-header a { justify-content: flex-start; }
    :root[data-sidebar="overlay"] #sidebar-user { padding: 1rem; }
    :root[data-sidebar="overlay"] #sidebar-user button { justify-content: flex-start; padding: 0.5rem; }

    #main-content { transition: margin-left 0.3s; }
    #sidebar { transition: width 0.3s, transform 0.3s; }

    .skeleton { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

    /* Desktop/tablet: reset padding bottom (no BottomNav) */
    @media (min-width: 640px) {
      #dashboard-content { padding-bottom: 1rem !important; }
    }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased overflow-hidden">
  <div class="flex h-dvh"  style="height: 100dvh">
    <Sidebar role={role} userName={userName} userEmail={userEmail} />

    <main id="main-content" class="flex-1 flex flex-col">
      <Topbar userName={userName}>
        <Fragment slot="title"><slot name="title">{title}</slot></Fragment>
        <slot name="topbar-actions" slot="actions" />
      </Topbar>

      <div class={noPadding ? 'flex-1 overflow-hidden' : 'flex-1 overflow-y-auto p-4'} id="dashboard-content" style="-webkit-overflow-scrolling: touch; padding-bottom: calc(3.5rem + env(safe-area-inset-bottom, 0px))">
        <slot />
      </div>
    </main>
  </div>

  <BottomNav role={role} />

  <div id="notification-dropdown" class="hidden fixed right-4 sm:right-6 top-16 w-80 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto">
    <div class="p-3 border-b border-gray-800">
      <h3 class="font-semibold text-sm">Notifikasi</h3>
    </div>
    <div id="notification-list" class="p-2">
      <p class="text-sm text-gray-500 text-center py-4">Tidak ada notifikasi</p>
    </div>
  </div>

  <div id="dashboard-meta" data-role={role} data-username={userName} style="display:none"></div>

  <script>
    import { initDashboard } from '@lib/dashboard-init';
    const meta = document.getElementById('dashboard-meta');
    initDashboard({
      role: meta?.dataset.role || 'member',
      userName: meta?.dataset.username || '',
    });
  </script>

  <script is:inline>
    console.log(
      '%c  SMA UII Lab  ',
      'background:#3b82f6;color:white;font-size:16px;font-weight:bold;padding:8px 16px;border-radius:6px'
    );
    console.log(
      '%cHei, kamu buka DevTools! 👀\n\nPlatform ini open source — fork, kontribusi, atau sekadar baca kodenya.\n\nAda sesuatu yang tersembunyi di sini → /app/about\n\nGitHub: https://github.com/SMA-UII-Yogyakarta',
      'color:#94a3b8;font-size:13px;line-height:1.8'
    );
  </script>
</body>
</html>
