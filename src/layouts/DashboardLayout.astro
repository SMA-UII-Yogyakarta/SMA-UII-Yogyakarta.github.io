---
import '@styles/global.css';
import { navItems } from '@lib/nav';
import Sidebar from '@components/Sidebar.astro';
import Topbar from '@components/Topbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
const role = (user?.role as 'maintainer' | 'member') ?? 'member';
const userName = user?.name ?? '';
const userEmail = user?.email ?? '';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
  <script is:inline>
    if (localStorage.getItem('sidebar-collapsed') === 'true') {
      document.querySelectorAll('.sidebar-label').forEach(el => el.classList.add('hidden'));
    }
  </script>
  <style is:global>
    #sidebar.sidebar-collapsed { width: 64px !important; }
    #sidebar.sidebar-collapsed .sidebar-label { display: none; }
    #main-content.sidebar-collapsed { margin-left: 64px !important; }
    #toggle-icon.rotate-180 { transform: rotate(180deg); }
    #sidebar.sidebar-collapsed #sidebar-header {
      flex-direction: column !important;
      padding: 0.75rem 0.5rem !important;
      gap: 0.5rem !important;
      justify-content: center !important;
    }
    #sidebar.sidebar-collapsed #sidebar-header a { display: none; }
    #sidebar.sidebar-collapsed #sidebar-toggle {
      margin: 0 auto;
      width: 2.25rem;
      height: 2.25rem;
    }
    .skeleton { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">
  <div class="flex min-h-screen">
    <Sidebar role={role} userName={userName} userEmail={userEmail} />

    <main id="main-content" class="flex-1 lg:ml-64 transition-all duration-300">
      <Topbar>
        <span slot="title">{title}</span>
        <span slot="user-name">{userName}</span>
      </Topbar>

      <div class="p-4 sm:p-6" id="dashboard-content">
        <slot />
      </div>
    </main>
  </div>

  <div id="notification-dropdown" class="hidden fixed right-4 sm:right-6 top-16 w-80 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto">
    <div class="p-3 border-b border-gray-800 flex items-center justify-between">
      <h3 class="font-semibold">Notifications</h3>
    </div>
    <div id="notification-list" class="p-2">
      <p class="text-sm text-gray-500 text-center py-4">No notifications</p>
    </div>
  </div>

  <script define:vars={{ userRole: role, userName }}>
    import { initDashboard } from '@lib/dashboard-init';
    initDashboard({ role: userRole, userName });
  </script>
</body>
</html>
