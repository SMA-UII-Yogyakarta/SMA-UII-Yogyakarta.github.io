---
import '@styles/global.css';
import Sidebar from '@components/Sidebar.astro';
import Topbar from '@components/Topbar.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;

const user = Astro.locals.user;
const role = (user?.role as 'maintainer' | 'member') ?? 'member';
const userName = user?.name ?? '';
const userEmail = user?.email ?? '';
---

<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
  <script is:inline>
    // Apply sidebar state BEFORE render to prevent flicker
    (function() {
      const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
      if (isCollapsed) {
        // Add style tag to apply collapsed state immediately
        const style = document.createElement('style');
        style.textContent = `
          #sidebar { width: 64px !important; }
          #sidebar .sidebar-label { display: none !important; }
          #main-content { margin-left: 64px !important; }
        `;
        document.head.appendChild(style);
        
        // Add class when DOM ready
        document.addEventListener('DOMContentLoaded', function() {
          document.getElementById('sidebar')?.classList.add('sidebar-collapsed');
          document.getElementById('main-content')?.classList.add('sidebar-collapsed');
        });
      }
    })();
  </script>
  <style is:global>
    #sidebar.sidebar-collapsed { width: 64px !important; }
    #sidebar.sidebar-collapsed .sidebar-label { display: none; }
    #main-content.sidebar-collapsed { margin-left: 64px !important; }
    
    /* Mobile: disable collapsed state, sidebar is full width overlay */
    @media (max-width: 1023px) {
      #sidebar.sidebar-collapsed {
        width: 16rem !important;
      }
      #main-content.sidebar-collapsed {
        margin-left: 0 !important;
      }
    }
    
    #sidebar.sidebar-collapsed #sidebar-header {
      padding: 1rem 0.5rem !important;
    }
    #sidebar.sidebar-collapsed #sidebar-header a {
      justify-content: center !important;
    }
    #sidebar.sidebar-collapsed #sidebar-nav {
      padding: 0.5rem !important;
      gap: 0.25rem !important;
      display: flex !important;
      flex-direction: column !important;
    }
    #sidebar.sidebar-collapsed #sidebar-nav a {
      justify-content: center !important;
      padding: 0 !important;
      width: 2.5rem !important;
      height: 2.5rem !important;
      margin: 0 auto !important;
    }
    #sidebar.sidebar-collapsed #sidebar-user {
      padding: 0.5rem !important;
    }
    #sidebar.sidebar-collapsed #sidebar-user button {
      justify-content: center !important;
      padding: 0.5rem !important;
    }
    .skeleton { animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
  </style>
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">
  <div class="flex min-h-screen">
    <Sidebar role={role} userName={userName} userEmail={userEmail} />

    <main id="main-content" class="flex-1 lg:ml-64 transition-all duration-300">
      <Topbar>
        <span slot="title">{title}</span>
      </Topbar>

      <div class="p-4" id="dashboard-content">
        <slot />
      </div>
    </main>
  </div>

  <div id="notification-dropdown" class="hidden fixed right-4 sm:right-6 top-16 w-80 max-w-[calc(100vw-2rem)] bg-gray-900 border border-gray-800 rounded-lg shadow-xl z-50 max-h-96 overflow-y-auto">
    <div class="p-3 border-b border-gray-800">
      <h3 class="font-semibold text-sm">Notifikasi</h3>
    </div>
    <div id="notification-list" class="p-2">
      <p class="text-sm text-gray-500 text-center py-4">Tidak ada notifikasi</p>
    </div>
  </div>

  <div id="dashboard-meta" data-role={role} data-username={userName} style="display:none"></div>

  <script>
    import { initDashboard } from '@lib/dashboard-init';
    const meta = document.getElementById('dashboard-meta');
    initDashboard({
      role: meta?.dataset.role || 'member',
      userName: meta?.dataset.username || '',
    });
  </script>
</body>
</html>
