---
import '@styles/global.css';

interface Props {
  title: string;
  subtitle?: string;
  wide?: boolean;
}

const { title, subtitle, wide = false } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMA UII Lab</title>
  <link rel="icon" href="/favicon.svg" />
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen">
  <!-- Ambient background -->
  <div class="fixed inset-0 pointer-events-none overflow-hidden" aria-hidden="true">
    <div class="absolute -top-40 -left-40 w-96 h-96 bg-blue-600/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 -right-40 w-80 h-80 bg-indigo-600/8 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-20 left-1/3 w-72 h-72 bg-blue-500/6 rounded-full blur-3xl"></div>
  </div>

  <div class="relative min-h-screen flex flex-col">
    <!-- Minimal header -->
    <header class="px-6 py-5 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2 text-white font-bold tracking-tight hover:opacity-80 transition">
        <span class="text-blue-400 text-xl">⬡</span>
        <span>SMA UII Lab</span>
      </a>
      <a href="/" class="text-sm text-gray-500 hover:text-gray-300 transition">← Beranda</a>
    </header>

    <!-- Main content -->
    <main class="flex-1 flex items-center justify-center px-4 py-12">
      <div class={`w-full ${wide ? 'max-w-2xl' : 'max-w-md'}`}>
        {(title || subtitle) && (
          <div class="text-center mb-8">
            <h1 class="text-2xl font-bold tracking-tight mb-2">{title}</h1>
            {subtitle && <p class="text-gray-400 text-sm">{subtitle}</p>}
          </div>
        )}

        <!-- Card -->
        <div class="bg-gray-900/60 backdrop-blur border border-gray-800/80 rounded-2xl p-8 shadow-2xl shadow-black/40">
          <slot />
        </div>
      </div>
    </main>

    <!-- Minimal footer -->
    <footer class="px-6 py-4 text-center text-xs text-gray-600">
      © 2026 SMA UII Lab · <a href="/about" class="hover:text-gray-400 transition">Tentang</a> · <a href="https://github.com/SMA-UII-Yogyakarta" target="_blank" class="hover:text-gray-400 transition">GitHub</a>
    </footer>
  </div>
</body>
</html>
