---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "SMAUII Lab — Ruang Eksplorasi Digital SMA UII Yogyakarta" } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMAUII Lab</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" />
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">
  <nav class="sticky top-0 z-50 bg-gray-950/80 backdrop-blur border-b border-gray-800">
    <div class="max-w-5xl mx-auto px-4 py-3 flex items-center gap-6">
      <a href="/" class="font-bold text-white flex items-center gap-2">
        <span class="text-blue-400">⬡</span> SMAUII Lab
      </a>
      <a href="/projects" class="text-sm text-gray-400 hover:text-white transition">Proyek</a>
      <a href="/tracks" class="text-sm text-gray-400 hover:text-white transition">Track</a>
      <a href="/members" class="text-sm text-gray-400 hover:text-white transition">Anggota</a>
      <div class="flex-1"></div>
      <a href="https://github.com/SMA-UII-Yogyakarta" target="_blank"
         class="text-sm border border-gray-700 px-3 py-1 rounded-md hover:border-blue-500 transition">
        GitHub →
      </a>
    </div>
  </nav>
  <slot />
  <footer class="border-t border-gray-800 mt-24 py-8 text-center text-sm text-gray-500">
    <p>SMAUII Lab · SMA Universitas Islam Indonesia Yogyakarta</p>
    <p class="mt-1">
      <a href="https://github.com/SMA-UII-Yogyakarta" class="text-blue-400 hover:underline">GitHub</a>
      · lab.smauiiyk.sch.id
    </p>
  </footer>
</body>
</html>
