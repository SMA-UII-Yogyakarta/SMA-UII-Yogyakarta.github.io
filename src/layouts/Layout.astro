---
import '@styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = "SMA UII Lab — Ruang eksplorasi digital buat yang suka ngulik teknologi" } = Astro.props;
const user = Astro.locals.user;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — SMA UII Lab</title>
  <meta name="description" content={description} />
  <link rel="icon" href="/favicon.svg" />
</head>
<body class="bg-gray-950 text-gray-100 font-sans antialiased">
  <nav class="fixed top-5 left-1/2 -translate-x-1/2 z-50 w-[calc(100%-2rem)] max-w-6xl">
    <div class="bg-gray-900/75 backdrop-blur-md border border-gray-700/40 rounded-full px-6 py-3.5 flex items-center gap-6 shadow-lg shadow-black/20">
      <!-- Logo -->
      <a href="/" class="font-bold text-white flex items-center gap-2 flex-shrink-0">
        <span class="text-blue-400">⬡</span> SMA UII Lab
      </a>

      <!-- Nav tengah -->
      <div class="flex-1 flex items-center justify-center gap-6">
        <a href="/tracks" class="text-gray-400 hover:text-white transition">Track</a>
        <a href="/learn" class="text-gray-400 hover:text-white transition">Belajar</a>
        <a href="/projects" class="text-gray-400 hover:text-white transition">Proyek</a>
        <a href="/members" class="text-gray-400 hover:text-white transition">Anggota</a>
        <a href="/about" class="text-gray-400 hover:text-white transition">Tentang</a>
      </div>

      <!-- Kanan: auth -->
      {user ? (
        <div class="relative flex-shrink-0" id="nav-profile">
          <button id="nav-profile-btn" class="flex items-center gap-2 hover:bg-gray-800 px-3 py-1.5 rounded-xl transition">
            <div class="w-7 h-7 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-xs flex-shrink-0">
              {user.name.charAt(0).toUpperCase()}
            </div>
            <span class="text-sm font-medium">{user.name.split(' ')[0]}</span>
            <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>
          <div id="nav-profile-dropdown" class="hidden absolute right-0 top-full mt-2 w-48 bg-gray-900 border border-gray-800 rounded-xl shadow-xl overflow-hidden">
            <a href="/app" class="flex items-center gap-2 px-4 py-2.5 text-sm text-gray-300 hover:bg-gray-800 hover:text-white transition">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
              Dashboard
            </a>
            <div class="border-t border-gray-800"></div>
            <form action="/api/auth/logout" method="POST">
              <button type="submit" class="w-full flex items-center gap-2 px-4 py-2.5 text-sm text-red-400 hover:bg-gray-800 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                Logout
              </button>
            </form>
          </div>
        </div>
      ) : (
        <div class="flex items-center gap-3 flex-shrink-0">
          <a href="/register" class="text-blue-400 hover:text-blue-300 transition">Daftar</a>
          <a href="/login" class="border border-gray-700 px-4 py-1.5 rounded-xl hover:border-blue-500 transition text-sm">Login</a>
        </div>
      )}
    </div>
  </nav>
  <script>
    const btn = document.getElementById('nav-profile-btn');
    const dropdown = document.getElementById('nav-profile-dropdown');
    btn?.addEventListener('click', (e) => { e.stopPropagation(); dropdown?.classList.toggle('hidden'); });
    document.addEventListener('click', () => dropdown?.classList.add('hidden'));
  </script>
  <div class="pt-20">
    <slot />
  </div>

  <!-- Event: sandikodev-birthday — hapus baris ini untuk menonaktifkan -->
  <script>
    import { launchBirthdayEvent } from '../events/sandikodev-birthday';
    launchBirthdayEvent();
  </script>
  <footer class="border-t border-gray-800 mt-24 py-12">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid md:grid-cols-4 gap-8 mb-8">
        <!-- About -->
        <div>
          <h3 class="font-bold mb-3 flex items-center gap-2">
            <span class="text-blue-400">⬡</span> SMA UII Lab
          </h3>
          <p class="text-sm text-gray-400">
            Ruang eksplorasi digital untuk siswa yang menekuni teknologi.
          </p>
        </div>
        
        <!-- Links -->
        <div>
          <h4 class="font-semibold mb-3 text-sm">Navigasi</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="/tracks" class="hover:text-blue-400 transition">Track</a></li>
            <li><a href="/learn" class="hover:text-blue-400 transition">Belajar</a></li>
            <li><a href="/projects" class="hover:text-blue-400 transition">Proyek</a></li>
            <li><a href="/members" class="hover:text-blue-400 transition">Anggota</a></li>
            <li><a href="/about" class="hover:text-blue-400 transition">Tentang</a></li>
          </ul>
        </div>
        
        <!-- Resources -->
        <div>
          <h4 class="font-semibold mb-3 text-sm">Resources</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/PHILOSOPHY.md" target="_blank" class="hover:text-blue-400 transition">Filosofi</a></li>
            <li><a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CONTRIBUTING.md" target="_blank" class="hover:text-blue-400 transition">Kontribusi</a></li>
            <li><a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/blob/main/CODE_OF_CONDUCT.md" target="_blank" class="hover:text-blue-400 transition">Code of Conduct</a></li>
            <li><a href="https://github.com/SMA-UII-Yogyakarta" target="_blank" class="hover:text-blue-400 transition">GitHub Org</a></li>
          </ul>
        </div>
        
        <!-- Contact -->
        <div>
          <h4 class="font-semibold mb-3 text-sm">Kontak</h4>
          <ul class="space-y-2 text-sm text-gray-400">
            <li><a href="https://github.com/sandikodev" target="_blank" class="hover:text-blue-400 transition">@sandikodev</a></li>
            <li><a href="https://github.com/SMA-UII-Yogyakarta/SMA-UII-Yogyakarta.github.io/issues" target="_blank" class="hover:text-blue-400 transition">Issues</a></li>
            <li class="text-gray-500">lab.smauiiyk.sch.id</li>
          </ul>
        </div>
      </div>
      
      <div class="border-t border-gray-800 pt-6 text-center text-sm text-gray-500">
        <p>© 2026 SMA UII Lab · SMA Universitas Islam Indonesia Yogyakarta</p>
        <p class="mt-1">Open Source · MIT License</p>
      </div>
    </div>
  </footer>
</body>
</html>
