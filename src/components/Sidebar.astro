---
import { navItems } from '@lib/nav';

interface Props {
  role: 'maintainer' | 'member';
  userName: string;
  userEmail: string;
}

const { role, userName, userEmail } = Astro.props;
const items = navItems[role] || navItems.member;
---

<aside id="sidebar" class="w-64 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full -translate-x-full lg:translate-x-0 transition-all duration-300 z-50">
  <div id="sidebar-header" class="h-16 px-3 border-b border-gray-800 flex items-center justify-between gap-2 transition-all duration-300">
    <a href="/" class="font-bold text-white flex items-center gap-2 whitespace-nowrap min-w-0 flex-1">
      <span class="text-blue-400 text-xl flex-shrink-0">⬡</span> 
      <span class="sidebar-label truncate">SMA UII Lab</span>
    </a>
    <button id="sidebar-toggle" class="text-gray-400 hover:text-white hover:bg-gray-800 p-2 rounded-lg transition flex items-center justify-center flex-shrink-0 w-9 h-9" title="Collapse sidebar">
      <svg id="toggle-icon" class="w-4 h-4 transition-transform duration-300 block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"/>
      </svg>
    </button>
  </div>

  <nav class="flex-1 p-4 space-y-1 overflow-y-auto" id="sidebar-nav">
    {items.map(item => (
      <a 
        href={item.href} 
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition text-gray-400 hover:text-white" 
        data-nav={item.label.toLowerCase()}
        title={item.label}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
        </svg>
        <span class="sidebar-label whitespace-nowrap">{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="p-4 border-t border-gray-800" id="sidebar-user">
    <div class="flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold flex-shrink-0">
        {userName.charAt(0).toUpperCase()}
      </div>
      <div class="flex-1 min-w-0 sidebar-label">
        <p class="text-sm font-medium truncate">{userName}</p>
        <p class="text-xs text-gray-500 truncate">{userEmail}</p>
      </div>
    </div>
    <form action="/api/auth/logout" method="POST" class="mt-3">
      <button type="submit" class="w-full text-left text-sm text-gray-400 hover:text-white transition py-2 sidebar-label">
        Logout
      </button>
    </form>
  </div>
</aside>

<script>
  const sidebar = document.getElementById('sidebar');
  const mainContent = document.getElementById('main-content');
  const toggleIcon = document.getElementById('toggle-icon');
  const toggleBtn = document.getElementById('sidebar-toggle');
  
  function updateSidebarState(isCollapsed: boolean) {
    if (isCollapsed) {
      sidebar?.classList.add('sidebar-collapsed');
      mainContent?.classList.add('sidebar-collapsed');
      toggleIcon?.classList.add('rotate-180');
      toggleBtn?.setAttribute('title', 'Expand sidebar');
    } else {
      sidebar?.classList.remove('sidebar-collapsed');
      mainContent?.classList.remove('sidebar-collapsed');
      toggleIcon?.classList.remove('rotate-180');
      toggleBtn?.setAttribute('title', 'Collapse sidebar');
    }
    localStorage.setItem('sidebar-collapsed', String(isCollapsed));
    document.querySelectorAll('.sidebar-label').forEach(el => el.classList.toggle('hidden', isCollapsed));
  }

  const savedState = localStorage.getItem('sidebar-collapsed') === 'true';
  updateSidebarState(savedState);

  toggleBtn?.addEventListener('click', () => {
    updateSidebarState(!sidebar?.classList.contains('sidebar-collapsed'));
  });
</script>