---
import { navItems } from '@lib/nav';

interface Props {
  role: 'maintainer' | 'member';
  userName: string;
  userEmail: string;
}

const { role, userName, userEmail } = Astro.props;
const items = navItems[role] || navItems.member;
---

<aside id="sidebar" class="w-64 bg-gray-900 border-r border-gray-800 flex flex-col fixed h-full -translate-x-full lg:translate-x-0 transition-all duration-300 z-50">
  <div id="sidebar-header" class="h-16 px-3 border-b border-gray-800 flex items-center justify-center transition-all duration-300">
    <a href="/" class="font-bold text-white flex items-center gap-2 whitespace-nowrap">
      <span class="text-blue-400 text-xl flex-shrink-0">⬡</span> 
      <span class="sidebar-label truncate">SMA UII Lab</span>
    </a>
  </div>

  <nav class="flex-1 p-4 space-y-1 overflow-y-auto" id="sidebar-nav">
    {items.map(item => (
      <a 
        href={item.href} 
        class="flex items-center gap-3 px-3 py-2.5 rounded-lg hover:bg-gray-800 transition text-gray-400 hover:text-white" 
        data-nav={item.label.toLowerCase()}
        title={item.label}
      >
        <svg class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon}/>
        </svg>
        <span class="sidebar-label whitespace-nowrap">{item.label}</span>
      </a>
    ))}
  </nav>

  <div class="p-4 border-t border-gray-800" id="sidebar-user">
    <button id="profile-dropdown-btn" class="w-full flex items-center gap-3 hover:bg-gray-800 p-2 rounded-lg transition group">
      <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold text-sm flex-shrink-0 group-hover:ring-2 group-hover:ring-blue-500 transition">
        {userName.charAt(0).toUpperCase()}
      </div>
      <div class="flex-1 min-w-0 sidebar-label text-left">
        <p class="text-sm font-medium truncate">{userName}</p>
        <p class="text-xs text-gray-500 truncate">{userEmail}</p>
      </div>
      <svg class="w-4 h-4 text-gray-400 sidebar-label flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/>
      </svg>
    </button>

    <div id="profile-dropdown" class="hidden mt-2 space-y-1">
      <a href="/app/profile" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition sidebar-label">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Profile
      </a>
      <a href="/app/settings" class="flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition sidebar-label">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Settings
      </a>
      <form action="/api/auth/logout" method="POST">
        <button id="logout-btn" type="submit" class="w-full flex items-center gap-2 px-3 py-2 text-sm text-gray-400 hover:text-red-400 hover:bg-gray-800 rounded-lg transition sidebar-label">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </button>
      </form>
    </div>
  </div>
</aside>

<!-- Profile Modal (for collapsed sidebar) -->
<div id="profile-modal" class="hidden fixed bottom-0 left-16 z-50 mb-4 ml-2">
  <div class="bg-gray-900 border border-gray-800 rounded-xl shadow-xl w-64">
    <div class="p-4 border-b border-gray-800 flex items-center gap-3">
      <div class="w-10 h-10 rounded-full bg-blue-600 flex items-center justify-center text-white font-bold">
        {userName.charAt(0).toUpperCase()}
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium truncate">{userName}</p>
        <p class="text-xs text-gray-500 truncate">{userEmail}</p>
      </div>
    </div>
    <div class="p-2 space-y-1">
      <a href="/app/profile" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        Profile
      </a>
      <a href="/app/settings" class="flex items-center gap-3 px-3 py-2.5 text-sm text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        Settings
      </a>
      <form action="/api/auth/logout" method="POST">
        <button type="submit" class="w-full flex items-center gap-3 px-3 py-2.5 text-sm text-gray-400 hover:text-red-400 hover:bg-gray-800 rounded-lg transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
          </svg>
          Logout
        </button>
      </form>
    </div>
  </div>
</div>

<script>
  const sidebar = document.getElementById('sidebar');
  const profileBtn = document.getElementById('profile-dropdown-btn');
  const profileDropdown = document.getElementById('profile-dropdown');
  const profileModal = document.getElementById('profile-modal');

  profileBtn?.addEventListener('click', () => {
    const isCollapsed = sidebar?.classList.contains('sidebar-collapsed');
    
    if (isCollapsed) {
      // Show modal when collapsed
      profileModal?.classList.toggle('hidden');
    } else {
      // Show dropdown when expanded
      profileDropdown?.classList.toggle('hidden');
    }
  });

  // Close modal when clicking outside
  document.addEventListener('click', (e) => {
    if (profileModal && !profileModal.classList.contains('hidden')) {
      const target = e.target as HTMLElement;
      if (!profileModal.contains(target) && !profileBtn?.contains(target)) {
        profileModal.classList.add('hidden');
      }
    }
  });
</script>