<header class="sticky top-0 z-40 bg-gray-950/80 backdrop-blur border-b border-gray-800 px-4 h-14 flex items-center justify-between">
  <div class="flex items-center gap-3 min-w-0">
    <!-- Hamburger: tampil di semua ukuran, behavior beda per breakpoint -->
    <button id="sidebar-toggle" class="hidden sm:flex text-gray-400 hover:text-white hover:bg-gray-800 p-2 rounded-lg transition flex-shrink-0 touch-manipulation items-center justify-center" title="Toggle sidebar" style="min-width:44px;min-height:44px;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
    <span class="font-semibold text-sm truncate flex items-center min-w-0"><slot name="title" /></span>
  </div>

  <div class="flex items-center gap-2">
    <slot name="actions" />
    <button id="notification-btn" class="relative text-gray-400 hover:text-white p-2 rounded-lg hover:bg-gray-800 transition flex-shrink-0 touch-manipulation" title="Notifikasi" style="min-width:44px;min-height:44px;display:flex;align-items:center;justify-content:center;">
      <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
      </svg>
      <span id="notification-badge" class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full hidden"></span>
    </button>
  </div>
</header>
