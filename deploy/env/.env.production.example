# ==============================================================================
# Digital Lab School — Production Environment Template
# ==============================================================================
# 1. Copy file ini ke root project sebagai .env:
#      cp deploy/env/.env.production.example .env
# 2. Isi semua nilai yang diperlukan (yang tanpa default)
# 3. Jangan commit .env ke git (already in .gitignore)
#
# Semua nilai bisa di-override via Docker --env-file atau environment host.
# ==============================================================================

# -----------------------------------------------------------------------------
# SITE — Identitas platform
# -----------------------------------------------------------------------------
PUBLIC_SITE_URL=https://lab.smauiiyk.sch.id
# Domain publik, dipakai untuk OAuth callback & tautan di email.
# Development: http://localhost:4321
# Production:  https://lab.domain.sch.id

PUBLIC_SITE_NAME=SMA UII Lab
# Nama yang tampil di title bar & header.

# -----------------------------------------------------------------------------
# DATABASE — Turso (LibSQL)
# -----------------------------------------------------------------------------
TURSO_URL=libsql://your-db-name.turso.io
# URL koneksi Turso. Buat database di https://turso.tech
# Format: libsql://<db-name>.<org>.turso.io
# Untuk development lokal: file:local.db

TURSO_TOKEN=
# Turso auth token. Generate via: turso db tokens create <db-name>

# -----------------------------------------------------------------------------
# AUTH — GitHub OAuth
# -----------------------------------------------------------------------------
OAUTH_GITHUB_CLIENT_ID=
# Dapat dari: GitHub → Settings → Developer settings → OAuth Apps
# Development callback: http://localhost:4321/api/auth/github/callback
# Production callback:  https://lab.domain.sch.id/api/auth/github/callback

OAUTH_GITHUB_CLIENT_SECRET=
# Client secret dari OAuth App yang sama.

# -----------------------------------------------------------------------------
# SLIMS — Verifikasi Data Siswa (opsional)
# -----------------------------------------------------------------------------
SLIMS_API_URL=
# URL internal ke plugin SLiMS untuk verifikasi NISN siswa.
# Format: http://slims-container/plugins/lab-digital-api
# Biarkan kosong untuk memakai mock data (development).

SLIMS_API_KEY=
# API key yang sama dengan yang dikonfigurasi di plugin SLiMS.
# Generate: openssl rand -hex 32

# -----------------------------------------------------------------------------
# EMAIL — Resend (opsional)
# -----------------------------------------------------------------------------
RESEND_API_KEY=
# API key dari https://resend.com
# Free tier: 3,000 emails/month.
# Biarkan kosong jika tidak pakai email notification.

# -----------------------------------------------------------------------------
# AUTH — Secret untuk JWT Token (reset password, dll)
# -----------------------------------------------------------------------------
AUTH_SECRET=
# Secret key untuk signing JWT token.
# Wajib diisi jika fitur reset password aktif.
# Generate: openssl rand -hex 32
# Fallback ke RESEND_API_KEY jika tidak diisi.
